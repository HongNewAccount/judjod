@model IEnumerable<WebApplication1.Models.Report>

@{
    ViewData["Title"] = "Reports";

    string GetPriorityClass(string priority) => priority switch
    {
        "High" => "bg-danger",
        "Medium" => "bg-warning text-dark",
        "Low" => "bg-info",
        "Urgent" => "bg-danger",
        _ => "bg-secondary"
    };

    string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "InProgress" => "bg-primary",
        "Resolved" => "bg-success",
        "Closed" => "bg-secondary",
        _ => "bg-secondary"
    };
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5">Reports</h1>
            <p class="text-muted">All problem reports and service requests</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">Create New Report</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Reported By</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td>
                                <strong>@report.Title</strong>
                                <br />
                                <small class="text-muted">@report.Description?.Substring(0, Math.Min(50, report.Description.Length))...</small>
                            </td>
                            <td>
                                <span class="badge @GetPriorityClass(report.Priority)">@report.Priority</span>
                            </td>
                            <td>
                                <span class="badge @GetStatusClass(report.Status)">@report.Status</span>
                            </td>
                            <td>
                                @report.CreatedByUser?.FirstName @report.CreatedByUser?.LastName
                            </td>
                            <td>
                                <small>@report.ReportedDate.ToString("MMM dd, yyyy HH:mm")</small>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@report.Id" class="btn btn-sm btn-info">View</a>
                                <a asp-action="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-warning">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No reports found. <a asp-action="Create" class="alert-link">Create one now</a>
        </div>
    }
</div>
