@model IEnumerable<WebApplication1.Models.Report>

@{
    ViewData["Title"] = "Reports";

    string GetPriorityClass(string priority) => priority switch
    {
        "High" => "bg-danger text-white",
        "Medium" => "bg-warning text-white",
        "Low" => "bg-success text-white",
        "Urgent" => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };

    string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-secondary text-white",
        "InProgress" => "bg-primary text-white",
        "Resolved" => "bg-success text-white",
        "Closed" => "bg-secondary text-white",
        _ => "bg-secondary text-white"
    };
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Reports</h1>
            <p class="page-subtitle">All problem reports and service requests</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-action">
                <i class="fas fa-plus me-2"></i>Create New Report
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Date</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Reported By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td>
                                <strong>@report.Title</strong>
                                <br />
                                <small class="text-muted">@report.Description?.Substring(0, Math.Min(50, report.Description.Length))...</small>
                            </td>
                            <td>
                                <small>@report.ReportedDate.ToString("dd MMM yyyy HH:mm")</small>
                            </td>
                            <td>
                                <span class="badge @GetPriorityClass(report.Priority)">@report.Priority</span>
                            </td>
                            <td>
                                <span class="badge @GetStatusClass(report.Status)">@report.Status</span>
                            </td>
                            <td>
                                @report.CreatedByUser?.FirstName @report.CreatedByUser?.LastName
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@report.Id" class="btn btn-sm text-white" style="background-color: #28a745;">View</a>
                                <a asp-action="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-info text-white">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No reports found. <a asp-action="Create" class="alert-link">Create one now</a>
        </div>
    }
</div>
