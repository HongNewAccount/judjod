@model IEnumerable<WebApplication1.Models.Report>

@{
    ViewData["Title"] = "Reports";
    var stats = (Dictionary<string, int>)ViewBag.Stats ?? new Dictionary<string, int>();
    var searchTerm = ViewBag.SearchTerm ?? "";
    var sortBy = ViewBag.SortBy ?? "latest";
    var statusFilter = ViewBag.StatusFilter ?? "all";

    string GetPriorityClass(string priority) => priority switch
    {
        "High" => "bg-danger text-white",
        "Medium" => "bg-warning text-white",
        "Low" => "bg-success text-white",
        "Urgent" => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };

    string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-secondary text-white",
        "InProgress" => "bg-primary text-white",
        "Resolved" => "bg-success text-white",
        "Closed" => "bg-secondary text-white",
        _ => "bg-secondary text-white"
    };
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Reports</h1>
            <p class="page-subtitle">All problem reports and service requests</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-action">
                <i class="fas fa-plus me-2"></i>Create New Report
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-4">
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-total">
                <div class="stat-card-icon"><i class="fas fa-file-alt"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("TotalReports", 0)</div>
                    <div class="stat-card-label">Total Reports</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-secondary">
                <div class="stat-card-icon"><i class="fas fa-clock"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("PendingReports", 0)</div>
                    <div class="stat-card-label">Pending</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-icon"><i class="fas fa-spinner"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("InProgressReports", 0)</div>
                    <div class="stat-card-label">In Progress</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-success">
                <div class="stat-card-icon"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("CompletedReports", 0)</div>
                    <div class="stat-card-label">Completed</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search reports..." value="@searchTerm" />
                </div>
                <div class="col-md-3">
                    <select name="statusFilter" class="form-select">
                        <option value="all" selected="@(statusFilter == "all")">All Status</option>
                        <option value="Pending" selected="@(statusFilter == "Pending")">Pending</option>
                        <option value="InProgress" selected="@(statusFilter == "InProgress")">In Progress</option>
                        <option value="Completed" selected="@(statusFilter == "Completed")">Completed</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="latest" selected="@(sortBy == "latest")">Latest</option>
                        <option value="oldest" selected="@(sortBy == "oldest")">Oldest</option>
                        <option value="priority-high" selected="@(sortBy == "priority-high")">Priority</option>
                        <option value="title-asc" selected="@(sortBy == "title-asc")">Title (A-Z)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-action w-100">Search</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Reported By</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@report.Title</strong>
                                        <br />
                                        <small class="text-muted">@report.Description?.Substring(0, Math.Min(50, report.Description.Length))...</small>
                                    </td>
                                    <td>
                                        <small>@report.ReportedDate.ToString("dd MMM yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        <span class="badge @GetPriorityClass(report.Priority)">@report.Priority</span>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusClass(report.Status)">@report.Status</span>
                                    </td>
                                    <td>
                                        @report.CreatedByUser?.FirstName @report.CreatedByUser?.LastName
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@report.Id" class="btn btn-sm btn-success">View</a>
                                        <a asp-action="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-info">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center">
                    <i class="fas fa-inbox" style="font-size: 48px; color: #ccc;"></i>
                    <p class="text-muted mt-3">No reports found. <a asp-action="Create">Create one now</a></p>
                </div>
            }
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-light">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        @{
                            int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                            int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                        }

                        <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-statusFilter="@statusFilter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@sortBy" asp-route-page="@(ViewBag.CurrentPage - 1)" aria-label="Previous">&lt;</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-statusFilter="@statusFilter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@sortBy" asp-route-page="@i">@i</a>
                                </li>
                            }
                        }

                        @if (endPage < ViewBag.TotalPages)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-statusFilter="@statusFilter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@sortBy" asp-route-page="@(ViewBag.CurrentPage + 1)" aria-label="Next">&gt;</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
