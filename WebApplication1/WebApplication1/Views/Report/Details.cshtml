@model WebApplication1.Models.Report

@{
    ViewData["Title"] = "Report Details";

    string GetPriorityClass(string priority) => priority switch
    {
        "High" => "bg-danger",
        "Medium" => "bg-warning text-dark",
        "Low" => "bg-info",
        "Urgent" => "bg-danger",
        _ => "bg-secondary"
    };

    string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "InProgress" => "bg-primary",
        "Resolved" => "bg-success",
        "Closed" => "bg-secondary",
        _ => "bg-secondary"
    };
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1>@Model.Title</h1>
            <p class="text-muted">Reported by @Model.CreatedByUser?.FirstName @Model.CreatedByUser?.LastName on @Model.ReportedDate.ToString("MMM dd, yyyy HH:mm")</p>
        </div>
        <div class="col-auto">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Report Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Description:</strong></p>
                    <p>@Model.Description</p>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Priority:</strong> <span class="badge @GetPriorityClass(Model.Priority)">@Model.Priority</span></p>
                            <p><strong>Status:</strong> <span class="badge @GetStatusClass(Model.Status)">@Model.Status</span></p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Scheduled Date:</strong> @Model.ScheduledDate?.ToString("MMM dd, yyyy HH:mm")</p>
                            <p><strong>Location:</strong> @Model.Location @(Model.IsOnSite ? "(On-site)" : "(Off-site)")</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Comments.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Comments (@Model.Comments.Count)</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="mb-3 pb-3 border-bottom">
                                <strong>@comment.User?.FirstName @comment.User?.LastName</strong>
                                <small class="text-muted d-block">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                                <p class="mt-2">@comment.Content</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Assignments</h5>
                </div>
                <div class="card-body">
                    @if (Model.Assignments.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var assignment in Model.Assignments)
                            {
                                <div class="list-group-item">
                                    <strong>@assignment.AssignedToUser?.FirstName @assignment.AssignedToUser?.LastName</strong>
                                    <br />
                                    <small class="text-muted">
                                        Status: <span class="badge bg-info">@assignment.Status</span>
                                    </small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No assignments yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
