@model WebApplication1.Models.User

@{
    ViewData["Title"] = "Create User";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0 fw-bold">Create New User</h6>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="Create">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                        {
                            <div class="alert alert-danger small py-2">
                                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                { <div>@err.ErrorMessage</div> }
                            </div>
                        }

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-semibold small">ชื่อ *</label>
                                <input type="text" class="form-control" asp-for="FirstName" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold small">นามสกุล</label>
                                <input type="text" class="form-control" asp-for="LastName" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Username *</label>
                            <input type="text" class="form-control" asp-for="Username" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Password *</label>
                            <input type="password" class="form-control" asp-for="PasswordHash" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Role</label>
                            <select class="form-control" asp-for="Role">
                                <option value="User">User (Viewer)</option>
                                <option value="Admin">Admin (Can Edit)</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-secondary flex-fill">Cancel</a>
                            <button type="submit" class="btn btn-modal-action flex-fill">Create User</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
