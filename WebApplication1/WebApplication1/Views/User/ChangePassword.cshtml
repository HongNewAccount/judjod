@{
    ViewData["Title"] = "Change Password";
    var target = ViewBag.TargetUser as WebApplication1.Models.User;
    var currentUserId = Context.Session.GetInt32("UserId");
    var isSelf = currentUserId == target?.Id;
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">

            <div class="page-header mb-4">
                <h1 class="page-title">Change Password</h1>
                <p class="page-subtitle">@target?.FirstName @target?.LastName</p>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger small py-2">@ViewBag.ErrorMessage</div>
                    }

                    <form method="post" asp-action="ChangePassword" asp-route-id="@target?.Id">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">New Password <span class="text-danger">*</span></label>
                            <input type="password" name="newPassword" class="form-control" placeholder="อย่างน้อย 6 ตัวอักษร" required minlength="6" autocomplete="new-password" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold small">Confirm Password <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" class="form-control" placeholder="ยืนยันรหัสผ่านใหม่" required autocomplete="new-password" />
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@target?.Id" class="btn btn-secondary flex-fill">Cancel</a>
                            <button type="submit" class="btn btn-modal-action flex-fill">
                                <i class="fas fa-key me-1"></i>Change Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
