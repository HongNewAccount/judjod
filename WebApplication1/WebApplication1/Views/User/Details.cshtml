@model WebApplication1.Models.User

@{
    ViewData["Title"] = "User Profile";
    var viewerRole = Context.Session.GetString("UserRole");
    var isAdminViewer = viewerRole == "Admin";
    var projectsOwnedCount = (int)(ViewBag.ProjectsOwnedCount ?? 0);
    var projectsCreatedCount = (int)(ViewBag.ProjectsCreatedCount ?? 0);
    var eventsAttendedCount = (int)(ViewBag.EventsAttendedCount ?? 0);
    var recentActivity = (List<WebApplication1.Models.ActivityLog>)(ViewBag.RecentActivity ?? new List<WebApplication1.Models.ActivityLog>());

    string GetRoleClass(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Manager" => "bg-warning text-dark",
        "User" => "bg-info",
        _ => "bg-secondary"
    };

    string GetStatusClass(string status) => status switch
    {
        "Available" => "bg-success",
        "Unavailable" => "bg-warning text-dark",
        "Absent" => "bg-danger",
        _ => "bg-secondary"
    };

    string GetActionBadgeClass(string actionType) => actionType switch
    {
        "Created" => "bg-secondary",
        "StatusChanged" => "bg-primary",
        "NameChanged" => "bg-primary",
        "DescriptionChanged" => "bg-primary",
        "StartDateChanged" => "bg-primary",
        "EndDateChanged" => "bg-primary",
        "OwnerAdded" => "bg-warning",
        "OwnerRemoved" => "bg-danger",
        "Deleted" => "bg-danger",
        "FavoriteAdded" => "bg-warning",
        "FavoriteRemoved" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">User Dashboard</h1>
            <p class="page-subtitle">Profile, activity and stats for this user</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card">
                <div class="card-body text-center p-4">
                    @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                    {
                        <img src="@Model.ProfileImagePath" alt="Profile" class="rounded-circle mb-3" width="120" height="120" style="object-fit: cover;" />
                    }
                    else
                    {
                        <div class="avatar-circle mb-3 mx-auto">
                            @Model.FirstName[0]@Model.LastName[0]
                        </div>
                    }
                    <h3>@Model.FirstName @Model.LastName</h3>
                    @if (!string.IsNullOrEmpty(Model.NickName))
                    {
                        <p class="text-muted mb-2">@Model.NickName</p>
                    }

                    <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                        <span class="badge @GetRoleClass(Model.Role)">@(Model.Role ?? "User")</span>
                        <span class="badge @GetStatusClass(Model.Status)">@(Model.Status ?? "Available")</span>
                        @if (!Model.IsActive)
                        {
                            <span class="badge bg-danger"><i class="fas fa-ban me-1"></i>Banned</span>
                        }
                        @if (Model.ProjectAccessSuspended)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-pause-circle me-1"></i>Project Access Suspended</span>
                        }
                    </div>

                    <div class="text-start">
                        <p class="mb-2"><strong>Position:</strong> @(Model.Position ?? "N/A")</p>
                        <p class="mb-2"><strong>Work Location:</strong> @(Model.WorkLocation ?? "N/A")</p>
                        <p class="mb-2">
                            <strong>Email:</strong>
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </p>
                        <p class="mb-2">
                            <strong>Phone:</strong>
                            @if (!string.IsNullOrEmpty(Model.Phone))
                            {
                                <a href="tel:@Model.Phone">@Model.Phone</a>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </p>
                        @if (!string.IsNullOrEmpty(Model.Links))
                        {
                            <p class="mb-2"><strong>Links:</strong> @Model.Links</p>
                        }
                        <p class="mb-0"><strong>Member Since:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-action">Edit Profile</a>
                </div>
            </div>

            @if (isAdminViewer)
            {
                <div class="card mt-4">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="fas fa-user-shield me-2"></i>Admin Moderation</h6>
                    </div>
                    <div class="card-body d-grid gap-2">
                        <form asp-action="ToggleBan" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('@(Model.IsActive ? "Ban" : "Unban") this user?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn @(Model.IsActive ? "btn-danger" : "btn-outline-danger") w-100">
                                <i class="fas fa-ban me-1"></i>@(Model.IsActive ? "Ban User" : "Unban User")
                            </button>
                        </form>
                        <form asp-action="ToggleProjectSuspension" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('@(Model.ProjectAccessSuspended ? "Restore" : "Suspend") this user\'s project access?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn @(Model.ProjectAccessSuspended ? "btn-outline-warning" : "btn-warning") w-100">
                                <i class="fas fa-pause-circle me-1"></i>@(Model.ProjectAccessSuspended ? "Restore Project Access" : "Suspend Project Access")
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="row mb-4">
                <div class="col-lg-4 col-6 mb-3">
                    <div class="stat-card stat-card-primary">
                        <div class="stat-card-icon"><i class="fas fa-project-diagram"></i></div>
                        <div>
                            <div class="stat-card-value">@projectsOwnedCount</div>
                            <div class="stat-card-label">Projects Owned</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-6 mb-3">
                    <div class="stat-card stat-card-secondary">
                        <div class="stat-card-icon"><i class="fas fa-folder-plus"></i></div>
                        <div>
                            <div class="stat-card-value">@projectsCreatedCount</div>
                            <div class="stat-card-label">Projects Created</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-6 mb-3">
                    <div class="stat-card stat-card-success">
                        <div class="stat-card-icon"><i class="fas fa-file-alt"></i></div>
                        <div>
                            <div class="stat-card-value">@Model.ReportsCreated.Count</div>
                            <div class="stat-card-label">Reports Created</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-6 mb-3">
                    <div class="stat-card stat-card-info">
                        <div class="stat-card-icon"><i class="fas fa-tasks"></i></div>
                        <div>
                            <div class="stat-card-value">@Model.Assignments.Count</div>
                            <div class="stat-card-label">Reports Assigned</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-6 mb-3">
                    <div class="stat-card stat-card-warning">
                        <div class="stat-card-icon"><i class="fas fa-calendar-check"></i></div>
                        <div>
                            <div class="stat-card-value">@eventsAttendedCount</div>
                            <div class="stat-card-label">Events Attended</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-6 mb-3">
                    <div class="stat-card stat-card-dark">
                        <div class="stat-card-icon"><i class="fas fa-comment"></i></div>
                        <div>
                            <div class="stat-card-value">@Model.Comments.Count</div>
                            <div class="stat-card-label">Comments Made</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i>Recent Activity</h5>
                </div>
                <div class="card-body p-0">
                    @if (!recentActivity.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted mb-0">No recent activity</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Project</th>
                                        <th>Action</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in recentActivity)
                                    {
                                        <tr>
                                            <td>
                                                @if (log.Project != null)
                                                {
                                                    <a asp-controller="ProjectTracker" asp-action="Details" asp-route-id="@log.ProjectId">@log.Project.Name</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">(Deleted Project)</span>
                                                }
                                            </td>
                                            <td><span class="badge @GetActionBadgeClass(log.ActionType)">@log.ActionType</span></td>
                                            <td><small class="text-muted">@log.CreatedAt.ToString("dd MMM yyyy HH:mm")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (Model.ReportsCreated.Any())
            {
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Reports Created (@Model.ReportsCreated.Count)</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var report in Model.ReportsCreated.Take(5))
                            {
                                <a asp-controller="Report" asp-action="Details" asp-route-id="@report.Id" class="list-group-item list-group-item-action">
                                    <h6 class="mb-1">@report.Title</h6>
                                    <small class="text-muted">@report.ReportedDate.ToString("MMM dd, yyyy")</small>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: bold;
    }
</style>
