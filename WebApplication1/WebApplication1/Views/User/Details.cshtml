@model WebApplication1.Models.User
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "User";
    var viewerRole = Context.Session.GetString("UserRole");
    var isAdminViewer = viewerRole == "Admin";
    var isSuperAdminViewer = Context.Session.GetString("IsSuperAdmin") == "true";
    var currentSessionId = Context.Session.GetInt32("UserId");
    var ownedProjects = (List<WebApplication1.Models.Project>)(ViewBag.OwnedProjects ?? new List<WebApplication1.Models.Project>());

    var todoProjects      = ownedProjects.Where(p => p.Status == "Planning").ToList();
    var inProgProjects    = ownedProjects.Where(p => p.Status == "InProgress").ToList();
    var lateProjects      = ownedProjects.Where(p => p.Status == "Late").ToList();
    var completedProjects = ownedProjects.Where(p => p.Status == "Completed").ToList();

}

<div class="container-fluid">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-4 flex-wrap">

                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath" alt="@Model.FirstName"
                         class="rounded-circle flex-shrink-0"
                         style="width:72px;height:72px;object-fit:cover;" />
                }
                else
                {
                    <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:72px;height:72px;font-size:24px;background:linear-gradient(135deg,#667eea,#764ba2);">
                        @Model.FirstName[0]@(string.IsNullOrEmpty(Model.LastName) ? "" : Model.LastName[0].ToString())
                    </div>
                }

                <div class="flex-grow-1" style="min-width:0;">
                    <h4 class="mb-1 fw-bold">@Model.FirstName @Model.LastName</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                        @if (Model.Id == 1)
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else
                        {
                            @if (Model.Role == "Editor")
                            {
                                <span class="badge" style="background:var(--color-accent);color:#fff;">Editor</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">User</span>
                            }
                        }
                        @if (!Model.IsActive)
                        {
                            <span class="badge bg-danger"><i class="fas fa-ban me-1"></i>Banned</span>
                        }
                        @if (Model.ProjectAccessSuspended)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-pause-circle me-1"></i>Project Suspended</span>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-3" style="font-size:.85rem;color:#6c757d;">
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <span><i class="fas fa-envelope me-1"></i>@Model.Email</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <span><i class="fas fa-phone me-1"></i>@Model.Phone</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.WorkLocation))
                        {
                            <span><i class="fas fa-map-marker-alt me-1"></i>@Model.WorkLocation</span>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap flex-shrink-0 align-items-center">
                    @if (isSuperAdminViewer)
                    {
                        @if (currentSessionId != Model.Id)
                        {
                        <form asp-action="SetRole" asp-route-id="@Model.Id" method="post" class="d-flex align-items-center gap-1">
                            @Html.AntiForgeryToken()
                            <i class="fas fa-user-tag text-muted" style="font-size:.8rem;"></i>
                            <select name="role" class="form-select form-select-sm" style="width:110px;font-size:.82rem;"
                                    onchange="this.form.submit()">
                                <option value="Editor" selected="@(Model.Role == "Editor")">Editor</option>
                                <option value="User" selected="@(Model.Role != "Editor")">User</option>
                            </select>
                        </form>
                        }

                        @if (currentSessionId != Model.Id)
                        {
                        <form asp-action="ToggleBan" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('@(Model.IsActive ? "Ban" : "Unban") @Model.FirstName?');">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-sm @(Model.IsActive ? "btn-danger" : "btn-outline-danger")">
                                <i class="fas fa-ban me-1"></i>@(Model.IsActive ? "Ban" : "Unban")
                            </button>
                        </form>
                        }
                        @if (currentSessionId != Model.Id)
                        {
                            <a asp-controller="Chat" asp-action="StartDM" asp-route-userId="@Model.Id"
                               class="btn btn-sm btn-primary">
                                <i class="fas fa-comment me-1"></i>Chat
                            </a>
                        }
                    }
                    @{
                        var canEditProfile = isSuperAdminViewer || isAdminViewer || currentSessionId == Model.Id;
                    }
                    @if (canEditProfile)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-modal-action">
                            <i class="fas fa-pencil-alt me-1"></i>Edit
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-sm btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var col in new (string Label, string Cls, string Icon, List<WebApplication1.Models.Project> Items)[]
        {
            ("To Do",       "secondary", "fa-list-ul",          todoProjects),
            ("In Progress", "primary",   "fa-spinner",           inProgProjects),
            ("Late",        "danger",    "fa-exclamation-circle",lateProjects),
            ("Complete",    "success",   "fa-check-circle",      completedProjects),
        })
        {
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header py-2 border-0 bg-@col.Cls bg-opacity-10">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold text-@col.Cls" style="font-size:.85rem;">
                                <i class="fas @col.Icon me-1"></i>@col.Label
                            </span>
                            <span class="badge bg-@col.Cls">@col.Items.Count</span>
                        </div>
                    </div>
                    <div class="card-body p-2">
                        @if (!col.Items.Any())
                        {
                            <div class="text-muted text-center py-3" style="font-size:.8rem;">No tasks</div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-1">
                                @foreach (var p in col.Items)
                                {
                                    <span class="text-decoration-none d-flex align-items-start gap-2 p-2 rounded hover-bg"
                                          style="font-size:.85rem;cursor:pointer;"
                                          data-id="@p.Id" data-name="@p.Name" data-status="@p.Status"
                                          onclick="openDetailModal(this.dataset.id, this.dataset.name, this.dataset.status)">
                                        @if (p.Groups.Any())
                                        {
                                            var firstGroup = p.Groups.FirstOrDefault()?.Group;
                                            if (firstGroup != null)
                                            {
                                                <span class="flex-shrink-0 mt-1" style="width:8px;height:8px;border-radius:50%;background:@(firstGroup.Color ?? "#6c757d");display:inline-block;"></span>
                                            }
                                        }
                                        <span class="text-dark">@p.Name</span>
                                    </span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <input type="text" id="taskDetailTitle" class="form-control form-control-sm fw-bold border-0 p-0"
                       style="font-size:1rem;box-shadow:none;" placeholder="Task name" />
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" style="max-height:70vh;overflow-y:auto;">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label small fw-semibold">Description</label>
                        <textarea id="taskDetailDesc" class="form-control" rows="2"
                                  placeholder="Add a description..."></textarea>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label small fw-semibold mb-0">Progress</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="range" id="taskDetailProgress" min="0" max="100" step="5" class="form-range flex-grow-1" />
                                <span class="badge text-bg-primary" id="taskDetailProgressValue">0%</span>
                            </div>
                        </div>
                        <textarea id="taskDetailProgressNote" class="form-control mt-2" rows="2"
                                  placeholder="Add progress note..."></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Progress Log</label>
                            <div id="taskDetailProgressLog" style="max-height:220px;overflow-y:auto;font-size:.8rem;">
                                <div class="text-muted">Loading...</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Activity Log</label>
                            <div id="taskDetailLog" style="max-height:220px;overflow-y:auto;font-size:.8rem;">
                                <div class="text-muted">Loading...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 px-3">
                <button type="button" class="btn btn-modal-action btn-sm" onclick="saveDetailModal()">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.hover-bg:hover { background: #f4f6fb; }
.task-log-entry {
    padding: .45rem .5rem;
    border-radius: .45rem;
    background: #f8f9fa;
    margin-bottom: .4rem;
}
.task-log-action {
    display: inline-block;
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #6c757d;
    margin-right: .25rem;
}
.task-log-desc {
    display: block;
    margin-top: .15rem;
    font-size: .8rem;
    color: #212529;
}
.task-log-meta {
    font-size: .72rem;
    color: #6c757d;
    margin-top: .2rem;
}
</style>

@section Scripts {
<script>
const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

let currentDetailId = null;
let currentDetailProgress = 0;

function syncProgressInputs(value) {
    const range = document.getElementById('taskDetailProgress');
    const badge = document.getElementById('taskDetailProgressValue');
    const parsed = Math.max(0, Math.min(100, Number(value) || 0));
    if (range) range.value = parsed;
    if (badge) badge.textContent = parsed + '%';
}

function renderLogEntries(entries, containerId, emptyText) {
    const container = document.getElementById(containerId);
    if (!container) return;
    if (!entries || entries.length === 0) {
        container.innerHTML = '<div class="text-muted small">' + emptyText + '</div>';
        return;
    }
    container.innerHTML = entries.map(l => {
        const detailText = l.description || '';
        const noteText = l.note || '';
        const mainText = detailText || noteText || '';
        return `
            <div class="task-log-entry">
                <span class="task-log-action">${l.actionType}</span>
                <span class="task-log-desc">${mainText}</span>
                ${noteText && detailText ? `<div class="text-muted small mt-1">${noteText}</div>` : ''}
                ${l.oldValue && l.newValue ? `<small class="text-muted ms-1">${l.oldValue} → ${l.newValue}</small>` : ''}
                <div class="task-log-meta">${l.userName} · ${l.createdAt}</div>
            </div>`;
    }).join('');
}

function openDetailModal(id, name, status) {
    currentDetailId = id;
    document.getElementById('taskDetailTitle').value = name;
    document.getElementById('taskDetailDesc').value = '';
    document.getElementById('taskDetailProgressNote').value = '';
    syncProgressInputs(0);
    document.getElementById('taskDetailProgressLog').innerHTML = '<div class="text-muted small">Loading...</div>';
    document.getElementById('taskDetailLog').innerHTML = '<div class="text-muted small">Loading...</div>';

    new bootstrap.Modal(document.getElementById('taskDetailModal')).show();

    fetch('/ProjectTracker/GetProjectDetails?id=' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            if (data.name) document.getElementById('taskDetailTitle').value = data.name;
            document.getElementById('taskDetailDesc').value = data.description || '';
            currentDetailProgress = data.progress ?? 0;
            syncProgressInputs(currentDetailProgress);
            renderLogEntries(data.progressLogs || [], 'taskDetailProgressLog', 'No progress updates yet');
            renderLogEntries(data.logs || [], 'taskDetailLog', 'No activity yet');
        })
        .catch(() => {
            document.getElementById('taskDetailLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
            document.getElementById('taskDetailProgressLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
        });
}

async function saveDetailModal() {
    const name = document.getElementById('taskDetailTitle').value.trim();
    const desc = document.getElementById('taskDetailDesc').value;
    const progress = Number(document.getElementById('taskDetailProgress').value || 0);
    const note = document.getElementById('taskDetailProgressNote').value.trim();
    if (!name) return;

    const saveButton = document.querySelector('#taskDetailModal .btn-modal-action');
    if (saveButton) {
        saveButton.disabled = true;
        saveButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
    }

    try {
        const r1 = await fetch('/ProjectTracker/UpdateName', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, name, __RequestVerificationToken: token })
        });
        if (!r1.ok) throw new Error('UpdateName failed: ' + r1.status);

        const r2 = await fetch('/ProjectTracker/UpdateDescription', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, description: desc, __RequestVerificationToken: token })
        });
        if (!r2.ok) throw new Error('UpdateDescription failed: ' + r2.status);

        let movedToCompleted = false;
        if (note || progress !== currentDetailProgress) {
            const r3 = await fetch('/ProjectTracker/UpdateProgress', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id: currentDetailId, progress, note, __RequestVerificationToken: token })
            });
            if (!r3.ok) throw new Error('UpdateProgress failed: ' + r3.status);
            const r3data = await r3.json().catch(() => ({}));
            movedToCompleted = r3data.movedToCompleted === true;
        }

        if (movedToCompleted) { location.reload(); return; }

        (bootstrap.Modal.getInstance(document.getElementById('taskDetailModal')) || new bootstrap.Modal(document.getElementById('taskDetailModal'))).hide();
    } catch (e) {
        console.error(e);
        alert('Unable to save changes. Please try again.');
    } finally {
        if (saveButton) {
            saveButton.disabled = false;
            saveButton.innerHTML = '<i class="fas fa-save me-1"></i>Save';
        }
    }
}

document.getElementById('taskDetailProgress').addEventListener('input', function () {
    syncProgressInputs(this.value);
});
</script>
}
