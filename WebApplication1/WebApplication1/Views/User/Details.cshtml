@model WebApplication1.Models.User

@{
    ViewData["Title"] = "User Profile";

    string GetRoleClass(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Manager" => "bg-warning text-dark",
        "User" => "bg-info",
        _ => "bg-secondary"
    };

    string GetStatusClass(string status) => status switch
    {
        "Available" => "bg-success",
        "Unavailable" => "bg-warning text-dark",
        "Absent" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body text-center p-5">
                    <div class="avatar-circle mb-3">
                        @Model.FirstName[0]@Model.LastName[0]
                    </div>
                    <h1>@Model.FirstName @Model.LastName</h1>
                    @if (!string.IsNullOrEmpty(Model.NickName))
                    {
                        <p class="text-muted mb-3">@Model.NickName</p>
                    }

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <span class="badge @GetRoleClass(Model.Role)">@(Model.Role ?? "User")</span>
                        <span class="badge @GetStatusClass(Model.Status)">@(Model.Status ?? "Available")</span>
                    </div>

                    <div class="row text-start">
                        <div class="col-md-6 mb-3">
                            <strong>Position:</strong>
                            <p>@(Model.Position ?? "N/A")</p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Work Location:</strong>
                            <p>@(Model.WorkLocation ?? "N/A")</p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Email:</strong>
                            <p>
                                @if (!string.IsNullOrEmpty(Model.Email))
                                {
                                    <a href="mailto:@Model.Email">@Model.Email</a>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Phone:</strong>
                            <p>
                                @if (!string.IsNullOrEmpty(Model.Phone))
                                {
                                    <a href="tel:@Model.Phone">@Model.Phone</a>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Line ID:</strong>
                            <p>@(Model.Line ?? "N/A")</p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Member Since:</strong>
                            <p>@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Profile</a>
                </div>
            </div>

            @if (Model.ReportsCreated.Any())
            {
                <div class="card mt-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Reports Created (@Model.ReportsCreated.Count)</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var report in Model.ReportsCreated.Take(5))
                            {
                                <a href="#" class="list-group-item list-group-item-action">
                                    <h6 class="mb-1">@report.Title</h6>
                                    <small class="text-muted">@report.ReportedDate.ToString("MMM dd, yyyy")</small>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: bold;
    }
</style>
