@model WebApplication1.Models.User
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "User";
    var viewerRole = Context.Session.GetString("UserRole");
    var isAdminViewer = viewerRole == "Admin";
    var isSuperAdminViewer = Context.Session.GetString("IsSuperAdmin") == "true";
    var ownedProjects = (List<WebApplication1.Models.Project>)(ViewBag.OwnedProjects ?? new List<WebApplication1.Models.Project>());

    var todoProjects      = ownedProjects.Where(p => p.Status == "Planning").ToList();
    var inProgProjects    = ownedProjects.Where(p => p.Status == "InProgress").ToList();
    var lateProjects      = ownedProjects.Where(p => p.Status == "Late").ToList();
    var completedProjects = ownedProjects.Where(p => p.Status == "Completed").ToList();

    var totalCompleted = completedProjects.Count;
    var totalLate      = lateProjects.Count;
}

<div class="container-fluid">

    <!-- Profile header -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-4 flex-wrap">

                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath" alt="@Model.FirstName"
                         class="rounded-circle flex-shrink-0"
                         style="width:72px;height:72px;object-fit:cover;" />
                }
                else
                {
                    <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:72px;height:72px;font-size:24px;background:linear-gradient(135deg,#667eea,#764ba2);">
                        @Model.FirstName[0]@(string.IsNullOrEmpty(Model.LastName) ? "" : Model.LastName[0].ToString())
                    </div>
                }

                <div class="flex-grow-1" style="min-width:0;">
                    <h4 class="mb-1 fw-bold">@Model.FirstName @Model.LastName</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                        @if (Model.Id == 1)
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else
                        {
                            @if (Model.Role == "Editor")
                            {
                                <span class="badge bg-primary">Editor</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">User</span>
                            }
                        }
                        @if (!Model.IsActive)
                        {
                            <span class="badge bg-danger"><i class="fas fa-ban me-1"></i>Banned</span>
                        }
                        @if (Model.ProjectAccessSuspended)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-pause-circle me-1"></i>Project Suspended</span>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-3" style="font-size:.85rem;color:#6c757d;">
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <span><i class="fas fa-envelope me-1"></i>@Model.Email</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <span><i class="fas fa-phone me-1"></i>@Model.Phone</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.WorkLocation))
                        {
                            <span><i class="fas fa-map-marker-alt me-1"></i>@Model.WorkLocation</span>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap flex-shrink-0 align-items-center">
                    @if (isSuperAdminViewer)
                    {
                        <form asp-action="SetRole" asp-route-id="@Model.Id" method="post" class="d-flex align-items-center gap-1">
                            @Html.AntiForgeryToken()
                            <i class="fas fa-user-tag text-muted" style="font-size:.8rem;"></i>
                            <select name="role" class="form-select form-select-sm" style="width:110px;font-size:.82rem;"
                                    onchange="this.form.submit()">
                                <option value="Editor" selected="@(Model.Role == "Editor")">Editor</option>
                                <option value="User" selected="@(Model.Role != "Editor")">User</option>
                            </select>
                        </form>

                        <form asp-action="ToggleBan" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('@(Model.IsActive ? "Ban" : "Unban") @Model.FirstName?');">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-sm @(Model.IsActive ? "btn-outline-danger" : "btn-danger")">
                                <i class="fas fa-ban me-1"></i>@(Model.IsActive ? "Ban" : "Unban")
                            </button>
                        </form>
                    }
                    @{
                        var currentSessionId = Context.Session.GetInt32("UserId");
                        var canEditProfile = isSuperAdminViewer || isAdminViewer || currentSessionId == Model.Id;
                    }
                    @if (canEditProfile)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-modal-action">
                            <i class="fas fa-pencil-alt me-1"></i>Edit
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-sm btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card stat-card-success">
                <div class="stat-card-icon"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="stat-card-value">@totalCompleted</div>
                    <div class="stat-card-label">Total Completed</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card stat-card-danger">
                <div class="stat-card-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div>
                    <div class="stat-card-value">@totalLate</div>
                    <div class="stat-card-label">Total Late</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects by status -->
    <div class="row g-3">
        @foreach (var col in new (string Label, string Cls, string Icon, List<WebApplication1.Models.Project> Items)[]
        {
            ("To Do",       "secondary", "fa-list-ul",          todoProjects),
            ("In Progress", "primary",   "fa-spinner",           inProgProjects),
            ("Late",        "danger",    "fa-exclamation-circle",lateProjects),
            ("Complete",    "success",   "fa-check-circle",      completedProjects),
        })
        {
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header py-2 border-0 bg-@col.Cls bg-opacity-10">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold text-@col.Cls" style="font-size:.85rem;">
                                <i class="fas @col.Icon me-1"></i>@col.Label
                            </span>
                            <span class="badge bg-@col.Cls">@col.Items.Count</span>
                        </div>
                    </div>
                    <div class="card-body p-2">
                        @if (!col.Items.Any())
                        {
                            <div class="text-muted text-center py-3" style="font-size:.8rem;">No tasks</div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-1">
                                @foreach (var p in col.Items)
                                {
                                    <a href="#" onclick="openTaskModal(@p.Id, '@p.Name.Replace("'", "\\'")')"
                                       class="text-decoration-none d-flex align-items-start gap-2 p-2 rounded hover-bg"
                                       style="font-size:.85rem;">
                                        @if (p.Group != null)
                                        {
                                            <span class="flex-shrink-0 mt-1" style="width:8px;height:8px;border-radius:50%;background:@(p.Group.Color ?? "#6c757d");display:inline-block;"></span>
                                        }
                                        <span class="text-dark">@p.Name</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Task detail modal (same as Kanban board) -->
<div class="modal fade" id="userTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <input type="text" id="uTaskTitle" class="form-control form-control-sm fw-bold border-0 p-0"
                       style="font-size:1rem;box-shadow:none;" placeholder="Task name" readonly />
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" style="max-height:70vh;overflow-y:auto;">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Description</label>
                        <div id="uTaskDesc" class="text-muted small p-2 rounded bg-light" style="min-height:80px;white-space:pre-wrap;"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Activity Log</label>
                        <div id="uTaskLog" style="max-height:250px;overflow-y:auto;font-size:.8rem;">
                            <div class="text-muted">Loading...</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 px-3">
                <a id="uTaskBoardLink" href="#" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-columns me-1"></i>Open in Board
                </a>
            </div>
        </div>
    </div>
</div>

<style>
.hover-bg:hover { background: #f4f6fb; }
.task-log-entry { padding: 4px 0; border-bottom: 1px solid #f0f0f0; }
.task-log-entry:last-child { border-bottom: none; }
.task-log-action { font-size:.7rem; font-weight:600; background:#e9ecef; padding:1px 5px; border-radius:3px; margin-right:4px; }
.task-log-meta { font-size:.7rem; color:#999; margin-top:1px; }
</style>

@section Scripts {
<script>
function openTaskModal(id, name) {
    document.getElementById('uTaskTitle').value = name;
    document.getElementById('uTaskDesc').textContent = '';
    document.getElementById('uTaskLog').innerHTML = '<div class="text-muted small">Loading...</div>';
    document.getElementById('uTaskBoardLink').href = '@Url.Action("Index", "ProjectTracker")' + '?openTask=' + id;

    new bootstrap.Modal(document.getElementById('userTaskModal')).show();

    fetch('/ProjectTracker/GetProjectDetails?id=' + id, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        if (data.name) document.getElementById('uTaskTitle').value = data.name;
        document.getElementById('uTaskDesc').textContent = data.description || '(No description)';
        const logEl = document.getElementById('uTaskLog');
        if (!data.logs || data.logs.length === 0) {
            logEl.innerHTML = '<div class="text-muted small">No activity yet</div>';
        } else {
            logEl.innerHTML = data.logs.map(l => `
                <div class="task-log-entry">
                    <span class="task-log-action">${l.actionType}</span>
                    <span>${l.description || ''}</span>
                    ${l.oldValue && l.newValue ? `<small class="text-muted"> ${l.oldValue} &rarr; ${l.newValue}</small>` : ''}
                    <div class="task-log-meta">${l.userName} &middot; ${l.createdAt}</div>
                </div>`).join('');
        }
    })
    .catch(() => {
        document.getElementById('uTaskLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
    });
    return false;
}
</script>
}
