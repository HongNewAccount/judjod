@model IEnumerable<WebApplication1.Models.User>

@{
    ViewData["Title"] = "Users";
    var userRole = Context.Session.GetString("UserRole");

    string GetRoleClass(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Manager" => "bg-warning text-dark",
        "User" => "bg-info",
        _ => "bg-secondary"
    };

    string GetStatusClass(string status) => status switch
    {
        "Available" => "bg-success",
        "Unavailable" => "bg-warning text-dark",
        "Absent" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Users</h1>
            <p class="page-subtitle">All organization members</p>
        </div>
        @if (userRole == "Admin")
        {
            <div class="col-auto">
                <a asp-controller="Auth" asp-action="Register" class="btn btn-action">
                    <i class="fas fa-user-plus me-2"></i>Register User
                </a>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="card">
            <div class="list-group list-group-flush">
                @foreach (var user in Model)
                {
                    <a asp-action="Details" asp-route-id="@user.Id" class="list-group-item list-group-item-action user-row d-flex align-items-center gap-3 text-decoration-none text-reset">
                        @if (!string.IsNullOrEmpty(user.ProfileImagePath))
                        {
                            <img src="@user.ProfileImagePath" alt="@user.FirstName" class="user-row-avatar" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="user-row-avatar d-flex align-items-center justify-content-center">
                                @user.FirstName[0]@user.LastName[0]
                            </div>
                        }
                        <div class="flex-grow-1" style="min-width: 0;">
                            <div class="d-flex align-items-center flex-wrap gap-2">
                                <span class="fw-semibold">@user.FirstName @user.LastName</span>
                                <span class="badge @GetRoleClass(user.Role)">@(user.Role ?? "User")</span>
                                <span class="badge @GetStatusClass(user.Status)">@(user.Status ?? "Available")</span>
                                @if (!user.IsActive)
                                {
                                    <span class="badge bg-danger"><i class="fas fa-ban me-1"></i>Banned</span>
                                }
                                @if (user.ProjectAccessSuspended)
                                {
                                    <span class="badge bg-warning text-dark"><i class="fas fa-pause-circle me-1"></i>Project Suspended</span>
                                }
                            </div>
                            <small class="text-muted">@(user.Position ?? "N/A")</small>
                        </div>
                        <i class="fas fa-chevron-right text-muted flex-shrink-0"></i>
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No users found. <a asp-action="Create" class="alert-link">Add one now</a>
        </div>
    }
</div>

<style>
    .user-row-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-size: 16px;
        font-weight: bold;
        flex-shrink: 0;
    }

    .user-row {
        padding: 0.75rem 1.25rem;
        transition: background-color 0.15s ease;
    }

    .user-row:hover {
        background-color: #f8f9fb;
        color: inherit;
    }
</style>
