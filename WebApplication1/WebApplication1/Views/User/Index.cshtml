@model IEnumerable<WebApplication1.Models.User>

@{
    ViewData["Title"] = "Users";
    var userRole = Context.Session.GetString("UserRole");
    var currentUserId = Context.Session.GetInt32("UserId");
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Users</h1>
            <p class="page-subtitle">All organization members</p>
        </div>
        @if (Context.Session.GetString("IsSuperAdmin") == "true")
        {
            <div class="col-auto">
                <button type="button" class="btn btn-action" data-bs-toggle="modal" data-bs-target="#registerModal">
                    <i class="fas fa-user-plus me-2"></i>Register User
                </button>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="row g-2">
            @foreach (var user in Model)
            {
                <div class="col-12 col-md-4">
                    <a asp-action="Details" asp-route-id="@user.Id"
                       class="user-row card border-0 shadow-sm text-decoration-none text-reset d-flex flex-row align-items-center gap-3 p-3">

                        @if (!string.IsNullOrEmpty(user.ProfileImagePath))
                        {
                            <img src="@user.ProfileImagePath" alt="@user.FirstName" class="user-row-avatar" style="object-fit:cover;" />
                        }
                        else
                        {
                            <div class="user-row-avatar d-flex align-items-center justify-content-center">
                                @user.FirstName[0]@(string.IsNullOrEmpty(user.LastName) ? "" : user.LastName[0].ToString())
                            </div>
                        }

                        <div class="flex-grow-1" style="min-width:0;">
                            <div class="fw-semibold text-truncate">@user.FirstName @user.LastName</div>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @if (user.Id == 1)
                                {
                                    <span class="badge bg-danger" style="font-size:.68rem;">Admin</span>
                                }
                                else
                                {
                                    @if (user.Role == "Editor")
                                    {
                                        <span class="badge bg-primary" style="font-size:.68rem;">Editor</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="font-size:.68rem;">User</span>
                                    }
                                }
                                @if (!user.IsActive)
                                {
                                    <span class="badge bg-danger" style="font-size:.68rem;"><i class="fas fa-ban me-1"></i>Banned</span>
                                }
                                @if (user.ProjectAccessSuspended)
                                {
                                    <span class="badge bg-warning text-dark" style="font-size:.68rem;">Suspended</span>
                                }
                            </div>
                        </div>

                        <i class="fas fa-chevron-right text-muted flex-shrink-0" style="font-size:.75rem;"></i>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">No users found.</div>
    }
</div>

<!-- ═══ Register Modal ═══ -->
@if (Context.Session.GetString("IsSuperAdmin") == "true")
{
    <div class="modal fade" id="registerModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header text-white py-3 px-4" style="background:var(--color-accent);">
                    <h6 class="modal-title fw-bold">
                        <i class="fas fa-user-plus me-2"></i>Register User
                    </h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div id="regError" class="alert alert-danger small py-2 d-none"></div>
                    <form id="regForm" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <input type="text" name="username" class="form-control" placeholder="Enter username" autocomplete="username" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                            <input type="password" name="password" class="form-control" placeholder="Enter password" autocomplete="new-password" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Confirm Password <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter password" autocomplete="new-password" />
                        </div>
                        <div class="mb-4 p-3 bg-light rounded">
                            <label class="form-label fw-semibold mb-2 d-block">Initial Settings</label>
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="regChat" checked />
                                    </div>
                                    <label for="regChat" class="small fw-semibold mb-0">
                                        <i class="fas fa-comments me-1" style="color:var(--color-accent);"></i>Chat Access
                                    </label>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="regProject" checked />
                                    </div>
                                    <label for="regProject" class="small fw-semibold mb-0">
                                        <i class="fas fa-columns me-1 text-primary"></i>Project Access
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-2">
                            <button type="submit" class="btn btn-modal-action px-5">
                                <i class="fas fa-user-check me-1"></i>Create User
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<style>
.user-row-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    font-size: 14px;
    font-weight: bold;
    flex-shrink: 0;
}
.user-row {
    transition: box-shadow 0.15s ease;
    cursor: pointer;
}
.user-row:hover {
    box-shadow: 0 4px 12px rgba(0,0,0,.1) !important;
}
</style>

@section Scripts {
<script>
(function () {
    var form = document.getElementById('regForm');
    if (!form) return;

    var modal = document.getElementById('registerModal');
    modal.addEventListener('hidden.bs.modal', function () {
        form.reset();
        document.getElementById('regError').classList.add('d-none');
    });

    form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var errEl = document.getElementById('regError');
        errEl.classList.add('d-none');

        var token = form.querySelector('input[name="__RequestVerificationToken"]').value;
        var params = new URLSearchParams({
            __RequestVerificationToken: token,
            username:        form.querySelector('[name="username"]').value,
            password:        form.querySelector('[name="password"]').value,
            confirmPassword: form.querySelector('[name="confirmPassword"]').value,
            chatEnabled:     document.getElementById('regChat').checked,
            projectAccess:   document.getElementById('regProject').checked,
        });

        var res = await fetch('/Auth/Register', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params
        });
        var json = await res.json();
        if (json.success) {
            location.reload();
        } else {
            errEl.textContent = json.error;
            errEl.classList.remove('d-none');
        }
    });
})();
</script>
}
