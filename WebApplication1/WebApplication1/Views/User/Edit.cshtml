@model WebApplication1.Models.User

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Edit User Profile</h5>
                </div>
                <div class="card-body p-4">
                    @{
                        var currentUserId = Context.Session.GetInt32("UserId");
                        var userRole = Context.Session.GetString("UserRole");
                        var canEditRole = userRole == "Admin";
                    }

                    <form method="post" asp-action="Edit" enctype="multipart/form-data" class="needs-validation" novalidate>
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <!-- Profile Image Section -->
                        <div class="mb-4 text-center">
                            <div class="mb-3">
                                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                                {
                                    <img src="@Model.ProfileImagePath" alt="Profile" class="rounded-circle" width="150" height="150" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width: 150px; height: 150px; font-size: 60px;">
                                        <i class="fas fa-user"></i>
                                    </div>
                                }
                            </div>
                            @if (currentUserId == Model.Id || canEditRole)
                            {
                                <label for="profileImage" class="form-label">Upload Profile Picture</label>
                                <input type="file" class="form-control" id="profileImage" name="profileImage" accept="image/*" />
                                <small class="text-muted">JPG, PNG, GIF (Max 5MB)</small>
                            }
                        </div>

                        <hr />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="firstName" class="form-label">First Name *</label>
                                <input type="text" class="form-control" id="firstName" asp-for="FirstName" required />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="lastName" class="form-label">Last Name *</label>
                                <input type="text" class="form-control" id="lastName" asp-for="LastName" required />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="nickName" class="form-label">Nickname</label>
                            <input type="text" class="form-control" id="nickName" asp-for="NickName" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" asp-for="Email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="phone" class="form-label">Phone</label>
                                <input type="tel" class="form-control" id="phone" asp-for="Phone" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="passwordHash" class="form-label">Password (Optional)</label>
                            <input type="password" class="form-control" id="passwordHash" asp-for="PasswordHash" placeholder="Leave blank to keep current password" />
                            <small class="text-muted">Only fill this field if you want to change the password</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="role" class="form-label">Role</label>
                                <select class="form-control" id="role" asp-for="Role" disabled="@(!canEditRole)">
                                    <option value="">Select Role</option>
                                    <option value="Admin">Admin</option>
                                    <option value="Manager">Manager</option>
                                    <option value="User">User</option>
                                </select>
                                @if (!canEditRole)
                                {
                                    <input type="hidden" asp-for="Role" />
                                    <small class="text-muted">(Admin only)</small>
                                }
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="position" class="form-label">Position</label>
                                <input type="text" class="form-control" id="position" asp-for="Position" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="workLocation" class="form-label">Work Location</label>
                            <input type="text" class="form-control" id="workLocation" asp-for="WorkLocation" placeholder="e.g., Floor 2, Desk 5" />
                        </div>

                        <div class="mb-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-control" id="status" asp-for="Status">
                                <option value="Available">Available</option>
                                <option value="Unavailable">Unavailable</option>
                                <option value="Absent">Absent</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="links" class="form-label">Links</label>
                            <input type="text" class="form-control" id="links" asp-for="Links" placeholder="e.g., portfolio/social links, comma-separated" />
                        </div>

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
