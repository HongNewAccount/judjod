@model IList<WebApplication1.Models.ActivityLog>

@{
    ViewData["Title"] = "Activity Log";
}

<style>
    .pagination .page-link {
        color: #0dcaf0;
        border-color: #0dcaf0;
    }

    .pagination .page-link:hover {
        color: #fff;
        background-color: #0dcaf0;
        border-color: #0dcaf0;
    }

    .pagination .page-item.active .page-link {
        background-color: #0dcaf0;
        border-color: #0dcaf0;
        color: #fff;
        font-weight: bold;
    }
</style>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3">Activity Log</h1>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-sm btn-secondary" title="Back to Project List">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header bg-light">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">All Project Changes</h5>
                    <small class="text-muted">Total: @ViewBag.TotalCount entries</small>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted">No activity logs found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 30%">Project</th>
                                <th style="width: 15%">Action</th>
                                <th style="width: 25%">Details</th>
                                <th style="width: 15%">User</th>
                                <th style="width: 15%">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr class="align-middle">
                                    <td>
                                        @if (log.Project != null)
                                        {
                                            <a asp-action="Details" asp-route-id="@log.ProjectId" 
                                               title="View project details">
                                                @log.Project.Name
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(Deleted Project)</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetActionBadgeClass(log.ActionType)">
                                            @GetActionLabel(log.ActionType)
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(log.OldValue) && !string.IsNullOrEmpty(log.NewValue))
                                            {
                                                <span>@log.OldValue <i class="fas fa-arrow-right"></i> @log.NewValue</span>
                                            }
                                            else
                                            {
                                                <span>@log.Description</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        @if (log.User != null)
                                        {
                                            <span>@log.User.FirstName @log.User.LastName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(Unknown User)</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @log.CreatedAt.ToString("dddd, dd MMMM yyyy HH:mm:ss")
                                        </small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-light">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        @{
                            int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                            int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="ActivityLog" asp-route-filter="@ViewBag.FilterType" asp-route-page="@i">@i</a>
                                </li>
                            }
                        }

                        @if (endPage < ViewBag.TotalPages)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Add pagination or real-time filtering here
    </script>
}

@functions {
    private string GetActionBadgeClass(string actionType)
    {
        return actionType switch
        {
            "Created" => "bg-secondary",
            "StatusChanged" => "bg-primary",
            "NameChanged" => "bg-primary",
            "DescriptionChanged" => "bg-primary",
            "StartDateChanged" => "bg-primary",
            "EndDateChanged" => "bg-primary",
            "OwnerAdded" => "bg-warning",
            "OwnerRemoved" => "bg-danger",
            "Deleted" => "bg-danger",
            "FavoriteAdded" => "bg-warning",
            "FavoriteRemoved" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetActionLabel(string actionType)
    {
        return actionType switch
        {
            "Created" => "Created",
            "StatusChanged" => "Status",
            "NameChanged" => "Name",
            "DescriptionChanged" => "Description",
            "StartDateChanged" => "Start Date",
            "EndDateChanged" => "End Date",
            "OwnerAdded" => "Owner Added",
            "OwnerRemoved" => "Owner Removed",
            "Deleted" => "Deleted",
            "FavoriteAdded" => "Favorite",
            "FavoriteRemoved" => "Favorite",
            _ => actionType
        };
    }
}
