@model IList<WebApplication1.Models.ActivityLog>

@{
    ViewData["Title"] = "Activity Log";
}

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-title">Activity Log</h1>
        <p class="page-subtitle">Track all project changes and activities</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Search removed *@
    @if (false)
    {
        <div class="d-none">
            <form method="get" asp-action="ActivityLog">
            </form>
        </div>
    }

    <div class="card">
        <div class="card-header bg-light">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">All Project Changes</h5>
                    <small class="text-muted">Total: @ViewBag.TotalCount entries</small>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted">No activity logs found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 30%">Project</th>
                                <th style="width: 15%">Action</th>
                                <th style="width: 25%">Details</th>
                                <th style="width: 15%">User</th>
                                <th style="width: 15%">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                var hasProject = log.Project != null;
                                var rowClick = hasProject
                                    ? $"openLogTaskModal({log.ProjectId}, '{log.Project!.Name.Replace("'", "\\'")}')"
                                    : "";
                                <tr class="align-middle @(hasProject ? "log-row-clickable" : "")"
                                    @(hasProject ? $"onclick=\"{rowClick}\" style=\"cursor:pointer;\"" : "")>
                                    <td>
                                        @if (hasProject)
                                        {
                                            <span>@log.Project!.Name</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(Deleted Project)</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge text-white @GetActionBadgeClass(log.ActionType)">
                                            @GetActionLabel(log.ActionType)
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(log.OldValue) && !string.IsNullOrEmpty(log.NewValue))
                                            {
                                                <span>@log.OldValue <i class="fas fa-arrow-right"></i> @log.NewValue</span>
                                            }
                                            else
                                            {
                                                <span>@log.Description</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        @if (log.User != null)
                                        {
                                            <span>@log.User.FirstName @log.User.LastName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(Unknown User)</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @log.CreatedAt.ToString("dddd, dd MMMM yyyy HH:mm:ss")
                                        </small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            int cur = (int)ViewBag.CurrentPage;
            int total = (int)ViewBag.TotalPages;
            // Always exactly 3 consecutive numbers (or fewer if total < 3)
            int pageCount = Math.Min(3, total);
            int pStart = Math.Max(1, Math.Min(cur - 1, total - pageCount + 1));
            int pEnd = pStart + pageCount - 1;
            <div class="card-footer bg-light d-flex justify-content-center">
                <ul class="pagination mb-0">
                    <li class="page-item @(cur <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="ActivityLog" asp-route-page="@(cur - 1)">&lsaquo;</a>
                    </li>
                    @for (int p = pStart; p <= pEnd; p++)
                    {
                        <li class="page-item @(p == cur ? "active" : "")">
                            <a class="page-link" asp-action="ActivityLog" asp-route-page="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(cur >= total ? "disabled" : "")">
                        <a class="page-link" asp-action="ActivityLog" asp-route-page="@(cur + 1)">&rsaquo;</a>
                    </li>
                </ul>
            </div>
        }
    </div>
</div>

<!-- Task detail modal -->
<div class="modal fade" id="logTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <input type="text" id="logTaskTitle" class="form-control form-control-sm fw-bold border-0 p-0"
                       style="font-size:1rem;box-shadow:none;" readonly />
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" style="max-height:70vh;overflow-y:auto;">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Description</label>
                        <div id="logTaskDesc" class="text-muted small p-2 rounded bg-light" style="min-height:80px;white-space:pre-wrap;"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Activity Log</label>
                        <div id="logTaskLog" style="max-height:250px;overflow-y:auto;font-size:.8rem;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 px-3">
                <a id="logTaskBoardLink" href="#" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-columns me-1"></i>Open in Board
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openLogTaskModal(id, name) {
            document.getElementById('logTaskTitle').value = name;
            document.getElementById('logTaskDesc').textContent = '';
            document.getElementById('logTaskLog').innerHTML = '<div class="text-muted small">Loading...</div>';
            document.getElementById('logTaskBoardLink').href = '@Url.Action("Index", "ProjectTracker")' + '?openTask=' + id;
            new bootstrap.Modal(document.getElementById('logTaskModal')).show();
            fetch('/ProjectTracker/GetProjectDetails?id=' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json())
                .then(data => {
                    if (data.name) document.getElementById('logTaskTitle').value = data.name;
                    document.getElementById('logTaskDesc').textContent = data.description || '(No description)';
                    const el = document.getElementById('logTaskLog');
                    if (!data.logs || data.logs.length === 0) {
                        el.innerHTML = '<div class="text-muted small">No activity yet</div>';
                    } else {
                        el.innerHTML = data.logs.map(l => `
                            <div style="padding:4px 0;border-bottom:1px solid #f0f0f0;">
                                <span style="font-size:.7rem;font-weight:600;background:#e9ecef;padding:1px 5px;border-radius:3px;margin-right:4px;">${l.actionType}</span>
                                ${l.description || ''}
                                ${l.oldValue && l.newValue ? `<small class="text-muted"> ${l.oldValue} &rarr; ${l.newValue}</small>` : ''}
                                <div style="font-size:.7rem;color:#999;">${l.userName} &middot; ${l.createdAt}</div>
                            </div>`).join('');
                    }
                })
                .catch(() => { document.getElementById('logTaskLog').innerHTML = '<div class="text-danger small">Failed to load</div>'; });
            return false;
        }
    </script>
}

@functions {
    private string GetActionBadgeClass(string actionType)
    {
        return actionType switch
        {
            "Created" => "text-bg-success",
            "StatusChanged" => "text-bg-primary",
            "NameChanged" => "text-bg-info",
            "DescriptionChanged" => "text-bg-secondary",
            "StartDateChanged" => "text-bg-dark",
            "EndDateChanged" => "text-bg-warning",
            "OwnerAdded" => "text-bg-success",
            "OwnerRemoved" => "text-bg-danger",
            "Deleted" => "text-bg-danger",
            "FavoriteAdded" => "text-bg-warning",
            "FavoriteRemoved" => "text-bg-secondary",
            _ => "text-bg-secondary"
        };
    }

    private string GetActionLabel(string actionType)
    {
        return actionType switch
        {
            "Created" => "Created",
            "StatusChanged" => "Status",
            "NameChanged" => "Name",
            "DescriptionChanged" => "Description",
            "StartDateChanged" => "Start Date",
            "EndDateChanged" => "End Date",
            "OwnerAdded" => "Owner Added",
            "OwnerRemoved" => "Owner Removed",
            "Deleted" => "Deleted",
            "FavoriteAdded" => "Favorite",
            "FavoriteRemoved" => "Favorite",
            _ => actionType
        };
    }
}
