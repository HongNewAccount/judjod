@model IList<WebApplication1.Models.ActivityLog>

@{
    ViewData["Title"] = "Activity Log";
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Activity Log</h1>
            <p class="page-subtitle">Track all project changes and activities</p>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-sm btn-secondary" title="Back to Project List">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Search removed *@
    @if (false)
    {
        <div class="d-none">
            <form method="get" asp-action="ActivityLog">
            </form>
        </div>
    }

    <div class="card">
        <div class="card-header bg-light">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">All Project Changes</h5>
                    <small class="text-muted">Total: @ViewBag.TotalCount entries</small>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted">No activity logs found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 30%">Project</th>
                                <th style="width: 15%">Action</th>
                                <th style="width: 25%">Details</th>
                                <th style="width: 15%">User</th>
                                <th style="width: 15%">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr class="align-middle">
                                    <td>
                                        @if (log.Project != null)
                                        {
                                            <a asp-action="Details" asp-route-id="@log.ProjectId" 
                                               title="View project details">
                                                @log.Project.Name
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(Deleted Project)</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetActionBadgeClass(log.ActionType)">
                                            @GetActionLabel(log.ActionType)
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(log.OldValue) && !string.IsNullOrEmpty(log.NewValue))
                                            {
                                                <span>@log.OldValue <i class="fas fa-arrow-right"></i> @log.NewValue</span>
                                            }
                                            else
                                            {
                                                <span>@log.Description</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        @if (log.User != null)
                                        {
                                            <span>@log.User.FirstName @log.User.LastName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(Unknown User)</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @log.CreatedAt.ToString("dddd, dd MMMM yyyy HH:mm:ss")
                                        </small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                <small class="text-muted">Page @ViewBag.CurrentPage of @ViewBag.TotalPages</small>
                <div class="d-flex gap-2">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a class="btn btn-sm btn-outline-secondary" asp-action="ActivityLog" asp-route-page="@(ViewBag.CurrentPage - 1)">
                            <i class="fas fa-chevron-left me-1"></i>Previous
                        </a>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a class="btn btn-sm btn-outline-secondary" asp-action="ActivityLog" asp-route-page="@(ViewBag.CurrentPage + 1)">
                            Next<i class="fas fa-chevron-right ms-1"></i>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Add pagination or real-time filtering here
    </script>
}

@functions {
    private string GetActionBadgeClass(string actionType)
    {
        return actionType switch
        {
            "Created" => "text-bg-success",
            "StatusChanged" => "text-bg-primary",
            "NameChanged" => "text-bg-info",
            "DescriptionChanged" => "text-bg-secondary",
            "StartDateChanged" => "text-bg-dark",
            "EndDateChanged" => "text-bg-warning",
            "OwnerAdded" => "text-bg-success",
            "OwnerRemoved" => "text-bg-danger",
            "Deleted" => "text-bg-danger",
            "FavoriteAdded" => "text-bg-warning",
            "FavoriteRemoved" => "text-bg-secondary",
            _ => "text-bg-secondary"
        };
    }

    private string GetActionLabel(string actionType)
    {
        return actionType switch
        {
            "Created" => "Created",
            "StatusChanged" => "Status",
            "NameChanged" => "Name",
            "DescriptionChanged" => "Description",
            "StartDateChanged" => "Start Date",
            "EndDateChanged" => "End Date",
            "OwnerAdded" => "Owner Added",
            "OwnerRemoved" => "Owner Removed",
            "Deleted" => "Deleted",
            "FavoriteAdded" => "Favorite",
            "FavoriteRemoved" => "Favorite",
            _ => actionType
        };
    }
}
