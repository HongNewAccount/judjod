@model WebApplication1.Models.Project

@{
    ViewData["Title"] = "Project Details";

    string GetActivityIcon(string actionType) => actionType switch
    {
        "Created" => "fas fa-plus",
        "StatusChanged" => "fas fa-sync-alt",
        "NameChanged" or "DescriptionChanged" => "fas fa-edit",
        "StartDateChanged" or "EndDateChanged" => "fas fa-calendar",
        "OwnerAdded" => "fas fa-user-plus",
        "OwnerRemoved" => "fas fa-user-minus",
        "Deleted" => "fas fa-trash",
        _ => "fas fa-history"
    };

    string GetActivityIconClass(string actionType) => actionType switch
    {
        "Created" => "created",
        "StatusChanged" => "status-changed",
        "NameChanged" or "DescriptionChanged" => "name-changed",
        "StartDateChanged" or "EndDateChanged" => "start-date-changed",
        "OwnerAdded" => "owner-added",
        "OwnerRemoved" => "owner-removed",
        "Deleted" => "deleted",
        _ => "created"
    };
}

<div class="container-fluid">
    @if (ViewBag.PendingUpdate != null)
    {
        var req = (WebApplication1.Models.ProjectApprovalRequest)ViewBag.PendingUpdate;
        var currentUserId = Context.Session.GetInt32("UserId") ?? 1;
        var userRole = Context.Session.GetString("UserRole") ?? "User";
        
        <div class="alert alert-warning border-start border-4 border-warning shadow-sm mb-4 d-flex justify-content-between align-items-center" role="alert">
            <div>
                <h5 class="alert-heading mb-1"><i class="fas fa-hourglass-half me-2"></i>Pending Edits Awaiting Approval</h5>
                <p class="mb-0 small text-dark">
                    Proposed updates were submitted by <strong>@req.RequestedByUser?.FirstName @req.RequestedByUser?.LastName</strong> on @req.RequestedAt.ToString("MMM dd, yyyy HH:mm").
                    These changes will not be visible here until an Administrator approves them.
                </p>
            </div>
            <div>
                @if (req.RequestedByUserId == currentUserId || userRole == "Admin")
                {
                    <div class="d-flex gap-2">
                        @if (userRole == "Admin")
                        {
                            <a asp-controller="Admin" asp-action="PendingRequests" class="btn btn-sm btn-warning">
                                <i class="fas fa-gavel me-1"></i> Review Request
                            </a>
                        }
                        <form asp-action="CancelRequest" asp-route-id="@req.Id" method="post" onsubmit="return confirm('Are you sure you want to cancel this edit request?');" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-times me-1"></i> Cancel Request
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row mb-4">
        <div class="col">
            <h1>@Model.Name</h1>
            <p class="text-muted">Created by @Model.CreatedByUser?.FirstName @Model.CreatedByUser?.LastName on @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
        </div>
        <div class="col-auto detail-actions">
            <a asp-action="Index" class="btn btn-sm btn-secondary" title="Back to List">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Project Information</h5>
                </div>
                <div class="card-body">
                    <h6>Description</h6>
                    <p>@(Model.Description ?? "No description provided")</p>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <h6>Owners</h6>
                            <p>
                                @if (Model.Owners.Any())
                                {
                                    @foreach (var owner in Model.Owners)
                                    {
                                        <span class="badge bg-secondary me-1">@owner.User?.FirstName @owner.User?.LastName</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No owners</span>
                                }
                            </p>

                            <h6>Start Date</h6>
                            <p>@Model.StartDate.ToString("dddd, MMMM dd, yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <h6>End Date</h6>
                            <p>@(Model.EndDate?.ToString("dddd, MMMM dd, yyyy") ?? "Ongoing")</p>

                            <h6>Status</h6>
                            <p>
                                <span class="badge bg-primary">@Model.Status</span>
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Issues))
                    {
                        <hr />
                        <h6>Issues/Notes</h6>
                        <p>@Model.Issues</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i>Activity Log (@ViewBag.TotalLogs)</h5>
                </div>
                <div class="card-body">
                    @{
                        int totalLogs = ViewBag.TotalLogs ?? 0;
                        int totalPages = ViewBag.TotalPages ?? 0;
                        int currentPage = ViewBag.CurrentPage ?? 1;
                        var paginatedLogs = ViewBag.PaginatedLogs ?? new List<ActivityLog>();
                    }
                    @if (totalLogs > 0)
                    {
                        <div class="activity-log">
                            @foreach (var log in paginatedLogs)
                            {
                                <div class="activity-item">
                                    <div class="activity-icon @GetActivityIconClass(log.ActionType)">
                                        <i class="@GetActivityIcon(log.ActionType)"></i>
                                    </div>
                                    <div class="activity-content">
                                        <p class="activity-description mb-1">@log.Description</p>
                                        <small class="text-muted d-block">
                                            <strong>@(log.User?.FirstName) @(log.User?.LastName)</strong>
                                            <br />
                                            @log.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                        </small>
                                        @if (!string.IsNullOrEmpty(log.OldValue) && !string.IsNullOrEmpty(log.NewValue))
                                        {
                                            <small class="text-muted d-block mt-1">
                                                <span class="badge bg-light text-dark">@log.OldValue</span>
                                                <i class="fas fa-arrow-right mx-1"></i>
                                                <span class="badge bg-light text-dark">@log.NewValue</span>
                                            </small>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        @if (totalPages > 1)
                        {
                            <nav aria-label="Activity Log Pagination" class="mt-3">
                                <ul class="pagination pagination-sm justify-content-center">
                                    @if (currentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-page="1" title="First">«</a>
                                        </li>
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-page="@(currentPage - 1)" title="Previous">‹</a>
                                        </li>
                                    }
                                    @for (int p = 1; p <= totalPages; p++)
                                    {
                                        @if (p == currentPage)
                                        {
                                            <li class="page-item active"><span class="page-link">@p</span></li>
                                        }
                                        else if (p <= currentPage + 2 && p >= currentPage - 2)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-page="@p">@p</a>
                                            </li>
                                        }
                                        else if (p == 1 || p == totalPages)
                                        {
                                            @if (p == 1 && currentPage > 3)
                                            {
                                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                            }
                                            <li class="page-item">
                                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-page="@p">@p</a>
                                            </li>
                                            @if (p == totalPages && currentPage < totalPages - 2)
                                            {
                                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                            }
                                        }
                                    }
                                    @if (currentPage < totalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-page="@(currentPage + 1)" title="Next">›</a>
                                        </li>
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-page="@totalPages" title="Last">»</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center">No activity yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .activity-log {
        position: relative;
    }

    .activity-log::before {
        content: '';
        position: absolute;
        left: 15px;
        top: 0;
        bottom: 0;
        width: 2px;
        background-color: #dee2e6;
    }

    .activity-item {
        position: relative;
        margin-bottom: 20px;
        padding-left: 45px;
    }

    .activity-icon {
        position: absolute;
        left: -8px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 14px;
        border: 2px solid white;
        box-shadow: 0 0 0 1px #dee2e6;
    }

    .activity-icon.created {
        background-color: #198754;
    }

    .activity-icon.status-changed {
        background-color: #0d6efd;
    }

    .activity-icon.name-changed,
    .activity-icon.description-changed {
        background-color: #ffc107;
    }

    .activity-icon.start-date-changed,
    .activity-icon.end-date-changed {
        background-color: #17a2b8;
    }

    .activity-icon.owner-added {
        background-color: #28a745;
    }

    .activity-icon.owner-removed {
        background-color: #dc3545;
    }

    .activity-icon.deleted {
        background-color: #dc3545;
    }

    .activity-description {
        font-size: 14px;
        color: #212529;
    }

    .badge {
        font-size: 11px;
        padding: 4px 6px;
    }

    .detail-actions {
        display: flex;
        gap: 8px;
    }

    .detail-actions .btn {
        border: 1px solid currentColor;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .detail-actions .action-form {
        display: inline;
    }

    .detail-actions .action-form .btn {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .detail-actions .btn-info {
        border-color: #0dcaf0;
        color: white;
        background-color: #0dcaf0;
    }

    .detail-actions .btn-danger {
        border-color: #dc3545;
        color: white;
        background-color: #dc3545;
    }

    .detail-actions .btn-secondary {
        border-color: #6c757d;
        color: white;
        background-color: #6c757d;
    }
</style>
