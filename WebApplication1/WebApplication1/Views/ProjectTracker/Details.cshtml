@model WebApplication1.Models.Project

@{
    ViewData["Title"] = "Project Details";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1>@Model.Name</h1>
            <p class="text-muted">Created by @Model.CreatedByUser?.FirstName @Model.CreatedByUser?.LastName on @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
        </div>
        <div class="col-auto">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this project?');">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Project Information</h5>
                </div>
                <div class="card-body">
                    <h6>Description</h6>
                    <p>@(Model.Description ?? "No description provided")</p>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <h6>Owners</h6>
                            <p>
                                @if (Model.Owners.Any())
                                {
                                    @foreach (var owner in Model.Owners)
                                    {
                                        <span class="badge bg-secondary me-1">@owner.User?.FirstName @owner.User?.LastName</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No owners</span>
                                }
                            </p>

                            <h6>Start Date</h6>
                            <p>@Model.StartDate.ToString("dddd, MMMM dd, yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <h6>End Date</h6>
                            <p>@(Model.EndDate?.ToString("dddd, MMMM dd, yyyy") ?? "Ongoing")</p>

                            <h6>Status</h6>
                            <p>
                                <span class="badge bg-primary">@Model.Status</span>
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Issues))
                    {
                        <hr />
                        <h6>Issues/Notes</h6>
                        <p>@Model.Issues</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Timeline</h5>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        <div class="timeline-item">
                            <div class="timeline-marker bg-primary"></div>
                            <div class="timeline-content">
                                <h6>Project Created</h6>
                                <small class="text-muted">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                            </div>
                        </div>

                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div class="timeline-item">
                                <div class="timeline-marker bg-info"></div>
                                <div class="timeline-content">
                                    <h6>Last Updated</h6>
                                    <small class="text-muted">@Model.UpdatedAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                                </div>
                            </div>
                        }

                        <div class="timeline-item">
                            <div class="timeline-marker bg-success"></div>
                            <div class="timeline-content">
                                <h6>End Date</h6>
                                <small class="text-muted">@(Model.EndDate?.ToString("MMM dd, yyyy") ?? "No end date set")</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 30px;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background-color: #dee2e6;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 30px;
    }

    .timeline-marker {
        position: absolute;
        left: -34px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        top: 5px;
    }

    .timeline-content h6 {
        margin-bottom: 5px;
        font-weight: 600;
    }
</style>
