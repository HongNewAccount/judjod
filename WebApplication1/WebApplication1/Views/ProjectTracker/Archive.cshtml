@model IEnumerable<WebApplication1.Models.Project>
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "Archive";
    var userRole = Context.Session.GetString("UserRole") ?? "User";
    var searchTerm = ViewBag.SearchTerm ?? "";
    var canEdit = userRole == "Admin" || userRole == "Editor";

    string Initials(WebApplication1.Models.User? u) {
        if (u == null) return "?";
        var f = u.FirstName?.Length > 0 ? u.FirstName[0].ToString() : "";
        var l = u.LastName?.Length > 0 ? u.LastName[0].ToString() : "";
        return f + l;
    }

    string PriorityCls(string? p) => p switch {
        "High" => "priority-high", "Medium" => "priority-medium", "Low" => "priority-low", _ => "priority-none"
    };
}

<div class="container-fluid">
    <div class="page-header mb-3">
        <h1 class="page-title mb-0"><i class="fas fa-archive me-2 text-success"></i>Archive</h1>
        <p class="page-subtitle">All archived tasks</p>
    </div>

    <div class="card mb-3">
        <div class="card-body py-2">
            <input type="text" id="archiveSearch" class="form-control" placeholder="Search by project or owner name..." />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card p-5 text-center border-0 shadow-sm">
            <i class="fas fa-archive" style="font-size:48px;color:#ccc;"></i>
            <p class="text-muted mt-3">No archived tasks yet.</p>
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.75rem;">
            @foreach (var project in Model)
            {
                <div class="kanban-card" style="cursor:pointer;"
                     data-id="@project.Id" data-name="@project.Name" data-status="@project.Status"
                     data-search="@($"{project.Name} {string.Join(' ', project.Owners.Select(o => o.User != null ? o.User.FirstName + " " + o.User.LastName : ""))}".ToLower())"
                     onclick="openDetailModal(this.dataset.id, this.dataset.name, this.dataset.status)">
                    <span class="badge bg-secondary mb-1" style="font-size:.65rem;">Archived</span>

                    <span class="kanban-card-title d-block">@project.Name</span>

                    @if (!string.IsNullOrWhiteSpace(project.Description))
                    {
                        <p class="kanban-card-desc">@project.Description</p>
                    }

                    <div class="kanban-quick-row mt-1">
                        @if (project.Owners.Any())
                        {
                            <span class="kanban-quick-btn kanban-quick-btn-empty" style="cursor:default;">
                                <div class="kanban-avatars">
                                    @foreach (var owner in project.Owners.Take(3))
                                    {
                                        <span class="kanban-card-avatar" title="@owner.User?.FirstName @owner.User?.LastName">
                                            @Initials(owner.User)
                                        </span>
                                    }
                                </div>
                            </span>
                        }

                        @if (project.Groups.Any())
                        {
                            <span class="kanban-quick-btn kanban-quick-btn-group" style="cursor:default;">
                                @foreach (var ga in project.Groups.Take(2))
                                {
                                    <span style="width:8px;height:8px;border-radius:50%;background:@(ga.Group?.Color ?? "#6c757d");display:inline-block;margin-right:2px;"></span>
                                }
                                <span>@string.Join(", ", project.Groups.Take(2).Select(ga => ga.Group?.Name ?? ""))</span>
                            </span>
                        }

                        @if (project.EndDate.HasValue)
                        {
                            <span class="kanban-quick-btn kanban-quick-btn-empty" style="cursor:default;"
                                  title="@project.EndDate.Value.ToString("dd MMM ") @(project.EndDate.Value.Year + 543)">
                                <i class="fas fa-calendar-alt me-1"></i>
                                @project.EndDate.Value.ToString("dd MMM ") @(project.EndDate.Value.Year + 543)
                            </span>
                        }

                        @if (!string.IsNullOrEmpty(project.Priority) && project.Priority != "None")
                        {
                            <span class="kanban-quick-btn kanban-priority-btn @PriorityCls(project.Priority)" style="cursor:default;">
                                <i class="fas fa-flag me-1"></i>@project.Priority
                            </span>
                        }
                    </div>

                    @if (canEdit)
                    {
                        <div class="mt-2 d-flex justify-content-end">
                            <button type="button" class="btn btn-sm btn-outline-secondary reopen-btn"
                                    data-project-id="@project.Id" title="Reopen task"
                                    onclick="event.stopPropagation()">
                                <i class="fas fa-undo me-1"></i>Reopen
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <input type="text" id="taskDetailTitle" class="form-control form-control-sm fw-bold border-0 p-0"
                       style="font-size:1rem;box-shadow:none;" placeholder="Task name" />
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" style="max-height:70vh;overflow-y:auto;">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label small fw-semibold">Description</label>
                        <textarea id="taskDetailDesc" class="form-control" rows="2"
                                  placeholder="Add a description..."></textarea>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label small fw-semibold mb-0">Progress</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="range" id="taskDetailProgress" min="0" max="100" step="5" class="form-range flex-grow-1" />
                                <span class="badge text-bg-primary" id="taskDetailProgressValue">0%</span>
                            </div>
                        </div>
                        <textarea id="taskDetailProgressNote" class="form-control mt-2" rows="2"
                                  placeholder="Add progress note..."></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Progress Log</label>
                            <div id="taskDetailProgressLog" style="max-height:220px;overflow-y:auto;font-size:.8rem;">
                                <div class="text-muted">Loading...</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Activity Log</label>
                            <div id="taskDetailLog" style="max-height:220px;overflow-y:auto;font-size:.8rem;">
                                <div class="text-muted">Loading...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 px-3">
                <button type="button" class="btn btn-modal-action btn-sm" onclick="saveDetailModal()">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.task-log-entry {
    padding: .45rem .5rem;
    border-radius: .45rem;
    background: #f8f9fa;
    margin-bottom: .4rem;
}
.task-log-action {
    display: inline-block;
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #6c757d;
    margin-right: .25rem;
}
.task-log-desc {
    display: block;
    margin-top: .15rem;
    font-size: .8rem;
    color: #212529;
}
.task-log-meta {
    font-size: .72rem;
    color: #6c757d;
    margin-top: .2rem;
}
</style>

@section Scripts {
<script>
const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

document.getElementById('archiveSearch').addEventListener('keyup', function () {
    const term = this.value.toLowerCase();
    document.querySelectorAll('.kanban-card[data-search]').forEach(card => {
        card.style.display = card.getAttribute('data-search').includes(term) ? '' : 'none';
    });
});

let currentDetailId = null;
let currentDetailProgress = 0;

function syncProgressInputs(value) {
    const range = document.getElementById('taskDetailProgress');
    const badge = document.getElementById('taskDetailProgressValue');
    const parsed = Math.max(0, Math.min(100, Number(value) || 0));
    if (range) range.value = parsed;
    if (badge) badge.textContent = parsed + '%';
}

function renderLogEntries(entries, containerId, emptyText) {
    const container = document.getElementById(containerId);
    if (!container) return;
    if (!entries || entries.length === 0) {
        container.innerHTML = '<div class="text-muted small">' + emptyText + '</div>';
        return;
    }
    container.innerHTML = entries.map(l => {
        const detailText = l.description || '';
        const noteText = l.note || '';
        const mainText = detailText || noteText || '';
        return `
            <div class="task-log-entry">
                <span class="task-log-action">${l.actionType}</span>
                <span class="task-log-desc">${mainText}</span>
                ${noteText && detailText ? `<div class="text-muted small mt-1">${noteText}</div>` : ''}
                ${l.oldValue && l.newValue ? `<small class="text-muted ms-1">${l.oldValue} → ${l.newValue}</small>` : ''}
                <div class="task-log-meta">${l.userName} · ${l.createdAt}</div>
            </div>`;
    }).join('');
}

function openDetailModal(id, name, status) {
    currentDetailId = id;
    document.getElementById('taskDetailTitle').value = name;
    document.getElementById('taskDetailDesc').value = '';
    document.getElementById('taskDetailProgressNote').value = '';
    syncProgressInputs(0);
    document.getElementById('taskDetailProgressLog').innerHTML = '<div class="text-muted small">Loading...</div>';
    document.getElementById('taskDetailLog').innerHTML = '<div class="text-muted small">Loading...</div>';

    new bootstrap.Modal(document.getElementById('taskDetailModal')).show();

    fetch('/ProjectTracker/GetProjectDetails?id=' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            if (data.name) document.getElementById('taskDetailTitle').value = data.name;
            document.getElementById('taskDetailDesc').value = data.description || '';
            currentDetailProgress = data.progress ?? 0;
            syncProgressInputs(currentDetailProgress);
            renderLogEntries(data.progressLogs || [], 'taskDetailProgressLog', 'No progress updates yet');
            renderLogEntries(data.logs || [], 'taskDetailLog', 'No activity yet');
        })
        .catch(() => {
            document.getElementById('taskDetailLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
            document.getElementById('taskDetailProgressLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
        });
}

async function saveDetailModal() {
    const name = document.getElementById('taskDetailTitle').value.trim();
    const desc = document.getElementById('taskDetailDesc').value;
    const progress = Number(document.getElementById('taskDetailProgress').value || 0);
    const note = document.getElementById('taskDetailProgressNote').value.trim();
    if (!name) return;

    const saveButton = document.querySelector('#taskDetailModal .btn-modal-action');
    if (saveButton) {
        saveButton.disabled = true;
        saveButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
    }

    try {
        const r1 = await fetch('/ProjectTracker/UpdateName', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, name, __RequestVerificationToken: token })
        });
        if (!r1.ok) throw new Error('UpdateName failed: ' + r1.status);

        const r2 = await fetch('/ProjectTracker/UpdateDescription', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, description: desc, __RequestVerificationToken: token })
        });
        if (!r2.ok) throw new Error('UpdateDescription failed: ' + r2.status);

        if (note || progress !== currentDetailProgress) {
            const r3 = await fetch('/ProjectTracker/UpdateProgress', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id: currentDetailId, progress, note, __RequestVerificationToken: token })
            });
            if (!r3.ok) throw new Error('UpdateProgress failed: ' + r3.status);
        }

        (bootstrap.Modal.getInstance(document.getElementById('taskDetailModal')) || new bootstrap.Modal(document.getElementById('taskDetailModal'))).hide();
    } catch (e) {
        console.error(e);
        alert('Unable to save changes. Please try again.');
    } finally {
        if (saveButton) {
            saveButton.disabled = false;
            saveButton.innerHTML = '<i class="fas fa-save me-1"></i>Save';
        }
    }
}

document.getElementById('taskDetailProgress').addEventListener('input', function () {
    syncProgressInputs(this.value);
});

document.querySelectorAll('.reopen-btn').forEach(btn => {
    btn.addEventListener('click', async function () {
        const id = this.getAttribute('data-project-id');
        try {
            const res = await fetch('/ProjectTracker/ReopenProject', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id, __RequestVerificationToken: token })
            });
            if (res.ok) location.reload();
        } catch { }
    });
});
</script>
}
