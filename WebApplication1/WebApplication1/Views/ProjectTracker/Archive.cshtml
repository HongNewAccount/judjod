@model IEnumerable<WebApplication1.Models.Project>
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "Archive";
    var userRole = Context.Session.GetString("UserRole") ?? "User";
    var searchTerm = ViewBag.SearchTerm ?? "";
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <div class="d-flex align-items-baseline gap-3">
                <h1 class="page-title mb-0"><i class="fas fa-archive me-2 text-success"></i>Archive</h1>
                <span class="badge bg-success">@Model.Count() Completed</span>
            </div>
            <p class="page-subtitle">All completed projects</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body py-2">
            <form method="get" asp-action="Archive" class="d-flex gap-2">
                <input type="text" name="searchTerm" class="form-control" placeholder="Search archived projects..." value="@searchTerm" />
                <button type="submit" class="btn btn-modal-action btn-sm" style="white-space:nowrap;">Search</button>
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <a asp-action="Archive" class="btn btn-sm btn-secondary" style="white-space:nowrap;">Clear</a>
                }
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="p-5 text-center">
                <i class="fas fa-archive" style="font-size:48px;color:#ccc;"></i>
                <p class="text-muted mt-3">No completed projects yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var project in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title fw-bold mb-0">@project.Name</h6>
                                <span class="badge bg-secondary ms-2 flex-shrink-0">Archived</span>
                            </div>

                            @if (project.Group != null)
                            {
                                <span class="badge mb-2" style="background: @(project.Group.Color ?? "#6c757d")22; color: @(project.Group.Color ?? "#6c757d"); border: 1px solid @(project.Group.Color ?? "#6c757d"); font-weight:600; font-size:.7rem;">
                                    @project.Group.Name
                                </span>
                            }

                            @if (!string.IsNullOrEmpty(project.Description))
                            {
                                <p class="card-text text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @project.Description
                                </p>
                            }

                            <div class="d-flex flex-wrap gap-2 mb-3 text-muted" style="font-size:.8rem;">
                                @if (project.Owners.Any())
                                {
                                    <span><i class="fas fa-users me-1"></i>@string.Join(", ", project.Owners.Select(o => o.User?.FirstName + " " + o.User?.LastName).Where(n => !string.IsNullOrWhiteSpace(n)))</span>
                                }
                                @if (project.EndDate.HasValue)
                                {
                                    <span><i class="fas fa-calendar-check me-1"></i>Due @project.EndDate.Value.ToString("dd MMM yyyy")</span>
                                }
                                @if (!string.IsNullOrEmpty(project.Priority) && project.Priority != "None")
                                {
                                    <span class="badge @(project.Priority switch { "High"=>"bg-danger","Medium"=>"bg-warning text-dark","Low"=>"bg-success",_=>"bg-secondary" })">@project.Priority</span>
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    Completed @((project.UpdatedAt ?? project.CreatedAt).ToString("dd MMM yyyy"))
                                </small>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-outline-success">
                                        <i class="fas fa-eye me-1"></i>View
                                    </a>
                                    @if (userRole == "Admin")
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary reopen-btn"
                                                data-project-id="@project.Id" title="Reopen project">
                                            <i class="fas fa-undo me-1"></i>Reopen
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
const archiveToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
document.querySelectorAll('.reopen-btn').forEach(btn => {
    btn.addEventListener('click', async function () {
        const id = this.getAttribute('data-project-id');
        try {
            const res = await fetch('/ProjectTracker/ReopenProject', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id, __RequestVerificationToken: archiveToken })
            });
            if (res.ok) location.reload();
        } catch { }
    });
});
</script>
}
