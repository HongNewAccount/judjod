@model IEnumerable<WebApplication1.Models.Project>
@inject WebApplication1.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "Board";
    var userRole = Context.Session.GetString("UserRole") ?? "User";
    var allUsers = DbContext.Users.Where(u => u.IsActive).ToList();
    var currentUserId = Context.Session.GetInt32("UserId") ?? 1;
    var isSuspended = (userRole != "Admin" && userRole != "Editor") || (DbContext.Users.Find(currentUserId)?.ProjectAccessSuspended ?? false);
    var pendingUpdates = (HashSet<int>)(ViewBag.PendingUpdates ?? new HashSet<int>());
    var pendingCreations = (IEnumerable<WebApplication1.Models.ProjectApprovalRequest>)(ViewBag.PendingCreations ?? new List<WebApplication1.Models.ProjectApprovalRequest>());
    var groups = (List<WebApplication1.Models.ProjectGroup>)(ViewBag.Groups ?? new List<WebApplication1.Models.ProjectGroup>());
    var selectedGroupId = (int?)ViewBag.SelectedGroupId;

    var columns = new (string Key, string Label, string Cls, string Icon)[]
    {
        ("Planning",   "To Do",       "secondary", "fa-list-ul"),
        ("InProgress", "In Progress", "primary",   "fa-spinner"),
        ("Late",       "Late",        "danger",    "fa-exclamation-circle"),
        ("Completed",  "Complete",    "success",   "fa-check-circle"),
    };

    string PriorityLabel(string? p) => p switch { "High"=>"High","Medium"=>"Medium","Low"=>"Low",_=>"Priority" };
    string PriorityCls(string? p) => p switch { "High"=>"priority-high","Medium"=>"priority-medium","Low"=>"priority-low",_=>"priority-none" };

    string DateLabel(DateTime? date) {
        if (!date.HasValue) return "Date";
        var days = (int)(date.Value.Date - DateTime.Today).TotalDays;
        var dateStr = date.Value.ToString("dd MMM ") + (date.Value.Year + 543);
        return days switch {
            0 => $"today · {dateStr}",
            > 0 => $"{days}d · {dateStr}",
            _ => $"{-days}d late · {dateStr}"
        };
    }
    string DateUrgencyCls(DateTime? date) {
        if (!date.HasValue) return "";
        var days = (int)(date.Value.Date - DateTime.Today).TotalDays;
        if (days < 0) return "date-overdue";
        if (days == 0) return "date-today";
        if (days <= 3) return "date-soon";
        return "";
    }
    string ToBE(DateTime? date) {
        if (!date.HasValue) return "";
        return date.Value.ToString("dd MMM ") + (date.Value.Year + 543);
    }
    string Initials(WebApplication1.Models.User? u) {
        if (u == null) return "?";
        var f = u.FirstName?.Length > 0 ? u.FirstName[0].ToString() : "";
        var l = u.LastName?.Length > 0 ? u.LastName[0].ToString() : "";
        return f + l;
    }

    string OwnerNamesFromCsv(string? csv)
    {
        if (string.IsNullOrEmpty(csv)) return "None";
        var ids = csv.Split(',').Select(s => int.TryParse(s, out var id) ? id : 0).Where(x => x > 0).ToList();
        var names = allUsers.Where(u => ids.Contains(u.Id)).Select(u => $"{u.FirstName} {u.LastName}");
        return names.Any() ? string.Join(", ", names) : "None";
    }
}

@Html.AntiForgeryToken()

<div class="container-fluid">
    <div class="row mb-3 page-header align-items-start">
        <div class="col">
            <h1 class="page-title mb-0">Board</h1>
            <p class="page-subtitle">Track and manage all organization projects</p>
        </div>
        @if (userRole == "Admin" || userRole == "Editor")
        {
            <div class="col-auto d-flex gap-2 align-items-center">
                <button type="button" id="btnDelete" class="btn btn-sm btn-outline-danger" onclick="enterSelectMode('delete')">
                    <i class="fas fa-trash me-1"></i>Delete
                </button>
                <button type="button" id="btnArchive" class="btn btn-sm btn-outline-success" onclick="enterSelectMode('archive')">
                    <i class="fas fa-archive me-1"></i>Archive
                </button>
            </div>
        }
    </div>

    <div class="card mb-3">
        <div class="card-body py-2">
            <input type="text" id="boardSearch" class="form-control" placeholder="Search by project or owner name..." />
        </div>
    </div>

    <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
        <button type="button" class="group-tab group-tab-active" id="filterAll" onclick="filterByGroup(null, this)">
            <i class="fas fa-th me-1"></i>All
        </button>
        @foreach (var g in groups)
        {
            <span class="group-tab" data-filter-group="@g.Id"
                  onclick="filterByGroup(@g.Id, this)"
                  style="cursor:pointer; @(g.Color != null ? $"--group-color: {g.Color};" : "")">
                <i class="fas fa-users me-1"></i>@g.Name
                @if (userRole == "Admin" || userRole == "Editor")
                {
                    <form asp-action="DeleteGroup" asp-route-id="@g.Id" method="post"
                          style="display:inline;" onsubmit="event.stopPropagation(); return confirm('Delete group &quot;@g.Name&quot;?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="group-tab-delete" title="Delete group"
                                onclick="event.stopPropagation()">&times;</button>
                    </form>
                }
            </span>
        }
        @if (userRole == "Admin" || userRole == "Editor")
        {
            <button type="button" class="group-tab group-tab-add" onclick="document.getElementById('newGroupForm').classList.toggle('d-none')">
                <i class="fas fa-plus me-1"></i>New Group
            </button>
            <form asp-action="CreateGroup" method="post" class="d-none d-flex gap-2 align-items-center" id="newGroupForm">
                @Html.AntiForgeryToken()
                <input type="text" name="name" class="form-control form-control-sm" placeholder="Group name" style="width:160px;" required />
                <input type="color" name="color" class="form-control form-control-color form-control-sm" value="#0d6efd" style="width:36px;padding:2px;" />
                <button type="submit" class="btn btn-sm btn-modal-action">Add</button>
                <button type="button" class="btn btn-sm btn-secondary" onclick="document.getElementById('newGroupForm').classList.add('d-none')">Cancel</button>
            </form>
        }
    </div>

    <div class="kanban-board" id="kanbanBoard">
        @foreach (var col in columns)
        {
            var colProjects = Model.Where(p => p.Status == col.Key).ToList();
            var colPending = pendingCreations.Where(r => (r.Status ?? "Planning") == col.Key).ToList();
            var count = colProjects.Count + colPending.Count;

            <div class="kanban-column kanban-col-@col.Cls">
                <div class="kanban-column-header kanban-column-@col.Cls">
                    <div class="kanban-column-title">
                        <i class="fas @col.Icon"></i>
                        <span>@col.Label</span>
                    </div>
                    <span class="kanban-column-count">@count</span>
                </div>

                @if (!isSuspended)
                {
                    <button type="button" class="kanban-add-task" onclick="openAddModal('@col.Key', @(selectedGroupId.HasValue ? selectedGroupId.Value.ToString() : "null"))">
                        <i class="fas fa-plus"></i> Add Task
                    </button>
                }

                <div class="kanban-column-body" data-status="@col.Key">
                    @foreach (var req in colPending)
                    {
                        <div class="kanban-card kanban-card-pending">
                            <span class="badge bg-warning text-dark mb-1" style="font-size:.65rem;"><i class="fas fa-hourglass-start me-1"></i>Pending</span>
                            <strong class="d-block">@req.Name</strong>
                            <div class="kanban-quick-row">
                                <span class="kanban-quick-btn kanban-quick-btn-empty"><i class="fas fa-user me-1"></i>@OwnerNamesFromCsv(req.OwnerIds)</span>
                            </div>
                            <form asp-action="CancelRequest" asp-route-id="@req.Id" method="post" onsubmit="return confirm('Cancel this request?');" class="mt-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">&times; Cancel</button>
                            </form>
                        </div>
                    }

                    @foreach (var project in colProjects)
                    {
                        var isAdmin = userRole == "Admin" || userRole == "Editor";
                        var isPendingEdit = pendingUpdates.Contains(project.Id);
                        var ownerIdList = string.Join(",", project.Owners.Select(o => o.UserId));

                        <div class="kanban-card"
                             data-project-id="@project.Id"
                             data-status="@project.Status"
                             data-sort-order="@project.SortOrder" data-group-id="@(project.GroupId?.ToString() ?? "")"
                             data-search="@($"{project.Name} {string.Join(' ', project.Owners.Select(o => o.User != null ? o.User.FirstName + ' ' + o.User.LastName : ""))}".ToLower())"
                             draggable="@(isAdmin ? "true" : "false")"
                             onclick="cardClicked(event, @project.Id, '@project.Name.Replace("'","\\'")')">

                            @if (isPendingEdit)
                            {
                                <span class="badge bg-warning text-dark mb-1" style="font-size:.65rem;"><i class="fas fa-hourglass-half me-1"></i>Pending</span>
                            }

                            <span class="kanban-card-title d-block">@project.Name</span>

                            @if (!string.IsNullOrWhiteSpace(project.Description))
                            {
                                <p class="kanban-card-desc">@project.Description</p>
                            }

                            <div class="kanban-quick-row">
                                @if (isAdmin)
                                {
                                    <div class="dropdown">
                                        <button type="button"
                                                class="kanban-quick-btn @(project.Owners.Any() ? "" : "kanban-quick-btn-empty")"
                                                data-bs-toggle="dropdown" title="Assignees">
                                            @if (project.Owners.Any())
                                            {
                                                <div class="kanban-avatars">
                                                    @foreach (var owner in project.Owners.Take(3))
                                                    {
                                                        <span class="kanban-card-avatar" title="@owner.User?.FirstName @owner.User?.LastName">
                                                            @Initials(owner.User)
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else { <i class="fas fa-user-plus"></i> }
                                        </button>
                                        <div class="dropdown-menu p-0 owner-picker" style="min-width:230px;" data-project-id="@project.Id">
                                            <div style="padding:.4rem .5rem;position:sticky;top:0;background:#fff;z-index:2;border-bottom:1px solid #f0f0f0;">
                                                <input type="text" class="form-control form-control-sm owner-search" placeholder="Search..." onclick="event.stopPropagation()" />
                                            </div>
                                            <div class="owner-scroll-list" style="max-height:220px;overflow-y:auto;padding:.25rem .5rem .5rem;">
                                            @foreach (var user in allUsers)
                                            {
                                                var isAssigned = project.Owners.Any(o => o.UserId == user.Id);
                                                <div class="owner-item py-1">
                                                    <label class="d-flex align-items-center gap-2" for="owner_@(project.Id)_@(user.Id)" style="cursor:pointer;margin:0;">
                                                        <input class="form-check-input flex-shrink-0 owner-checkbox" type="checkbox"
                                                               id="owner_@(project.Id)_@(user.Id)" value="@user.Id"
                                                               checked="@isAssigned" data-project-id="@project.Id"
                                                               style="margin:0;" />
                                                        @if (!string.IsNullOrEmpty(user.ProfileImagePath))
                                                        {
                                                            <img src="@user.ProfileImagePath" class="rounded-circle flex-shrink-0" style="width:24px;height:24px;object-fit:cover;" />
                                                        }
                                                        else
                                                        {
                                                            <span class="rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0" style="width:24px;height:24px;font-size:9px;background:linear-gradient(135deg,#667eea,#764ba2);">
                                                                @(user.FirstName.Length > 0 ? user.FirstName[0].ToString() : "")@(user.LastName?.Length > 0 ? user.LastName[0].ToString() : "")
                                                            </span>
                                                        }
                                                        <span class="small">@user.FirstName @user.LastName</span>
                                                    </label>
                                                </div>
                                            }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="dropdown">
                                        <button type="button"
                                                class="kanban-quick-btn @(project.GroupId.HasValue ? "kanban-quick-btn-group" : "kanban-quick-btn-empty")"
                                                data-bs-toggle="dropdown" data-bs-auto-close="outside" title="Group">
                                            @if (project.Group?.Color != null)
                                            {
                                                <span style="width:8px;height:8px;border-radius:50%;background:@project.Group.Color;display:inline-block;margin-right:4px;flex-shrink:0;"></span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-users me-1"></i>
                                            }
                                            <span>@(project.Group?.Name ?? "Group")</span>
                                        </button>
                                        <div class="dropdown-menu p-0 group-picker" style="min-width:190px;" data-project-id="@project.Id">
                                            <div style="padding:.4rem .5rem;position:sticky;top:0;background:#fff;z-index:2;border-bottom:1px solid #f0f0f0;">
                                                <input type="text" class="form-control form-control-sm group-search" placeholder="Search team..." onclick="event.stopPropagation()" />
                                            </div>
                                            <div style="max-height:200px;overflow-y:auto;padding:.25rem .5rem .5rem;">
                                                <div class="group-item py-1">
                                                    <label class="d-flex align-items-center gap-2" style="cursor:pointer;margin:0;font-size:.85rem;">
                                                        <input type="radio" class="form-check-input flex-shrink-0 group-radio" name="grp_@project.Id"
                                                               value="" @(project.GroupId == null ? "checked" : "") data-project-id="@project.Id" style="margin:0;" />
                                                        <i class="fas fa-times" style="color:#aaa;font-size:.75rem;"></i>
                                                        <span class="small">None</span>
                                                    </label>
                                                </div>
                                                @foreach (var g in groups)
                                                {
                                                    <div class="group-item py-1">
                                                        <label class="d-flex align-items-center gap-2" style="cursor:pointer;margin:0;font-size:.85rem;">
                                                            <input type="radio" class="form-check-input flex-shrink-0 group-radio" name="grp_@project.Id"
                                                                   value="@g.Id" @(project.GroupId == g.Id ? "checked" : "") data-project-id="@project.Id"
                                                                   data-group-id="@g.Id" style="margin:0;" />
                                                            <span style="width:10px;height:10px;border-radius:50%;background:@(g.Color ?? "#6c757d");flex-shrink:0;display:inline-block;"></span>
                                                            <span class="small">@g.Name</span>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="kanban-date-wrap">
                                        <button type="button"
                                                class="kanban-quick-btn @(project.EndDate.HasValue ? DateUrgencyCls(project.EndDate) : "kanban-quick-btn-empty")"
                                                title="@ToBE(project.EndDate)"
                                                onclick="toggleDatePicker(this)"
                                                data-project-id="@project.Id">
                                            <i class="fas fa-calendar-alt me-1"></i>
                                            <span class="due-date-label">@DateLabel(project.EndDate)</span>
                                        </button>
                                        <input type="date" class="kanban-date-input form-control form-control-sm d-none"
                                               value="@(project.EndDate?.ToString("yyyy-MM-dd") ?? "")"
                                               data-project-id="@project.Id" />
                                    </div>

                                    <div class="dropdown">
                                        <button type="button"
                                                class="kanban-quick-btn kanban-priority-btn @PriorityCls(project.Priority)"
                                                data-bs-toggle="dropdown" title="Priority">
                                            <i class="fas fa-flag me-1"></i>
                                            <span class="priority-label">@PriorityLabel(project.Priority)</span>
                                        </button>
                                        <div class="dropdown-menu p-1" style="min-width:130px;">
                                            @foreach (var pOpt in new[] { "None","Low","Medium","High" })
                                            {
                                                <button class="dropdown-item small priority-pick-btn" type="button"
                                                        data-project-id="@project.Id" data-priority="@pOpt">
                                                    @pOpt
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @if (project.Owners.Any())
                                    {
                                        <span class="kanban-quick-btn kanban-quick-btn-empty" style="cursor:default;" title="Assignees">
                                            <div class="kanban-avatars">
                                                @foreach (var owner in project.Owners.Take(3))
                                                {
                                                    <span class="kanban-card-avatar">@Initials(owner.User)</span>
                                                }
                                            </div>
                                        </span>
                                    }
                                    @if (project.EndDate.HasValue)
                                    {
                                        <span class="kanban-quick-btn @DateUrgencyCls(project.EndDate)" style="cursor:default;"
                                              title="@project.EndDate.Value.ToString("dd MMM yyyy")">
                                            <i class="fas fa-calendar-alt me-1"></i>@DateLabel(project.EndDate)
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(project.Priority) && project.Priority != "None")
                                    {
                                        <span class="kanban-quick-btn kanban-priority-btn @PriorityCls(project.Priority)" style="cursor:default;">
                                            <i class="fas fa-flag me-1"></i>@PriorityLabel(project.Priority)
                                        </span>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<div id="bulkBottomBar" class="bulk-fab-bar d-none">
    <div class="bulk-fab-count" id="bulkSelectionCount">0 selected</div>
    <div class="d-flex gap-3 justify-content-center">
        <button type="button" id="bulkApplyBtn" class="bulk-fab-btn bulk-fab-apply" onclick="applyBulkAction()" title="Apply">
            <i class="fas fa-check"></i>
        </button>
        <button type="button" class="bulk-fab-btn bulk-fab-cancel" onclick="exitSelectMode()" title="Cancel">
            <i class="fas fa-times"></i>
        </button>
    </div>
</div>

<div class="modal fade" id="addTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <h6 class="modal-title fw-bold" id="addTaskModalTitle">Add Task</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <div class="mb-3">
                    <input type="text" id="addTaskName" class="form-control" placeholder="Task name *" />
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label small fw-semibold">Priority</label>
                        <select id="addTaskPriority" class="form-select form-select-sm">
                            <option value="None">None</option>
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold">Due Date</label>
                        <input type="date" id="addTaskDate" class="form-control form-control-sm" />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label small fw-semibold">Assignees</label>
                    <div class="modal-assignee-list">
                        @foreach (var user in allUsers)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input add-task-assignee" type="checkbox"
                                       id="addAssignee_@user.Id" value="@user.Id" />
                                <label class="form-check-label small" for="addAssignee_@user.Id">@user.FirstName @user.LastName</label>
                            </div>
                        }
                    </div>
                </div>
                <div id="addTaskError" class="text-danger small d-none"></div>
            </div>
            <div class="modal-footer py-2 px-3">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-modal-action" id="addTaskSubmit" onclick="submitAddTask()">
                    <i class="fas fa-plus me-1"></i>Add Task
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <input type="text" id="taskDetailTitle" class="form-control form-control-sm fw-bold border-0 p-0"
                       style="font-size:1rem;box-shadow:none;" placeholder="Task name" />
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" style="max-height:70vh;overflow-y:auto;">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Description</label>
                        <textarea id="taskDetailDesc" class="form-control form-control-sm" rows="8"
                                  placeholder="Add a description..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Activity Log</label>
                        <div id="taskDetailLog" style="max-height:250px;overflow-y:auto;font-size:.8rem;">
                            <div class="text-muted">Loading...</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 px-3">
                <button type="button" class="btn btn-modal-action btn-sm" onclick="saveDetailModal()">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<script>
const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

function filterByGroup(groupId, tabEl) {
    document.querySelectorAll('.group-tab').forEach(t => t.classList.remove('group-tab-active'));
    if (tabEl) tabEl.classList.add('group-tab-active');
    document.querySelectorAll('.kanban-card[data-project-id]').forEach(card => {
        if (!groupId) {
            card.style.display = '';
        } else {
            const cg = card.getAttribute('data-group-id');
            card.style.display = (String(cg) === String(groupId)) ? '' : 'none';
        }
    });
}
document.getElementById('boardSearch').addEventListener('keyup', function () {
    const term = this.value.toLowerCase();
    document.querySelectorAll('.kanban-card[data-search]').forEach(card => {
        card.style.display = card.getAttribute('data-search').includes(term) ? '' : 'none';
    });
});

let selectMode = null;

function enterSelectMode(mode) {
    selectMode = mode;
    const bar = document.getElementById('bulkBottomBar');
    bar.classList.remove('d-none');
    const applyBtn = document.getElementById('bulkApplyBtn');
    if (mode === 'delete') {
        applyBtn.className = 'bulk-fab-btn bulk-fab-apply bulk-fab-delete';
        applyBtn.title = 'Delete selected';
        document.getElementById('btnDelete')?.classList.replace('btn-outline-danger', 'btn-danger');
        document.getElementById('btnArchive')?.classList.replace('btn-success', 'btn-outline-success');
    } else {
        applyBtn.className = 'bulk-fab-btn bulk-fab-apply bulk-fab-archive';
        applyBtn.title = 'Archive selected';
        document.getElementById('btnArchive')?.classList.replace('btn-outline-success', 'btn-success');
        document.getElementById('btnDelete')?.classList.replace('btn-danger', 'btn-outline-danger');
    }
    document.querySelectorAll('.kanban-card[data-project-id]').forEach(card => {
        const status = card.getAttribute('data-status');
        const isEligible = mode === 'delete' || status === 'Completed';
        if (!isEligible) return;

        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.className = 'bulk-cb';
        cb.addEventListener('change', updateBulkCount);
        cb.addEventListener('click', e => e.stopPropagation());
        card.prepend(cb);
    });
    document.getElementById('kanbanBoard').classList.add('select-mode');
    updateBulkCount();
}

function exitSelectMode() {
    selectMode = null;
    document.getElementById('bulkBottomBar').classList.add('d-none');
    document.querySelectorAll('.bulk-cb').forEach(cb => cb.remove());
    document.getElementById('kanbanBoard').classList.remove('select-mode');
    document.getElementById('btnDelete')?.classList.replace('btn-danger', 'btn-outline-danger');
    document.getElementById('btnArchive')?.classList.replace('btn-success', 'btn-outline-success');
}

function updateBulkCount() {
    const count = document.querySelectorAll('.bulk-cb:checked').length;
    document.getElementById('bulkSelectionCount').textContent = count + ' selected';
}

async function applyBulkAction() {
    const checked = [...document.querySelectorAll('.bulk-cb:checked')];
    if (checked.length === 0) { alert('Select at least one task.'); return; }
    const projectIds = checked.map(cb => cb.closest('.kanban-card').getAttribute('data-project-id')).join(',');
    const action = selectMode;
    try {
        const res = await fetch('/ProjectTracker/BulkAction', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ action, projectIds, __RequestVerificationToken: token })
        });
        if (res.ok) location.reload();
        else alert('Action failed.');
    } catch { alert('Error occurred.'); }
}

function cardClicked(e, id, name) {
    if (selectMode) {
        const card = e.currentTarget;
        const cb = card.querySelector('.bulk-cb');
        if (cb && e.target !== cb) { cb.checked = !cb.checked; updateBulkCount(); }
        return;
    }
    if (e.target.closest('.kanban-quick-row')) return;
    const skipTags = ['BUTTON','INPUT','SELECT','TEXTAREA','A'];
    if (skipTags.includes(e.target.tagName)) return;
    openDetailModal(id, name, null);
}

function updatePriorityDOM(id, priority) {
    const card = document.querySelector('.kanban-card[data-project-id="' + id + '"]');
    if (!card) return;
    const btn = card.querySelector('.kanban-priority-btn');
    const label = btn?.querySelector('.priority-label');
    if (btn) {
        btn.classList.remove('priority-none','priority-low','priority-medium','priority-high');
        const m = {None:'priority-none',Low:'priority-low',Medium:'priority-medium',High:'priority-high'};
        btn.classList.add(m[priority] || 'priority-none');
    }
    if (label) label.textContent = (priority === 'None') ? 'Priority' : priority;
}

function updateDateDOM(id, endDate) {
    const card = document.querySelector('.kanban-card[data-project-id="' + id + '"]');
    if (!card) return;
    const label = card.querySelector('.due-date-label');
    const dateBtn = label?.closest('button');
    if (!label) return;
    if (!endDate) { label.textContent = 'Date'; return; }
    const d = new Date(endDate + 'T00:00:00');
    const today = new Date(); today.setHours(0,0,0,0);
    const days = Math.round((d - today) / 86400000);
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const dateStr = d.getDate() + ' ' + months[d.getMonth()] + ' ' + (d.getFullYear() + 543);
    label.textContent = days === 0 ? 'today · ' + dateStr : (days > 0 ? days + 'd · ' + dateStr : (-days) + 'd late · ' + dateStr);
    if (dateBtn) {
        dateBtn.classList.remove('date-today','date-soon','date-overdue','kanban-quick-btn-empty');
        dateBtn.title = dateStr;
        if (days === 0) dateBtn.classList.add('date-today');
        else if (days > 0 && days <= 3) dateBtn.classList.add('date-soon');
        else if (days < 0) dateBtn.classList.add('date-overdue');
    }
}

function updateGroupDOM(id, groupId, radioEl) {
    const card = document.querySelector('.kanban-card[data-project-id="' + id + '"]');
    if (!card) return;
    const groupDropdown = [...card.querySelectorAll('.kanban-quick-row .dropdown')]
        .find(dd => dd.querySelector('.group-picker, .group-radio'));
    if (!groupDropdown) return;
    const btn = groupDropdown.querySelector('[data-bs-toggle="dropdown"]');
    if (!btn) return;
    const nameSpan = btn.querySelector('span:last-child');

    if (groupId) {
        const label = radioEl?.closest?.('.group-item') ?? radioEl?.parentElement;
        const colorDot = label?.querySelector('span[style*="border-radius:50%"]');
        const nameEl = label?.querySelector('span.small');
        const color = colorDot?.style?.background || '#6c757d';
        const groupName = nameEl?.textContent?.trim() || 'Team';

        btn.className = 'kanban-quick-btn kanban-quick-btn-group';
        let dot = btn.querySelector('span[style*="border-radius:50%"]');
        const usersIcon = btn.querySelector('i.fa-users');
        if (usersIcon) usersIcon.remove();
        if (!dot) {
            dot = document.createElement('span');
            dot.style.cssText = 'width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:4px;flex-shrink:0;';
            btn.insertBefore(dot, nameSpan);
        }
        dot.style.background = color;
        if (nameSpan) nameSpan.textContent = groupName;
    } else {
        btn.className = 'kanban-quick-btn kanban-quick-btn-empty';
        const dot = btn.querySelector('span[style*="border-radius:50%"]');
        if (dot) dot.remove();
        if (!btn.querySelector('i.fa-users')) {
            const icon = document.createElement('i');
            icon.className = 'fas fa-users me-1';
            btn.insertBefore(icon, nameSpan);
        }
        if (nameSpan) nameSpan.textContent = 'Group';
    }
}

document.querySelectorAll('.priority-pick-btn').forEach(btn => {
    btn.addEventListener('click', async function () {
        const id = this.getAttribute('data-project-id');
        const priority = this.getAttribute('data-priority');
        try {
            const res = await fetch('/ProjectTracker/UpdatePriority', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id, priority, __RequestVerificationToken: token })
            });
            if (res.ok) updatePriorityDOM(id, priority);
        } catch (e) { console.error(e); }
    });
});

function toggleDatePicker(btn) {
    const wrap = btn.closest('.kanban-date-wrap');
    const input = wrap.querySelector('.kanban-date-input');
    if (!input) return;
    input.classList.toggle('d-none');
    if (!input.classList.contains('d-none')) input.focus();
}

document.querySelectorAll('.kanban-date-input').forEach(input => {
    input.addEventListener('change', async () => {
        const id = input.getAttribute('data-project-id');
        const endDate = input.value;
        try {
            const res = await fetch('/ProjectTracker/UpdateDueDate', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id, endDate, __RequestVerificationToken: token })
            });
            if (res.ok) { updateDateDOM(id, endDate); }
        } catch (e) { console.error(e); }
    });
    input.addEventListener('blur', () => input.classList.add('d-none'));
});

function updateOwnerAvatars(projectId, picker) {
    const card = document.querySelector('.kanban-card[data-project-id="' + projectId + '"]');
    if (!card) return;
    const checked = [...picker.querySelectorAll('.owner-checkbox:checked')];
    const btn = picker.closest('.dropdown')?.querySelector('[data-bs-toggle="dropdown"]');
    if (!btn) return;
    if (checked.length === 0) {
        btn.className = 'kanban-quick-btn kanban-quick-btn-empty';
        btn.innerHTML = '<i class="fas fa-user-plus"></i>';
    } else {
        btn.className = 'kanban-quick-btn';
        const avatarsHtml = checked.slice(0, 3).map(cb => {
            const label = picker.querySelector('label[for="' + cb.id + '"] span.small');
            const name = label ? label.textContent.trim() : '?';
            const parts = name.trim().split(' ');
            const initials = (parts[0]?.[0] || '') + (parts[1]?.[0] || '');
            return '<span class="kanban-card-avatar">' + (initials || '?') + '</span>';
        }).join('');
        btn.innerHTML = '<div class="kanban-avatars">' + avatarsHtml + '</div>';
    }
}

document.querySelectorAll('.owner-checkbox').forEach(cb => {
    cb.addEventListener('change', async function () {
        const id = this.getAttribute('data-project-id');
        const picker = this.closest('.owner-picker');
        const checked = [...picker.querySelectorAll('.owner-checkbox:checked')].map(c => c.value);
        try {
            await fetch('/ProjectTracker/UpdateOwners', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id, ownerIds: checked.join(','), __RequestVerificationToken: token })
            });
            updateOwnerAvatars(id, picker);
        } catch (e) { console.error(e); }
    });
});

document.querySelectorAll('.kanban-card .dropdown').forEach(dd => {
    const col = dd.closest('.kanban-column');
    dd.addEventListener('show.bs.dropdown', () => { if (col) col.style.overflow = 'visible'; });
    dd.addEventListener('hide.bs.dropdown', () => { if (col) col.style.overflow = ''; });
});

document.querySelectorAll('.owner-search').forEach(input => {
    input.addEventListener('input', function () {
        const term = this.value.toLowerCase();
        const list = this.closest('.owner-picker').querySelector('.owner-scroll-list');
        (list || this.closest('.owner-picker')).querySelectorAll('.owner-item').forEach(item => {
            const name = item.querySelector('span.small')?.textContent?.toLowerCase() ?? '';
            item.style.display = name.includes(term) ? '' : 'none';
        });
    });
    input.addEventListener('keydown', e => e.stopPropagation());
});

document.querySelectorAll('.group-radio').forEach(radio => {
    radio.addEventListener('change', async function () {
        const id = this.getAttribute('data-project-id');
        const groupId = this.value || '';
        try {
            await fetch('/ProjectTracker/AssignGroup', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id, groupId, __RequestVerificationToken: token })
            });
            updateGroupDOM(id, groupId, this);
            const dropdownEl = this.closest('.dropdown')?.querySelector('[data-bs-toggle="dropdown"]');
            if (dropdownEl) { const inst = bootstrap.Dropdown.getInstance(dropdownEl); if (inst) inst.hide(); }
        } catch (e) { console.error(e); }
    });
});

document.querySelectorAll('.group-search').forEach(input => {
    input.addEventListener('input', function () {
        const term = this.value.toLowerCase();
        const picker = this.closest('.group-picker');
        picker?.querySelectorAll('.group-item').forEach(item => {
            const name = item.querySelector('span.small')?.textContent?.toLowerCase() ?? '';
            item.style.display = name.includes(term) ? '' : 'none';
        });
    });
    input.addEventListener('keydown', e => e.stopPropagation());
});

let currentAddStatus = 'Planning';
let currentAddGroupId = null;

function openAddModal(status, groupId) {
    currentAddStatus = status;
    currentAddGroupId = (groupId === null || groupId === 'null') ? null : parseInt(groupId);

    document.getElementById('addTaskName').value = '';
    document.getElementById('addTaskDate').value = '';
    document.getElementById('addTaskPriority').value = 'None';
    document.getElementById('addTaskError').classList.add('d-none');
    document.querySelectorAll('.add-task-assignee').forEach(cb => cb.checked = false);

    const titles = { Planning: 'To Do', InProgress: 'In Progress', Late: 'Late', Completed: 'Complete' };
    document.getElementById('addTaskModalTitle').textContent = 'Add Task - ' + (titles[status] || status);

    new bootstrap.Modal(document.getElementById('addTaskModal')).show();
    setTimeout(() => document.getElementById('addTaskName').focus(), 300);
}

document.getElementById('addTaskName').addEventListener('keydown', e => {
    if (e.key === 'Enter') submitAddTask();
});

async function submitAddTask() {
    const name = document.getElementById('addTaskName').value.trim();
    const errEl = document.getElementById('addTaskError');
    if (!name) { errEl.textContent = 'Task name is required.'; errEl.classList.remove('d-none'); return; }

    errEl.classList.add('d-none');
    const status = currentAddStatus;
    const priority = document.getElementById('addTaskPriority').value;
    const endDate = document.getElementById('addTaskDate').value;
    const groupId = currentAddGroupId ?? '';
    const ownerIds = [...document.querySelectorAll('.add-task-assignee:checked')].map(c => c.value).join(',');

    const btn = document.getElementById('addTaskSubmit');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Adding...';

    try {
        const res = await fetch('/ProjectTracker/CreateQuick', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ name, status, priority, endDate, ownerIds, groupId, __RequestVerificationToken: token })
        });
        if (res.ok) {
            bootstrap.Modal.getInstance(document.getElementById('addTaskModal')).hide();
            location.reload();
        } else {
            errEl.textContent = 'Failed to create task.';
            errEl.classList.remove('d-none');
        }
    } catch (e) {
        errEl.textContent = 'Error: ' + e.message;
        errEl.classList.remove('d-none');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-plus me-1"></i>Add Task';
    }
}

let currentDetailId = null;
let currentDetailStatus = null;
function openDetailModal(id, name, status) {
    currentDetailId = id;
    currentDetailStatus = status || null;
    document.getElementById('taskDetailTitle').value = name;
    const archiveBtn = document.getElementById('modalArchiveBtn');
    if (archiveBtn) archiveBtn.style.display = (status === 'Completed') ? '' : 'none';
    document.getElementById('taskDetailDesc').value = '';
    document.getElementById('taskDetailLog').innerHTML = '<div class="text-muted small">Loading...</div>';

    new bootstrap.Modal(document.getElementById('taskDetailModal')).show();

    fetch('/ProjectTracker/GetProjectDetails?id=' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            if (data.name) document.getElementById('taskDetailTitle').value = data.name;
            if (data.status) { currentDetailStatus = data.status; const ab=document.getElementById('modalArchiveBtn'); if(ab) ab.style.display=(data.status==='Completed'?'':'none'); }
            document.getElementById('taskDetailDesc').value = data.description || '';
            const logEl = document.getElementById('taskDetailLog');
            if (!data.logs || data.logs.length === 0) {
                logEl.innerHTML = '<div class="text-muted small">No activity yet</div>';
            } else {
                logEl.innerHTML = data.logs.map(l => `
                    <div class="task-log-entry">
                        <span class="task-log-action">${l.actionType}</span>
                        <span class="task-log-desc">${l.description || ''}</span>
                        ${l.oldValue && l.newValue ? `<small class="text-muted ms-1">${l.oldValue} â†’ ${l.newValue}</small>` : ''}
                        <div class="task-log-meta">${l.userName} Â· ${l.createdAt}</div>
                    </div>`).join('');
            }
        })
        .catch(() => {
            document.getElementById('taskDetailLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
        });
}

async function saveDetailModal() {
    const name = document.getElementById('taskDetailTitle').value.trim();
    const desc = document.getElementById('taskDetailDesc').value;
    if (!name) return;

    await Promise.all([
        fetch('/ProjectTracker/UpdateName', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, name, __RequestVerificationToken: token })
        }),
        fetch('/ProjectTracker/UpdateDescription', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, description: desc, __RequestVerificationToken: token })
        })
    ]);

    bootstrap.Modal.getInstance(document.getElementById('taskDetailModal')).hide();
}

async function archiveCurrentTask() {
    if (!currentDetailId) return;
    if (!confirm('Archive this task? It will be removed from the board.')) return;
    try {
        const res = await fetch('/ProjectTracker/UpdateStatus', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, status: 'Closed', __RequestVerificationToken: token })
        });
        if (res.ok) {
            bootstrap.Modal.getInstance(document.getElementById('taskDetailModal')).hide();
            location.reload();
        }
    } catch (e) { console.error(e); }
}

let draggedCard = null;
let placeholder = null;

function createPlaceholder() {
    const p = document.createElement('div');
    p.className = 'kanban-drag-placeholder';
    return p;
}

document.querySelectorAll('.kanban-card[draggable="true"]').forEach(card => {
    card.addEventListener('dragstart', e => {
        if (selectMode) { e.preventDefault(); return; }
        draggedCard = card;
        setTimeout(() => { card.classList.add('dragging'); }, 0);
        e.dataTransfer.effectAllowed = 'move';
    });
    card.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        placeholder?.remove();
        placeholder = null;
        lastDropTarget = null; lastDropBody = null;
        document.querySelectorAll('.kanban-column-body.drag-over').forEach(b => b.classList.remove('drag-over'));
        draggedCard = null;
    });
});

let lastDropTarget = null; // card to insertBefore, or null = append at end
let lastDropBody = null;   // which column body was last hovered

document.querySelectorAll('.kanban-column-body').forEach(body => {
    body.addEventListener('dragover', e => {
        if (!draggedCard) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        body.classList.add('drag-over');

        const afterCard = getDragAfterCard(body, e.clientY);
        lastDropTarget = afterCard ?? null;
        lastDropBody = body;

        if (!placeholder) placeholder = createPlaceholder();
        if (afterCard) body.insertBefore(placeholder, afterCard);
        else body.appendChild(placeholder);
    });

    body.addEventListener('dragleave', e => {
        if (body.contains(e.relatedTarget)) return;
        body.classList.remove('drag-over');
        placeholder?.remove();
        placeholder = null;
    });

    body.addEventListener('drop', async e => {
        e.preventDefault();
        body.classList.remove('drag-over');
        if (!draggedCard) return;

        const newStatus = body.getAttribute('data-status');
        const oldStatus = draggedCard.getAttribute('data-status');
        const projectId = draggedCard.getAttribute('data-project-id');

        const insertBefore = (placeholder && body.contains(placeholder))
            ? placeholder
            : (lastDropTarget && body.contains(lastDropTarget) ? lastDropTarget : null);

        if (insertBefore) {
            body.insertBefore(draggedCard, insertBefore);
        } else {
            body.appendChild(draggedCard);
        }

        if (placeholder) { placeholder.remove(); placeholder = null; }
        lastDropTarget = null; lastDropBody = null;

        const orderedIds = [...body.querySelectorAll('.kanban-card[data-project-id]')]
            .map(c => parseInt(c.getAttribute('data-project-id')))
            .filter(id => id > 0);

        const saveReorder = async () => {
            if (orderedIds.length === 0) return;
            try {
                await fetch('/ProjectTracker/ReorderProjects', {
                    method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new URLSearchParams({ orderedIds: orderedIds.join(',') })
                });
            } catch (err) { console.error('ReorderProjects error:', err); }
        };

        if (newStatus !== oldStatus) {
            draggedCard.setAttribute('data-status', newStatus);
            try {
                await fetch('/ProjectTracker/UpdateStatus', {
                    method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new URLSearchParams({ id: projectId, status: newStatus, __RequestVerificationToken: token })
                });
                await saveReorder();
            } catch {  }
            updateColumnCounts();
        } else {
            saveReorder(); // fire-and-forget, no reload
        }
    });
});

function getDragAfterCard(container, y) {
    const cards = [...container.querySelectorAll('.kanban-card:not(.dragging)')];
    return cards.reduce((closest, card) => {
        const box = card.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        if (offset < 0 && offset > (closest.offset ?? -Infinity)) {
            return { offset, element: card };
        }
        return closest;
    }, {}).element;
}

(function () {
    const taskId = new URLSearchParams(window.location.search).get('openTask');
    if (!taskId) return;
    const card = document.querySelector(`.kanban-card[data-project-id="${taskId}"]`);
    const name = card ? (card.querySelector('.kanban-card-title')?.textContent?.trim() || '') : '';
    openDetailModal(parseInt(taskId), name);
    history.replaceState(null, '', window.location.pathname + (window.location.search.replace(/[?&]openTask=\d+/, '') || ''));
})();

function updateColumnCounts() {
    document.querySelectorAll('.kanban-column').forEach(col => {
        const body = col.querySelector('.kanban-column-body');
        const header = col.querySelector('.kanban-column-count');
        if (body && header) {
            const count = body.querySelectorAll('.kanban-card').length;
            header.textContent = count;
        }
    });
}
</script>

