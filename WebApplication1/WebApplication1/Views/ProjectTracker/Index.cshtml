@model IEnumerable<WebApplication1.Models.Project>
@inject WebApplication1.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "Project Tracker";
    var stats = (Dictionary<string, int>)ViewBag.Stats ?? new Dictionary<string, int>();
    var userRole = Context.Session.GetString("UserRole") ?? "User";
    var allUsers = DbContext.Users.Where(u => u.IsActive).ToList();
    var currentUserIdForSuspension = Context.Session.GetInt32("UserId") ?? 1;
    var isSuspended = userRole != "Admin" && (DbContext.Users.Find(currentUserIdForSuspension)?.ProjectAccessSuspended ?? false);
    var searchTerm = ViewBag.SearchTerm ?? "";
    var currentSort = ViewBag.CurrentSort ?? "latest";
    var currentFilter = ViewBag.CurrentFilter ?? "all";

    string GetStatusClass(string status) => status switch
    {
        "Planning" => "bg-secondary",
        "InProgress" => "bg-primary",
        "Late" => "bg-danger text-white",
        "Completed" => "bg-success",
        _ => "bg-secondary"
    };

    string GetStatusTextClass(string status) => status switch
    {
        "Planning" => "text-secondary",
        "InProgress" => "text-primary",
        "Late" => "text-danger",
        "Completed" => "text-success",
        _ => "text-secondary"
    };
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Project Tracker</h1>
            <p class="page-subtitle">Track and manage all organization projects</p>
        </div>
        <div class="col-auto">
            @if (isSuspended)
            {
                <span class="btn btn-action disabled" style="opacity: 0.5; cursor: not-allowed;" title="Your project access has been suspended by an Admin.">
                    <i class="fas fa-plus me-2"></i>Create New Project
                </span>
            }
            else
            {
                <a asp-action="Create" class="btn btn-action">
                    <i class="fas fa-plus me-2"></i>Create New Project
                </a>
            }
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-4">
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-total">
                <div class="stat-card-icon"><i class="fas fa-folder"></i></div>
                <div>
                    <div class="stat-card-value">@(stats.ContainsKey("TotalProjects") ? stats["TotalProjects"] : 0)</div>
                    <div class="stat-card-label">Total Projects</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-secondary">
                <div class="stat-card-icon"><i class="fas fa-circle"></i></div>
                <div>
                    <div class="stat-card-value">@(stats.ContainsKey("PlanningProjects") ? stats["PlanningProjects"] : 0)</div>
                    <div class="stat-card-label">Planning Projects</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-icon"><i class="fas fa-spinner"></i></div>
                <div>
                    <div class="stat-card-value">@(stats.ContainsKey("ActiveProjects") ? stats["ActiveProjects"] : 0)</div>
                    <div class="stat-card-label">Active Projects</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-danger">
                <div class="stat-card-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div>
                    <div class="stat-card-value">@(stats.ContainsKey("LateProjects") ? stats["LateProjects"] : 0)</div>
                    <div class="stat-card-label">Late Projects</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-warning">
                <div class="stat-card-icon"><i class="fas fa-star"></i></div>
                <div>
                    <div class="stat-card-value">@(stats.ContainsKey("FavoriteProjects") ? stats["FavoriteProjects"] : 0)</div>
                    <div class="stat-card-label">Favorite Projects</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-success">
                <div class="stat-card-icon"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="stat-card-value">@(stats.ContainsKey("CompletedProjects") ? stats["CompletedProjects"] : 0)</div>
                    <div class="stat-card-label">Completed Projects</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search, Filter & Sort -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by project or owner name..." value="@searchTerm" />
                </div>
                <div class="col-md-3">
                    <select name="filter" class="form-select">
                        <option value="all" selected="@(currentFilter == "all")">All</option>
                        <option value="planning" selected="@(currentFilter == "planning")">Planning</option>
                        <option value="inprogress" selected="@(currentFilter == "inprogress")">Active</option>
                        <option value="late" selected="@(currentFilter == "late")">Late</option>
                        <option value="completed" selected="@(currentFilter == "completed")">Completed</option>
                        <option value="favorites" selected="@(currentFilter == "favorites")">Favorite</option>
                        <option value="thismonth" selected="@(currentFilter == "thismonth")">This Month</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="latest" selected="@(currentSort == "latest")">Latest</option>
                        <option value="date_asc" selected="@(currentSort == "date_asc")">Start Date (Old→New)</option>
                        <option value="date_desc" selected="@(currentSort == "date_desc")">Start Date (New→Old)</option>
                        <option value="enddate_asc" selected="@(currentSort == "enddate_asc")">End Date (Old→New)</option>
                        <option value="enddate_desc" selected="@(currentSort == "enddate_desc")">End Date (New→Old)</option>
                        <option value="name_asc" selected="@(currentSort == "name_asc")">Name (A-Z)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-action w-100">Search</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Projects Table -->
    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">All Projects</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any() || (ViewBag.PendingCreations != null && ((IEnumerable<WebApplication1.Models.ProjectApprovalRequest>)ViewBag.PendingCreations).Any()))
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Project Name</th>
                                <th>Owners</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                                <th>Created By</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.PendingCreations != null)
                            {
                                @foreach (var req in (IEnumerable<WebApplication1.Models.ProjectApprovalRequest>)ViewBag.PendingCreations)
                                {
                                    <tr class="table-warning border-start border-4 border-warning align-middle">
                                        <td>
                                            <strong class="text-warning">
                                                @req.Name
                                            </strong>
                                            <span class="badge bg-warning text-dark ms-1">
                                                <i class="fas fa-hourglass-start me-1"></i>Pending Creation
                                            </span>
                                            @if (!string.IsNullOrEmpty(req.Description))
                                            {
                                                <br />
                                                <small class="text-muted">@req.Description.Substring(0, Math.Min(50, req.Description.Length))...</small>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                var ownerNames = "None";
                                                if (!string.IsNullOrEmpty(req.OwnerIds))
                                                {
                                                    var ids = req.OwnerIds.Split(',').Select(s => int.TryParse(s, out var id) ? id : 0).Where(x => x > 0).ToList();
                                                    var names = allUsers.Where(u => ids.Contains(u.Id)).Select(u => $"{u.FirstName} {u.LastName}");
                                                    if (names.Any())
                                                    {
                                                        ownerNames = string.Join(", ", names);
                                                    }
                                                }
                                            }
                                            @ownerNames
                                        </td>
                                        <td>@req.StartDate.ToString("dd MMM yyyy")</td>
                                        <td>@(req.EndDate?.ToString("dd MMM yyyy") ?? "Ongoing")</td>
                                        <td>
                                            <span class="badge bg-secondary">@req.Status</span>
                                        </td>
                                        <td>@req.RequestedByUser?.FirstName @req.RequestedByUser?.LastName</td>
                                        <td>
                                            <form asp-action="CancelRequest" asp-route-id="@req.Id" method="post" onsubmit="return confirm('Are you sure you want to cancel this creation request?');" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-times me-1"></i> Cancel
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }

                            @foreach (var project in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="@GetStatusTextClass(project.Status)">
                                            @project.Name
                                            @if (project.Favorites.Any())
                                            {
                                                <i class="fas fa-star text-warning ms-1"></i>
                                            }
                                        </strong>
                                        @if (ViewBag.PendingUpdates != null && ((HashSet<int>)ViewBag.PendingUpdates).Contains(project.Id))
                                        {
                                            <span class="badge bg-warning text-dark ms-1" title="Proposed updates are awaiting Admin approval.">
                                                <i class="fas fa-hourglass-half me-1"></i>Pending Edits
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(project.Description))
                                        {
                                            <br />
                                            <small class="text-muted">@project.Description.Substring(0, Math.Min(50, project.Description.Length))...</small>
                                        }
                                    </td>
                                    <td>
                                        @if (project.Owners.Any())
                                        {
                                            @foreach (var owner in project.Owners)
                                            {
                                                <span class="badge bg-secondary me-1">@owner.User?.FirstName @owner.User?.LastName</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">No owners</span>
                                        }
                                    </td>
                                    <td>@project.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@(project.EndDate?.ToString("dd MMM yyyy") ?? "Ongoing")</td>
                                    <td>
                                        <span class="badge @GetStatusClass(project.Status)">@project.Status</span>
                                    </td>
                                    <td>@project.CreatedByUser?.FirstName @project.CreatedByUser?.LastName</td>
                                    <td>
                                        <div class="action-buttons">
                                            <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-success" title="View Details">
                                                View
                                            </a>
                                            @{
                                                var currentUserId = Context.Session.GetInt32("UserId") ?? 1;
                                                var isOwner = project.Owners.Any(o => o.UserId == currentUserId);
                                                var canEdit = userRole == "Admin" || (isOwner && !isSuspended);
                                                var editTitle = canEdit ? "Edit" : (isOwner && isSuspended ? "Your project access has been suspended by an Admin." : "Only owner can edit");
                                            }
                                            @if (canEdit)
                                            {
                                                <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-info" title="@editTitle">
                                                    Edit
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="btn btn-sm btn-secondary disabled" style="opacity: 0.5; cursor: not-allowed;" title="@editTitle">
                                                    Edit
                                                </span>
                                            }
                                            <form asp-action="ToggleFavorite" asp-route-id="@project.Id" method="post" class="action-form">
                                                @Html.AntiForgeryToken()
                                                @if (userRole == "Admin")
                                                {
                                                    <button type="submit" class="btn btn-sm @(project.Favorites.Any() ? "btn-warning" : "btn-outline-warning")" title="@(project.Favorites.Any() ? "Remove Mark" : "Mark Project")">
                                                        <i class="@(project.Favorites.Any() ? "fas fa-star" : "far fa-star")"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" disabled class="btn btn-sm btn-secondary disabled" title="Only admin can mark favorite" style="opacity: 0.5; cursor: not-allowed;">
                                                        <i class="@(project.Favorites.Any() ? "fas fa-star" : "far fa-star")"></i>
                                                    </button>
                                                }
                                            </form>
                                            @if (canEdit)
                                            {
                                                <form asp-action="Delete" asp-route-id="@project.Id" method="post" class="action-form" onsubmit="return confirm('Are you sure you want to delete this project?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button type="button" disabled class="btn btn-sm btn-secondary disabled" style="opacity: 0.5; cursor: not-allowed;" title="@(isOwner && isSuspended ? "Your project access has been suspended by an Admin." : "Only owner can delete")">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center">
                    <i class="fas fa-inbox" style="font-size: 48px; color: #ccc;"></i>
                    <p class="text-muted mt-3">No projects found. <a asp-action="Create">Create one now</a></p>
                </div>
            }
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-light">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        @{
                            int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                            int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                        }

                        <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-filter="@currentFilter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@currentSort" asp-route-page="@(ViewBag.CurrentPage - 1)" aria-label="Previous">&lt;</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-filter="@currentFilter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@currentSort" asp-route-page="@i">@i</a>
                                </li>
                            }
                        }

                        @if (endPage < ViewBag.TotalPages)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-filter="@currentFilter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@currentSort" asp-route-page="@(ViewBag.CurrentPage + 1)" aria-label="Next">&gt;</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .text-secondary {
        color: #6c757d;
    }

    .text-primary {
        color: #0d6efd;
    }

    .text-danger {
        color: #dc3545;
    }

    .text-success {
        color: #198754;
    }

    .action-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
        width: 180px;
    }

    .action-buttons .btn,
    .action-form .btn {
        border: 1px solid currentColor;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        height: 32px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .action-buttons .btn-info,
    .action-form .btn-info {
        border-color: #0dcaf0;
        color: white;
        background-color: #0dcaf0;
    }

    .action-buttons .btn-success,
    .action-form .btn-success {
        border-color: #6ec96e;
        color: white;
        background-color: #6ec96e;
    }

    .action-buttons .btn-warning,
    .action-form .btn-warning {
        border-color: #ffc107;
        color: white;
    }

    .action-buttons .btn-outline-warning,
    .action-form .btn-outline-warning {
        border-color: #ffc107;
        color: white;
        background-color: #ffc107;
    }

    .action-buttons .btn-danger,
    .action-form .btn-danger {
        border-color: #dc3545;
    }

    .action-form {
        display: inline;
    }

    table th {
        white-space: nowrap;
    }
</style>

<script>
    // Handle favorite button with AJAX
    document.querySelectorAll('form[action*="ToggleFavorite"]').forEach(form => {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const button = form.querySelector('button[type="submit"]');
            if (!button) return;

            const isFilled = button.classList.contains('btn-warning');

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: new FormData(form)
                });

                if (response.ok) {
                    // Toggle button appearance
                    button.classList.toggle('btn-warning');
                    button.classList.toggle('btn-outline-warning');

                    const icon = button.querySelector('i');
                    icon.classList.toggle('fas');
                    icon.classList.toggle('far');

                    // Toggle star icon in project name
                    const row = form.closest('tr');
                    if (row) {
                        const projectNameElement = row.querySelector('td strong');
                        if (projectNameElement) {
                            const starIcon = projectNameElement.querySelector('.fa-star');
                            if (isFilled && starIcon) {
                                starIcon.remove();
                            } else if (!isFilled && !starIcon) {
                                const newStar = document.createElement('i');
                                newStar.className = 'fas fa-star text-warning ms-1';
                                projectNameElement.appendChild(newStar);
                            }
                        }
                    }
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
            }
        });
    });
</script>
