@model IEnumerable<WebApplication1.Models.Project>

@{
    ViewData["Title"] = "Project Tracker";
    var stats = (Dictionary<string, int>)ViewBag.Stats ?? new Dictionary<string, int>();
    
    string GetStatusClass(string status) => status switch
    {
        "Planning" => "bg-secondary",
        "InProgress" => "bg-primary",
        "OnHold" => "bg-danger text-white",
        "Completed" => "bg-success",
        _ => "bg-secondary"
    };

    string GetStatusTextClass(string status) => status switch
    {
        "Planning" => "text-secondary",
        "InProgress" => "text-primary",
        "OnHold" => "text-danger",
        "Completed" => "text-success",
        _ => "text-secondary"
    };
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4">Project Tracker</h1>
            <p class="text-muted">Track and manage all organization projects</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="fas fa-plus me-2"></i>Create New Project
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-4">
        <div class="col-lg-3 mb-3">
            <div class="card bg-light border-0">
                <div class="card-body text-center">
                    <h2 class="card-title text-dark">@(stats.ContainsKey("TotalProjects") ? stats["TotalProjects"] : 0)</h2>
                    <p class="card-text text-muted">Total Projects</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="card bg-secondary text-white border-0">
                <div class="card-body text-center">
                    <h2 class="card-title">@(stats.ContainsKey("PlanningProjects") ? stats["PlanningProjects"] : 0)</h2>
                    <p class="card-text">Planning Projects</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="card bg-primary text-white border-0">
                <div class="card-body text-center">
                    <h2 class="card-title">@(stats.ContainsKey("ActiveProjects") ? stats["ActiveProjects"] : 0)</h2>
                    <p class="card-text">Active Projects</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="card bg-danger text-white border-0">
                <div class="card-body text-center">
                    <h2 class="card-title">@(stats.ContainsKey("OnHoldProjects") ? stats["OnHoldProjects"] : 0)</h2>
                    <p class="card-text">On Hold Projects</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="card bg-warning text-white border-0">
                <div class="card-body text-center">
                    <h2 class="card-title">@(stats.ContainsKey("FavoriteProjects") ? stats["FavoriteProjects"] : 0)</h2>
                    <p class="card-text"><i class="fas fa-star me-1"></i>Favorite Projects</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 mb-3">
            <div class="card bg-success text-white border-0">
                <div class="card-body text-center">
                    <h2 class="card-title">@(stats.ContainsKey("CompletedProjects") ? stats["CompletedProjects"] : 0)</h2>
                    <p class="card-text">Completed Projects</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Sort & Filter Controls -->
    <div class="card mb-4 border-0 bg-light">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12">
                    <h6 class="text-dark fw-bold mb-3"><i class="fas fa-search me-2"></i>Search Projects</h6>
                    <input type="text" id="searchInput" class="form-control mb-3" placeholder="Type project name..." />
                </div>
                <div class="col-12">
                    <h6 class="text-dark fw-bold mb-3"><i class="fas fa-filter me-2"></i>Filter by Status</h6>
                    <div class="btn-group flex-wrap" role="group">
                        <button type="button" class="btn btn-sm btn-outline-secondary status-btn" data-status="planning">
                            <i class="fas fa-circle me-1"></i> Planning
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary status-btn" data-status="inprogress">
                            <i class="fas fa-spinner me-1"></i> In Progress
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary status-btn" data-status="onhold">
                            <i class="fas fa-pause-circle me-1"></i> On Hold
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary status-btn" data-status="completed">
                            <i class="fas fa-check-circle me-1"></i> Completed
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary status-btn" data-status="favorites">
                            <i class="fas fa-star me-1"></i> Star
                        </button>
                    </div>
                </div>
                <div class="col-12">
                    <h6 class="text-dark fw-bold mb-3"><i class="fas fa-sort me-2"></i>Sort by</h6>
                    <div class="btn-group flex-wrap" role="group">
                        <a href="@Url.Action("Index", new { sortBy = "latest", filter = ViewBag.CurrentFilter })"
                           class="btn btn-sm @(ViewBag.CurrentSort == "latest" || ViewBag.CurrentSort == null ? "btn-secondary" : "btn-outline-secondary")">
                            <i class="fas fa-clock me-1"></i> Latest
                        </a>
                        <a href="@Url.Action("Index", new { sortBy = "date_asc", filter = ViewBag.CurrentFilter })"
                           class="btn btn-sm @(ViewBag.CurrentSort == "date_asc" ? "btn-secondary" : "btn-outline-secondary")">
                            <i class="fas fa-arrow-up me-1"></i> Start Date (Old→New)
                        </a>
                        <a href="@Url.Action("Index", new { sortBy = "date_desc", filter = ViewBag.CurrentFilter })"
                           class="btn btn-sm @(ViewBag.CurrentSort == "date_desc" ? "btn-secondary" : "btn-outline-secondary")">
                            <i class="fas fa-arrow-down me-1"></i> Start Date (New→Old)
                        </a>
                        <a href="@Url.Action("Index", new { sortBy = "enddate_asc", filter = ViewBag.CurrentFilter })"
                           class="btn btn-sm @(ViewBag.CurrentSort == "enddate_asc" ? "btn-secondary" : "btn-outline-secondary")">
                            <i class="fas fa-arrow-up me-1"></i> End Date (Old→New)
                        </a>
                        <a href="@Url.Action("Index", new { sortBy = "enddate_desc", filter = ViewBag.CurrentFilter })"
                           class="btn btn-sm @(ViewBag.CurrentSort == "enddate_desc" ? "btn-secondary" : "btn-outline-secondary")">
                            <i class="fas fa-arrow-down me-1"></i> End Date (New→Old)
                        </a>
                        <a href="@Url.Action("Index", new { sortBy = "name_asc", filter = ViewBag.CurrentFilter })"
                           class="btn btn-sm @(ViewBag.CurrentSort == "name_asc" ? "btn-secondary" : "btn-outline-secondary")">
                            <i class="fas fa-sort-alpha-down me-1"></i> Name (A-Z)
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Table -->
    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">All Projects</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Project Name</th>
                                <th>Owners</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                                <th>Created By</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model)
                            {
                                <tr class="project-row">
                                    <td>
                                        <strong class="@GetStatusTextClass(project.Status)" data-project-name="@project.Name.ToLower()">
                                            @project.Name
                                            @if (project.Favorites.Any())
                                            {
                                                <i class="fas fa-star text-warning ms-1"></i>
                                            }
                                        </strong>
                                        @if (!string.IsNullOrEmpty(project.Description))
                                        {
                                            <br />
                                            <small class="text-muted">@project.Description.Substring(0, Math.Min(50, project.Description.Length))...</small>
                                        }
                                    </td>
                                    <td>
                                        @if (project.Owners.Any())
                                        {
                                            @foreach (var owner in project.Owners)
                                            {
                                                <span class="badge bg-secondary me-1">@owner.User?.FirstName @owner.User?.LastName</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">No owners</span>
                                        }
                                    </td>
                                    <td>@project.StartDate.ToString("MMM dd, yyyy")</td>
                                    <td>@(project.EndDate?.ToString("MMM dd, yyyy") ?? "Ongoing")</td>
                                    <td>
                                        <span class="badge @GetStatusClass(project.Status)">@project.Status</span>
                                    </td>
                                    <td>@project.CreatedByUser?.FirstName @project.CreatedByUser?.LastName</td>
                                    <td>
                                        <div class="action-buttons">
                                            <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-info" title="View Details">
                                                View
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-info" title="Edit">
                                                Edit
                                            </a>
                                            <form asp-action="ToggleFavorite" asp-route-id="@project.Id" method="post" class="action-form">
                                                <button type="submit" class="btn btn-sm @(project.Favorites.Any() ? "btn-warning" : "btn-outline-warning")" title="@(project.Favorites.Any() ? "Remove Mark" : "Mark Project")">
                                                    <i class="@(project.Favorites.Any() ? "fas fa-star" : "far fa-star")"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Delete" asp-route-id="@project.Id" method="post" class="action-form" onsubmit="return confirm('Are you sure you want to delete this project?');">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center">
                    <i class="fas fa-inbox" style="font-size: 48px; color: #ccc;"></i>
                    <p class="text-muted mt-3">No projects found. <a asp-action="Create">Create one now</a></p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .progress {
        background-color: #e9ecef;
    }

    .progress-bar {
        background-color: #0d6efd;
    }

    .text-secondary {
        color: #6c757d;
    }

    .text-primary {
        color: #0d6efd;
    }

    .text-danger {
        color: #dc3545;
    }

    .text-success {
        color: #198754;
    }

    .text-dark {
        color: #212529;
    }

    .action-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
        width: 180px;
    }

    .action-buttons .btn,
    .action-form .btn {
        border: 1px solid currentColor;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        height: 32px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .action-buttons .btn-info,
    .action-form .btn-info {
        border-color: #0dcaf0;
        color: white;
        background-color: #0dcaf0;
    }

    .action-buttons .btn-success,
    .action-form .btn-success {
        border-color: #198754;
    }

    .action-buttons .btn-warning,
    .action-form .btn-warning {
        border-color: #ffc107;
        color: white;
    }

    .action-buttons .btn-outline-warning,
    .action-form .btn-outline-warning {
        border-color: #ffc107;
        color: white;
        background-color: #ffc107;
    }

    .action-buttons .btn-danger,
    .action-form .btn-danger {
        border-color: #dc3545;
    }

    .action-form {
        display: inline;
    }

    table th {
        white-space: nowrap;
    }
</style>

<script>
    let selectedStatus = null;
    let includeFavorites = false;
    const searchInput = document.getElementById('searchInput');
    const statusButtons = document.querySelectorAll('.status-btn');

    statusButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            const status = this.getAttribute('data-status');

            if (status === 'favorites') {
                // Star can be toggled with other statuses
                if (includeFavorites) {
                    includeFavorites = false;
                    this.classList.remove('btn-secondary');
                    this.classList.add('btn-outline-secondary');
                } else {
                    includeFavorites = true;
                    this.classList.add('btn-secondary');
                    this.classList.remove('btn-outline-secondary');
                }
            } else {
                // Other statuses are single-select
                statusButtons.forEach(b => {
                    if (b.getAttribute('data-status') !== 'favorites') {
                        if (b === this) {
                            if (selectedStatus === status) {
                                selectedStatus = null;
                                b.classList.remove('btn-secondary');
                                b.classList.add('btn-outline-secondary');
                            } else {
                                selectedStatus = status;
                                b.classList.add('btn-secondary');
                                b.classList.remove('btn-outline-secondary');
                            }
                        } else {
                            b.classList.remove('btn-secondary');
                            b.classList.add('btn-outline-secondary');
                        }
                    }
                });
            }
            applyFilters();
        });
    });

    function applyFilters() {
        const searchValue = searchInput.value.toLowerCase();
        const rows = document.querySelectorAll('.project-row');

        rows.forEach(row => {
            const projectName = row.querySelector('[data-project-name]')?.getAttribute('data-project-name') || '';
            const isFavorite = row.querySelector('strong .fa-star') !== null;

            // Get status badge (it's in the Status column, after owners column)
            const statusCell = row.querySelectorAll('td')[4]; // Status is 5th column (0-indexed: 4)
            const statusBadgeElement = statusCell?.querySelector('.badge');
            const statusText = statusBadgeElement?.textContent.trim() || '';

            // Check if project matches search
            const matchesSearch = projectName.includes(searchValue);

            // Check if status matches
            let matchesStatus = true;
            if (selectedStatus) {
                const statusMap = {
                    'planning': 'Planning',
                    'inprogress': 'InProgress',
                    'onhold': 'OnHold',
                    'completed': 'Completed'
                };
                matchesStatus = statusText === statusMap[selectedStatus];
            }

            // Check if must include favorites
            let matchesFavorite = true;
            if (includeFavorites) {
                matchesFavorite = isFavorite;
            }

            row.style.display = (matchesSearch && matchesStatus && matchesFavorite) ? '' : 'none';
        });
    }

    searchInput.addEventListener('keyup', applyFilters);
</script>
