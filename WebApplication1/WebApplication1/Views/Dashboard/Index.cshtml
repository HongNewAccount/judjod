@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "Calendar";
    var monthProjects = (List<WebApplication1.Models.Project>?)ViewBag.MonthProjects ?? new List<WebApplication1.Models.Project>();
    var selectedYear = (int)ViewBag.SelectedYear;
    var selectedMonth = (int)ViewBag.SelectedMonth;
    var monthName = (string)ViewBag.MonthName;
    var startDate = (DateTime)ViewBag.StartDate;
    var endDate = (DateTime)ViewBag.EndDate;

    var daysInMonth = DateTime.DaysInMonth(selectedYear, selectedMonth);
    var firstDayOfMonth = new DateTime(selectedYear, selectedMonth, 1);
    var firstDayOfWeek = (int)firstDayOfMonth.DayOfWeek;

    var previousMonth = selectedMonth == 1 ? 12 : selectedMonth - 1;
    var previousYear = selectedMonth == 1 ? selectedYear - 1 : selectedYear;
    var nextMonth = selectedMonth == 12 ? 1 : selectedMonth + 1;
    var nextYear = selectedMonth == 12 ? selectedYear + 1 : selectedYear;

    var projectsByDay = new Dictionary<int, List<(int, string, string)>>();
    foreach (var proj in monthProjects)
    {
        if (proj.EndDate.HasValue)
        {
            var d = proj.EndDate.Value.Day;
            if (d >= 1 && d <= daysInMonth && proj.EndDate.Value.Month == selectedMonth && proj.EndDate.Value.Year == selectedYear)
            {
                if (!projectsByDay.ContainsKey(d)) projectsByDay[d] = new List<(int, string, string)>();
                projectsByDay[d].Add((proj.Id, proj.Name, proj.Status ?? "Planning"));
            }
        }
    }

    string GetStatusDot(string status) => status switch
    {
        "Completed" => "bg-success",
        "Late" => "bg-danger",
        "InProgress" => "bg-primary",
        _ => "bg-secondary"
    };
}

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-calendar-alt text-primary me-2"></i>Calendar</h1>
        <p class="page-subtitle">View project deadlines by month</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Index", "Dashboard", new { year = previousYear, month = previousMonth })" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-chevron-left me-1"></i>Previous
                    </a>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#datePickerModal">
                        <i class="fas fa-calendar me-1"></i>@monthName
                    </button>
                    <a href="@Url.Action("Index", "Dashboard", new { year = nextYear, month = nextMonth })" class="btn btn-outline-secondary btn-sm">
                        Next<i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <table class="table table-bordered calendar-table">
                <thead>
                    <tr class="table-light">
                        @foreach (var day in new[] { "Sun","Mon","Tue","Wed","Thu","Fri","Sat" })
                        {
                            <th class="calendar-header">@day</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        int dayCounter = 1;
                        for (int week = 0; week < 6; week++)
                        {
                            if (dayCounter > daysInMonth) break;
                            <tr>
                                @for (int dayOfWeek = 0; dayOfWeek < 7; dayOfWeek++)
                                {
                                    if (week == 0 && dayOfWeek < firstDayOfWeek)
                                    {
                                        <td class="calendar-day calendar-day-empty"></td>
                                    }
                                    else if (dayCounter <= daysInMonth)
                                    {
                                        var currentDate = new DateTime(selectedYear, selectedMonth, dayCounter);
                                        var isToday = currentDate.Date == DateTime.UtcNow.Date;
                                        var dayProjects = projectsByDay.ContainsKey(dayCounter) ? projectsByDay[dayCounter] : new List<(int, string, string)>();

                                        <td class="calendar-day @(isToday ? "calendar-day-today" : "")">
                                            <div class="calendar-day-number @(isToday ? "today-badge" : "")">@dayCounter</div>
                                            <div class="calendar-day-items">
                                                @foreach (var proj in dayProjects.Take(3))
                                                {
                                                    <span class="calendar-item calendar-project-link" title="@proj.Item2 — @proj.Item3"
                                                          data-id="@proj.Item1" data-name="@proj.Item2" data-status="@proj.Item3"
                                                          onclick="openDetailModal(this.dataset.id, this.dataset.name, this.dataset.status)" style="cursor:pointer;">
                                                        <span class="badge @GetStatusDot(proj.Item3) me-1" style="width:7px;height:7px;border-radius:50%;padding:0;display:inline-block;"></span>
                                                        @proj.Item2
                                                    </span>
                                                }
                                                @if (dayProjects.Count > 3)
                                                {
                                                    <div class="calendar-item-more">+@(dayProjects.Count - 3) more</div>
                                                }
                                            </div>
                                        </td>
                                        dayCounter++;
                                    }
                                    else
                                    {
                                        <td class="calendar-day calendar-day-empty"></td>
                                    }
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row mt-3 g-3">
        <div class="col-6">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-icon"><i class="fas fa-project-diagram"></i></div>
                <div>
                    <div class="stat-card-value">@monthProjects.Count</div>
                    <div class="stat-card-label">Deadlines This Month</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="stat-card stat-card-danger">
                <div class="stat-card-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div>
                    <div class="stat-card-value">@monthProjects.Count(p => p.Status == "Late")</div>
                    <div class="stat-card-label">Late This Month</div>
                </div>
            </div>
        </div>
    </div>

    @if (monthProjects.Any())
    {
        <div class="card mt-4 border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="fas fa-list me-2 text-primary"></i>Project Deadlines — @monthName</h6>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var p in monthProjects.OrderBy(x => x.EndDate))
                {
                    <span class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                          data-id="@p.Id" data-name="@p.Name" data-status="@p.Status"
                          onclick="openDetailModal(this.dataset.id, this.dataset.name, this.dataset.status)" style="cursor:pointer;">
                        <span>
                            <span class="badge me-2 @(p.Status switch { "Completed"=>"bg-success","Late"=>"bg-danger","InProgress"=>"bg-primary",_=>"bg-secondary" })">@p.Status</span>
                            @p.Name
                        </span>
                        <small class="text-muted">@p.EndDate?.ToString("dd MMM")</small>
                    </span>
                }
            </div>
        </div>
    }
</div>

<div class="modal fade" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <input type="text" id="taskDetailTitle" class="form-control form-control-sm fw-bold border-0 p-0"
                       style="font-size:1rem;box-shadow:none;" placeholder="Task name" />
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" style="max-height:70vh;overflow-y:auto;">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label small fw-semibold">Description</label>
                        <textarea id="taskDetailDesc" class="form-control" rows="2"
                                  placeholder="Add a description..."></textarea>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label small fw-semibold mb-0">Progress</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="range" id="taskDetailProgress" min="0" max="100" step="5" class="form-range flex-grow-1" />
                                <span class="badge text-bg-primary" id="taskDetailProgressValue">0%</span>
                            </div>
                        </div>
                        <textarea id="taskDetailProgressNote" class="form-control mt-2" rows="2"
                                  placeholder="Add progress note..."></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Progress Log</label>
                            <div id="taskDetailProgressLog" style="max-height:220px;overflow-y:auto;font-size:.8rem;">
                                <div class="text-muted">Loading...</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Activity Log</label>
                            <div id="taskDetailLog" style="max-height:220px;overflow-y:auto;font-size:.8rem;">
                                <div class="text-muted">Loading...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 px-3">
                <button type="button" class="btn btn-modal-action btn-sm" onclick="saveDetailModal()">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.task-log-entry {
    padding: .45rem .5rem;
    border-radius: .45rem;
    background: #f8f9fa;
    margin-bottom: .4rem;
}
.task-log-action {
    display: inline-block;
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #6c757d;
    margin-right: .25rem;
}
.task-log-desc {
    display: block;
    margin-top: .15rem;
    font-size: .8rem;
    color: #212529;
}
.task-log-meta {
    font-size: .72rem;
    color: #6c757d;
    margin-top: .2rem;
}
</style>

<div class="modal fade" id="datePickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Select Month and Year</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="get" action="@Url.Action("Index", "Dashboard")">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Year</label>
                            <select class="form-select" name="year" required>
                                @for (int y = DateTime.UtcNow.Year - 2; y <= DateTime.UtcNow.Year + 2; y++)
                                {
                                    <option value="@y" selected="@(y == selectedYear)">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Month</label>
                            <select class="form-select" name="month" required>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m" selected="@(m == selectedMonth)">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer mt-3 px-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Go to Month</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

let currentDetailId = null;
let currentDetailProgress = 0;

function syncProgressInputs(value) {
    const range = document.getElementById('taskDetailProgress');
    const badge = document.getElementById('taskDetailProgressValue');
    const parsed = Math.max(0, Math.min(100, Number(value) || 0));
    if (range) range.value = parsed;
    if (badge) badge.textContent = parsed + '%';
}

function renderLogEntries(entries, containerId, emptyText) {
    const container = document.getElementById(containerId);
    if (!container) return;
    if (!entries || entries.length === 0) {
        container.innerHTML = '<div class="text-muted small">' + emptyText + '</div>';
        return;
    }
    container.innerHTML = entries.map(l => {
        const detailText = l.description || '';
        const noteText = l.note || '';
        const mainText = detailText || noteText || '';
        return `
            <div class="task-log-entry">
                <span class="task-log-action">${l.actionType}</span>
                <span class="task-log-desc">${mainText}</span>
                ${noteText && detailText ? `<div class="text-muted small mt-1">${noteText}</div>` : ''}
                ${l.oldValue && l.newValue ? `<small class="text-muted ms-1">${l.oldValue} → ${l.newValue}</small>` : ''}
                <div class="task-log-meta">${l.userName} · ${l.createdAt}</div>
            </div>`;
    }).join('');
}

function openDetailModal(id, name, status) {
    currentDetailId = id;
    document.getElementById('taskDetailTitle').value = name;
    document.getElementById('taskDetailDesc').value = '';
    document.getElementById('taskDetailProgressNote').value = '';
    syncProgressInputs(0);
    document.getElementById('taskDetailProgressLog').innerHTML = '<div class="text-muted small">Loading...</div>';
    document.getElementById('taskDetailLog').innerHTML = '<div class="text-muted small">Loading...</div>';

    new bootstrap.Modal(document.getElementById('taskDetailModal')).show();

    fetch('/ProjectTracker/GetProjectDetails?id=' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            if (data.name) document.getElementById('taskDetailTitle').value = data.name;
            document.getElementById('taskDetailDesc').value = data.description || '';
            currentDetailProgress = data.progress ?? 0;
            syncProgressInputs(currentDetailProgress);
            renderLogEntries(data.progressLogs || [], 'taskDetailProgressLog', 'No progress updates yet');
            renderLogEntries(data.logs || [], 'taskDetailLog', 'No activity yet');
        })
        .catch(() => {
            document.getElementById('taskDetailLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
            document.getElementById('taskDetailProgressLog').innerHTML = '<div class="text-danger small">Failed to load</div>';
        });
}

async function saveDetailModal() {
    const name = document.getElementById('taskDetailTitle').value.trim();
    const desc = document.getElementById('taskDetailDesc').value;
    const progress = Number(document.getElementById('taskDetailProgress').value || 0);
    const note = document.getElementById('taskDetailProgressNote').value.trim();
    if (!name) return;

    const saveButton = document.querySelector('#taskDetailModal .btn-modal-action');
    if (saveButton) {
        saveButton.disabled = true;
        saveButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
    }

    try {
        const r1 = await fetch('/ProjectTracker/UpdateName', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, name, __RequestVerificationToken: token })
        });
        if (!r1.ok) throw new Error('UpdateName failed: ' + r1.status);

        const r2 = await fetch('/ProjectTracker/UpdateDescription', {
            method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: new URLSearchParams({ id: currentDetailId, description: desc, __RequestVerificationToken: token })
        });
        if (!r2.ok) throw new Error('UpdateDescription failed: ' + r2.status);

        let movedToCompleted = false;
        if (note || progress !== currentDetailProgress) {
            const r3 = await fetch('/ProjectTracker/UpdateProgress', {
                method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({ id: currentDetailId, progress, note, __RequestVerificationToken: token })
            });
            if (!r3.ok) throw new Error('UpdateProgress failed: ' + r3.status);
            const r3data = await r3.json().catch(() => ({}));
            movedToCompleted = r3data.movedToCompleted === true;
        }

        if (movedToCompleted) { location.reload(); return; }

        (bootstrap.Modal.getInstance(document.getElementById('taskDetailModal')) || new bootstrap.Modal(document.getElementById('taskDetailModal'))).hide();
    } catch (e) {
        console.error(e);
        alert('Unable to save changes. Please try again.');
    } finally {
        if (saveButton) {
            saveButton.disabled = false;
            saveButton.innerHTML = '<i class="fas fa-save me-1"></i>Save';
        }
    }
}

document.getElementById('taskDetailProgress').addEventListener('input', function () {
    syncProgressInputs(this.value);
});
</script>
}
