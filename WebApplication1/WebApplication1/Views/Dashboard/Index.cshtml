@{
    ViewData["Title"] = "Calendar";
    var monthProjects = (List<WebApplication1.Models.Project>?)ViewBag.MonthProjects ?? new List<WebApplication1.Models.Project>();
    var selectedYear = (int)ViewBag.SelectedYear;
    var selectedMonth = (int)ViewBag.SelectedMonth;
    var monthName = (string)ViewBag.MonthName;
    var startDate = (DateTime)ViewBag.StartDate;
    var endDate = (DateTime)ViewBag.EndDate;
    var events = (List<WebApplication1.Models.OrganizationEvent>)ViewBag.Events;

    var daysInMonth = DateTime.DaysInMonth(selectedYear, selectedMonth);
    var firstDayOfMonth = new DateTime(selectedYear, selectedMonth, 1);
    var firstDayOfWeek = (int)firstDayOfMonth.DayOfWeek;

    var previousMonth = selectedMonth == 1 ? 12 : selectedMonth - 1;
    var previousYear = selectedMonth == 1 ? selectedYear - 1 : selectedYear;
    var nextMonth = selectedMonth == 12 ? 1 : selectedMonth + 1;
    var nextYear = selectedMonth == 12 ? selectedYear + 1 : selectedYear;

    var eventsByDay = new Dictionary<int, List<(int Id, string Title)>>();
    var projectsByDay = new Dictionary<int, List<(int Id, string Name)>>();

    // Map events to days
    foreach (var evt in events)
    {
        for (var d = 1; d <= daysInMonth; d++)
        {
            var dateToCheck = new DateTime(selectedYear, selectedMonth, d);
            if ((evt.EventDate.Date == dateToCheck ||
                 (evt.EventEndDate.HasValue && evt.EventEndDate.Value.Date >= dateToCheck && evt.EventDate.Date <= dateToCheck)))
            {
                if (!eventsByDay.ContainsKey(d))
                    eventsByDay[d] = new List<(int, string)>();
                eventsByDay[d].Add((evt.Id, evt.Title));
            }
        }
    }

    // Map projects (end dates) to days
    foreach (var proj in monthProjects)
    {
        if (proj.EndDate.HasValue)
        {
            var projDay = proj.EndDate.Value.Day;
            if (projDay >= 1 && projDay <= daysInMonth && proj.EndDate.Value.Month == selectedMonth && proj.EndDate.Value.Year == selectedYear)
            {
                if (!projectsByDay.ContainsKey(projDay))
                    projectsByDay[projDay] = new List<(int, string)>();
                projectsByDay[projDay].Add((proj.Id, proj.Name));
            }
        }
    }
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h2 class="h3 mb-1 text-gray-800">
            <i class="fas fa-calendar-alt text-primary me-2"></i>Calendar
        </h2>
        <p class="text-muted mb-0">View events and project deadlines</p>
    </div>

    <!-- Dashboard Summary -->
    <div class="row mb-4 g-3">
        @{
            var monthProjectCount = monthProjects.Count;
            var monthEventCount = events.Count;
        }

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small mb-1">Project Deadlines</p>
                            <h3 class="mb-0 text-primary">@monthProjectCount</h3>
                        </div>
                        <i class="fas fa-project-diagram fa-2x text-primary opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small mb-1">Events</p>
                            <h3 class="mb-0 text-info">@monthEventCount</h3>
                        </div>
                        <i class="fas fa-calendar fa-2x text-info opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Event Calendar -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Index", "Dashboard", new { year = previousYear, month = previousMonth })" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-chevron-left me-1"></i>Previous
                    </a>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#datePickerModal">
                        <i class="fas fa-calendar me-1"></i>@monthName
                    </button>
                    <a href="@Url.Action("Index", "Dashboard", new { year = nextYear, month = nextMonth })" class="btn btn-outline-secondary btn-sm">
                        Next<i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <table class="table table-bordered calendar-table">
                <thead>
                    <tr class="table-light">
                        <th class="calendar-header">Sun</th>
                        <th class="calendar-header">Mon</th>
                        <th class="calendar-header">Tue</th>
                        <th class="calendar-header">Wed</th>
                        <th class="calendar-header">Thu</th>
                        <th class="calendar-header">Fri</th>
                        <th class="calendar-header">Sat</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int dayCounter = 1;
                        for (int week = 0; week < 6; week++)
                        {
                            <tr>
                                @for (int dayOfWeek = 0; dayOfWeek < 7; dayOfWeek++)
                                {
                                    if (week == 0 && dayOfWeek < firstDayOfWeek)
                                    {
                                        <td class="calendar-day calendar-day-empty"></td>
                                    }
                                    else if (dayCounter <= daysInMonth)
                                    {
                                        var currentDate = new DateTime(selectedYear, selectedMonth, dayCounter);
                                        var isToday = currentDate.Date == DateTime.UtcNow.Date;
                                        var dayItemEvents = eventsByDay.ContainsKey(dayCounter) ? eventsByDay[dayCounter] : new List<(int, string)>();
                                        var dayItemProjects = projectsByDay.ContainsKey(dayCounter) ? projectsByDay[dayCounter] : new List<(int, string)>();

                                        <td class="calendar-day @(isToday ? "calendar-day-today" : "")">
                                            <div class="calendar-day-number @(isToday ? "today-badge" : "")">@dayCounter</div>
                                            <div class="calendar-day-items">
                                                @foreach (var evt in dayItemEvents.Take(2))
                                                {
                                                    <a href="@Url.Action("Details", "Event", new { id = evt.Item1 })" class="calendar-item calendar-event-link" title="@evt.Item2">
                                                        <i class="fas fa-calendar-day"></i> @evt.Item2
                                                    </a>
                                                }
                                                @foreach (var proj in dayItemProjects.Take(2 - dayItemEvents.Count))
                                                {
                                                    <a href="@Url.Action("Details", "ProjectTracker", new { id = proj.Item1 })" class="calendar-item calendar-project-link" title="@proj.Item2">
                                                        <i class="fas fa-flag"></i> @proj.Item2
                                                    </a>
                                                }
                                                @if (dayItemEvents.Count + dayItemProjects.Count > 2)
                                                {
                                                    <div class="calendar-item-more">+@(dayItemEvents.Count + dayItemProjects.Count - 2) more</div>
                                                }
                                            </div>
                                        </td>
                                        dayCounter++;
                                    }
                                    else
                                    {
                                        <td class="calendar-day calendar-day-empty"></td>
                                    }
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Date Picker Modal -->
<div class="modal fade" id="datePickerModal" tabindex="-1" aria-labelledby="datePickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="datePickerModalLabel">Select Month and Year</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="get" action="@Url.Action("Index", "Dashboard")">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="yearSelect" class="form-label">Year</label>
                            <select class="form-select" id="yearSelect" name="year" required>
                                @{
                                    for (int y = DateTime.UtcNow.Year - 2; y <= DateTime.UtcNow.Year + 2; y++)
                                    {
                                        var isSelected = y == selectedYear;
                                        <option value="@y" selected="@isSelected">@y</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="monthSelect" class="form-label">Month</label>
                            <select class="form-select" id="monthSelect" name="month" required>
                                @{
                                    for (int m = 1; m <= 12; m++)
                                    {
                                        var isSelected = m == selectedMonth;
                                        var displayMonth = DateTime.UtcNow.AddMonths(m - DateTime.UtcNow.Month).ToString("MMMM");
                                        <option value="@m" selected="@isSelected">@displayMonth</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer mt-4">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Go to Month</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .calendar-table {
        table-layout: fixed;
        border-collapse: collapse;
    }

    .calendar-table tbody td {
        border: 1px solid #dee2e6 !important;
    }

    .calendar-header {
        background-color: #f8f9fa !important;
        padding: 12px 8px !important;
        font-weight: 600;
        text-align: center;
        color: #495057;
        font-size: 0.875rem;
        border-bottom: 2px solid #dee2e6 !important;
    }

    .calendar-day {
        background-color: white;
        min-height: 120px;
        padding: 8px;
        position: relative;
        overflow-y: auto;
        vertical-align: top;
    }

    .calendar-day-empty {
        background-color: #f8f9fa;
    }

    .calendar-day-today {
        background-color: #e7f3ff;
    }

    .calendar-day-number {
        font-weight: 600;
        font-size: 0.95rem;
        color: #495057;
        margin-bottom: 6px;
    }

    .calendar-day-number.today-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: #0d6efd;
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-size: 0.875rem;
    }

    .calendar-day-items {
        display: flex;
        flex-direction: column;
        gap: 3px;
        font-size: 0.75rem;
    }

    .calendar-item {
        display: block;
        padding: 3px 6px;
        background-color: #e3f2fd;
        color: #1976d2;
        border-radius: 3px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        font-size: 0.75rem;
    }

    .calendar-item:hover {
        background-color: #1976d2;
        color: white;
        text-decoration: none;
    }

    .calendar-event-link {
        background-color: #e3f2fd;
        color: #1976d2;
    }

    .calendar-event-link:hover {
        background-color: #1976d2;
        color: white;
    }

    .calendar-project-link {
        background-color: #fff3cd;
        color: #856404;
    }

    .calendar-project-link:hover {
        background-color: #856404;
        color: white;
    }

    .calendar-item-more {
        padding: 2px 6px;
        color: #6c757d;
        font-size: 0.7rem;
        font-weight: 500;
    }

    @@media (max-width: 768px) {
        .calendar-day {
            min-height: 80px;
            font-size: 0.85rem;
            padding: 4px;
        }

        .calendar-day-number {
            font-size: 0.85rem;
        }

        .calendar-item {
            font-size: 0.65rem;
            padding: 1px 3px;
        }
    }
</style>
