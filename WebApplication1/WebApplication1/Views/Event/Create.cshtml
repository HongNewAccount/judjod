@model WebApplication1.Models.OrganizationEvent

@{
    ViewData["Title"] = "Create Event";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4">Create New Event</h1>

            <form method="post" asp-action="Create" class="needs-validation" novalidate>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                }

                <div class="mb-3">
                    <label for="title" class="form-label">Event Title *</label>
                    <input type="text" class="form-control" id="title" asp-for="Title" required />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description *</label>
                    <textarea class="form-control" id="description" asp-for="Description" rows="4" required></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="eventDate" class="form-label">Start Date & Time *</label>
                        <input type="datetime-local" class="form-control" id="eventDate" asp-for="EventDate" required />
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="eventEndDate" class="form-label">End Date & Time</label>
                        <input type="datetime-local" class="form-control" id="eventEndDate" asp-for="EventEndDate" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="location" class="form-label">Location *</label>
                    <input type="text" class="form-control" id="location" asp-for="Location" placeholder="e.g., Conference Room A, Building 2" required />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="isOnSite" asp-for="IsOnSite" checked />
                    <label class="form-check-label" for="isOnSite">
                        On-site location
                    </label>
                </div>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Create Event</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
