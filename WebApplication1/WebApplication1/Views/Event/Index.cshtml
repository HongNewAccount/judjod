@model IEnumerable<WebApplication1.Models.OrganizationEvent>

@{
    ViewData["Title"] = "Events";
    var stats = (Dictionary<string, int>)ViewBag.Stats ?? new Dictionary<string, int>();
    var searchTerm = ViewBag.SearchTerm ?? "";
    var sortBy = ViewBag.SortBy ?? "latest";
    var filter = ViewBag.FilterType ?? "all";
}

<div class="container-fluid">
    <div class="row mb-4 page-header">
        <div class="col">
            <h1 class="page-title">Organization Events</h1>
            <p class="page-subtitle">All company events and activities</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-action">
                <i class="fas fa-plus me-2"></i>Create New Event
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-4">
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-total">
                <div class="stat-card-icon"><i class="fas fa-calendar-day"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("TotalEvents", 0)</div>
                    <div class="stat-card-label">Total Events</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-icon"><i class="fas fa-arrow-circle-up"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("UpcomingEvents", 0)</div>
                    <div class="stat-card-label">Upcoming</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-secondary">
                <div class="stat-card-icon"><i class="fas fa-history"></i></div>
                <div>
                    <div class="stat-card-value">@stats.GetValueOrDefault("PastEvents", 0)</div>
                    <div class="stat-card-label">Past Events</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 mb-3">
            <div class="stat-card stat-card-info">
                <div class="stat-card-icon"><i class="fas fa-calendar"></i></div>
                <div>
                    <div class="stat-card-value">@ViewBag.TotalCount</div>
                    <div class="stat-card-label">Matching Events</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search, Filter & Sort -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search events..." value="@searchTerm" />
                </div>
                <div class="col-md-3">
                    <select name="filter" class="form-select">
                        <option value="all" selected="@(filter == "all")">All</option>
                        <option value="upcoming" selected="@(filter == "upcoming")">Upcoming</option>
                        <option value="past" selected="@(filter == "past")">Past</option>
                        <option value="thismonth" selected="@(filter == "thismonth")">This Month</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="latest" selected="@(sortBy == "latest")">Latest First</option>
                        <option value="oldest" selected="@(sortBy == "oldest")">Oldest First</option>
                        <option value="title-asc" selected="@(sortBy == "title-asc")">Title (A-Z)</option>
                        <option value="title-desc" selected="@(sortBy == "title-desc")">Title (Z-A)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-action w-100">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var evt in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@evt.Title</h5>
                            <p class="card-text text-muted">@evt.Description?.Substring(0, Math.Min(100, evt.Description?.Length ?? 0))...</p>

                            <div class="mb-3">
                                <small><strong>Date:</strong></small>
                                <br />
                                <small>@evt.EventDate.ToString("MMM dd, yyyy HH:mm")</small>
                                @if (evt.EventEndDate.HasValue)
                                {
                                    <br />
                                    <small>to @evt.EventEndDate.Value.ToString("HH:mm")</small>
                                }
                            </div>

                            <div class="mb-3">
                                <small><strong>Location:</strong></small>
                                <br />
                                <small>@evt.Location @(evt.IsOnSite ? "(On-site)" : "(Off-site)")</small>
                            </div>

                            <div>
                                <small><strong>Attendees:</strong></small>
                                <br />
                                <small>@evt.Attendees.Count person(s)</small>
                            </div>
                        </div>
                        <div class="card-footer bg-light">
                            <a asp-action="Details" asp-route-id="@evt.Id" class="btn btn-sm btn-info">View Details</a>
                            <a asp-action="Edit" asp-route-id="@evt.Id" class="btn btn-sm btn-warning">Edit</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    @{
                        int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                    }

                    <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-filter="@filter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@sortBy" asp-route-page="@(ViewBag.CurrentPage - 1)" aria-label="Previous">&lt;</a>
                    </li>

                    @if (startPage > 1)
                    {
                        <li class="page-item"><span class="page-link">...</span></li>
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        if (i == ViewBag.CurrentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-route-filter="@filter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@sortBy" asp-route-page="@i">@i</a>
                            </li>
                        }
                    }

                    @if (endPage < ViewBag.TotalPages)
                    {
                        <li class="page-item"><span class="page-link">...</span></li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-filter="@filter" asp-route-searchTerm="@searchTerm" asp-route-sortBy="@sortBy" asp-route-page="@(ViewBag.CurrentPage + 1)" aria-label="Next">&gt;</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No events found. <a asp-action="Create" class="alert-link">Create one now</a>
        </div>
    }
</div>
