@model WebApplication1.Models.OrganizationEvent

@{
    ViewData["Title"] = "Event Details";

    string GetAttendanceClass(string status) => status switch
    {
        "Attending" => "bg-success",
        "NotAttending" => "bg-danger",
        "Maybe" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1>@Model.Title</h1>
            <p class="text-muted">Created by @Model.CreatedByUser?.FirstName @Model.CreatedByUser?.LastName on @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
        </div>
        <div class="col-auto">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Event Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Description:</strong></p>
                    <p>@Model.Description</p>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Start Date & Time:</strong> <br /> @Model.EventDate.ToString("dddd, MMM dd, yyyy HH:mm")</p>
                            @if (Model.EventEndDate.HasValue)
                            {
                                <p><strong>End Date & Time:</strong> <br /> @Model.EventEndDate.Value.ToString("dddd, MMM dd, yyyy HH:mm")</p>
                            }
                        </div>
                        <div class="col-md-6">
                            <p><strong>Location:</strong> <br /> @Model.Location</p>
                            <p><strong>Type:</strong> <br /> @(Model.IsOnSite ? "On-site" : "Off-site")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Attendees (@Model.Attendees.Count)</h5>
                </div>
                <div class="card-body">
                    @if (Model.Attendees.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var attendee in Model.Attendees)
                            {
                                <div class="list-group-item">
                                    <strong>@attendee.User?.FirstName @attendee.User?.LastName</strong>
                                    <br />
                                    <small class="text-muted">
                                        Status: <span class="badge @GetAttendanceClass(attendee.AttendanceStatus)">@attendee.AttendanceStatus</span>
                                    </small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No attendees yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
