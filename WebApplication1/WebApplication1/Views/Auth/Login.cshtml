@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutAuth";
}

<div class="login-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <script src="https://unpkg.com/@@lottiefiles/lottie-player@@latest/dist/lottie-player.js"></script>
    <lottie-player src="/uploads/pic/Car2.json"
                   background="transparent" speed="1" loop autoplay
                   style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:100vmax;height:100vmax;z-index:1;pointer-events:none;"></lottie-player>

    <div class="login-wrap">


        <div class="glass-card">
            <div class="text-center mb-4">
                <div class="glass-logo mx-auto mb-3">
                    <img src="/uploads/pic/logo.jpg" alt="Logo"
                         style="width:72px;height:72px;object-fit:contain;border-radius:16px;" />
                </div>
                <h4 class="fw-bold mb-0" style="color:#1a1a2e;letter-spacing:2px;">JUDJOD</h4>
                <p style="color:#888;font-size:.8rem;margin-top:2px;">Project Tracking</p>
            </div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
            {
                <div class="alert py-2 small mb-3"
                     style="background:rgba(220,53,69,.08);border:1px solid rgba(220,53,69,.25);color:#dc3545;border-radius:12px;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="fas fa-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" asp-controller="Auth" asp-action="Login" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <div class="glass-input-wrap">
                        <i class="fas fa-user glass-input-icon"></i>
                        <input type="text" name="username" class="glass-input"
                               placeholder="Username" required autocomplete="off" />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="glass-input-wrap">
                        <i class="fas fa-lock glass-input-icon"></i>
                        <input type="password" name="password" id="loginPwd" class="glass-input"
                               placeholder="Password" required autocomplete="new-password" />
                        <button type="button" class="glass-eye-btn" onclick="togglePwd()" tabindex="-1">
                            <i class="fas fa-eye-slash" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="glass-submit w-100">
                    Sign In &nbsp;<i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <p class="text-center mt-4" style="color:#aaa;font-size:.75rem;">
                <i class="fas fa-shield-alt me-1"></i>Contact the admin to create an account
            </p>
        </div>
    </div>
</div>

<style>
* { box-sizing: border-box; }

.login-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fef6ec 0%, #f8f4ff 50%, #eef4ff 100%);
    position: relative;
    overflow: hidden;
    padding: 1rem;
}

.blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: .4;
    animation: floatBlob 9s ease-in-out infinite;
}
.blob-1 { width:380px;height:380px;background:#fd7e14;top:-100px;left:-80px;animation-delay:0s; }
.blob-2 { width:300px;height:300px;background:#a78bfa;bottom:-80px;right:-60px;animation-delay:3s; }
.blob-3 { width:220px;height:220px;background:#60a5fa;top:55%;left:60%;animation-delay:5.5s; }

@@keyframes floatBlob {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-24px) scale(1.04); }
}

.login-wrap {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 3rem;
}

.login-lottie {
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.glass-card {
    width: 100%;
    max-width: 400px;
    background: rgba(255,255,255,.65);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,.85);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 0 8px 32px rgba(100,80,200,.1), 0 2px 8px rgba(0,0,0,.06);
}

.glass-logo {
    width: 80px; height: 80px;
    border-radius: 20px;
    background: rgba(255,255,255,.9);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(253,126,20,.2);
}

.glass-input-wrap {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,.75);
    border: 1.5px solid rgba(200,200,220,.45);
    border-radius: 12px;
    padding: 0 1rem;
    height: 3rem;
    overflow: hidden;
    transition: border-color .2s, box-shadow .2s;
}
.glass-input-wrap:focus-within {
    border-color: #fd7e14;
    box-shadow: 0 0 0 3px rgba(253,126,20,.12);
    background: rgba(255,255,255,.95);
}
.glass-input-icon { color:#ccc;width:18px;flex-shrink:0;margin-right:.65rem;font-size:.85rem; }
.glass-input { flex:1;background:transparent;border:none;outline:none;color:#1a1a2e;font-size:.95rem; }
#loginPwd::-ms-reveal,
#loginPwd::-ms-clear { display:none !important; }
.glass-input::placeholder { color:#ccc; }

.glass-eye-btn { background:transparent;border:none;color:#ccc;cursor:pointer;padding:0;line-height:1;font-size:.85rem; }
.glass-eye-btn:hover { color:#999; }

.glass-submit {
    background: linear-gradient(135deg, #fd7e14, #e85d00);
    color: #fff;
    border: none;
    border-radius: 12px;
    padding: .75rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity .2s, transform .15s;
    box-shadow: 0 4px 16px rgba(253,126,20,.3);
}
.glass-submit:hover { opacity:.9; transform:translateY(-1px); }
.glass-submit:active { transform:translateY(0); }
</style>

@section Scripts {
<script>
function togglePwd() {
    const inp = document.getElementById('loginPwd');
    const ico = document.getElementById('eyeIcon');
    if (inp.type === 'password') {
        inp.type = 'text';
        ico.classList.replace('fa-eye-slash', 'fa-eye');
    } else {
        inp.type = 'password';
        ico.classList.replace('fa-eye', 'fa-eye-slash');
    }
}

function clearForm() {
    document.querySelector('input[name="username"]').value = '';
    document.getElementById('loginPwd').value = '';
}
window.addEventListener('load', clearForm);
window.addEventListener('pageshow', clearForm);
</script>
}
