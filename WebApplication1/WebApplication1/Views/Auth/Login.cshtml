@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutAuth";
}

<div class="login-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="glass-card">
        <div class="text-center mb-4">
            <div class="glass-logo mx-auto mb-3">
                <i class="fas fa-square-parking"></i>
            </div>
            <h4 class="fw-bold mb-0" style="color:#fff;letter-spacing:2px;">JUDJOD</h4>
            <p style="color:rgba(255,255,255,.6);font-size:.8rem;margin-top:2px;">จุดจอด · Parking Management</p>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
        {
            <div class="alert py-2 small mb-3" style="background:rgba(220,53,69,.25);border:1px solid rgba(220,53,69,.4);color:#fff;border-radius:10px;">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="fas fa-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" asp-controller="Auth" asp-action="Login">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <div class="glass-input-wrap">
                    <i class="fas fa-user glass-input-icon"></i>
                    <input type="text" name="username" class="glass-input"
                           placeholder="Username" required autocomplete="username" />
                </div>
            </div>

            <div class="mb-4">
                <div class="glass-input-wrap">
                    <i class="fas fa-lock glass-input-icon"></i>
                    <input type="password" name="password" id="loginPwd" class="glass-input"
                           placeholder="Password" required autocomplete="current-password" />
                    <button type="button" class="glass-eye-btn" onclick="togglePwd()" tabindex="-1">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="glass-submit w-100">
                Sign In &nbsp;<i class="fas fa-arrow-right"></i>
            </button>
        </form>

        <p class="text-center mt-4" style="color:rgba(255,255,255,.45);font-size:.75rem;">
            <i class="fas fa-shield-alt me-1"></i>Contact your administrator for access
        </p>
    </div>
</div>

<style>
* { box-sizing: border-box; }

.login-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
    position: relative;
    overflow: hidden;
    padding: 1rem;
}

.blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: .55;
    animation: float 8s ease-in-out infinite;
}
.blob-1 {
    width: 400px; height: 400px;
    background: #fd7e14;
    top: -120px; left: -100px;
    animation-delay: 0s;
}
.blob-2 {
    width: 350px; height: 350px;
    background: #6610f2;
    bottom: -100px; right: -80px;
    animation-delay: 3s;
}
.blob-3 {
    width: 250px; height: 250px;
    background: #0d6efd;
    top: 50%; left: 55%;
    animation-delay: 5s;
}
@@keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-30px) scale(1.05); }
}

.glass-card {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 400px;
    background: rgba(255,255,255,.10);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.20);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 0 8px 40px rgba(0,0,0,.4);
}

.glass-logo {
    width: 72px; height: 72px;
    border-radius: 18px;
    background: linear-gradient(135deg, #fd7e14, #e85d00);
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; color: #fff;
    box-shadow: 0 4px 20px rgba(253,126,20,.5);
}

.glass-input-wrap {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 12px;
    padding: .65rem 1rem;
    transition: border-color .2s, background .2s;
}
.glass-input-wrap:focus-within {
    background: rgba(255,255,255,.18);
    border-color: rgba(253,126,20,.7);
    box-shadow: 0 0 0 3px rgba(253,126,20,.15);
}
.glass-input-icon {
    color: rgba(255,255,255,.5);
    width: 18px;
    flex-shrink: 0;
    margin-right: .65rem;
    font-size: .85rem;
}
.glass-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-size: .95rem;
}
.glass-input::placeholder { color: rgba(255,255,255,.4); }

.glass-eye-btn {
    background: transparent;
    border: none;
    color: rgba(255,255,255,.45);
    cursor: pointer;
    padding: 0;
    line-height: 1;
    font-size: .85rem;
}
.glass-eye-btn:hover { color: rgba(255,255,255,.8); }

.glass-submit {
    background: linear-gradient(135deg, #fd7e14, #e85d00);
    color: #fff;
    border: none;
    border-radius: 12px;
    padding: .75rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .5px;
    cursor: pointer;
    transition: opacity .2s, transform .15s;
    box-shadow: 0 4px 16px rgba(253,126,20,.4);
}
.glass-submit:hover { opacity: .9; transform: translateY(-1px); }
.glass-submit:active { transform: translateY(0); }
</style>

@section Scripts {
<script>
function togglePwd() {
    const inp = document.getElementById('loginPwd');
    const ico = document.getElementById('eyeIcon');
    if (inp.type === 'password') {
        inp.type = 'text';
        ico.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        inp.type = 'password';
        ico.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
}
