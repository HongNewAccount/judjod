@{
    ViewData["Title"] = "Create User";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="fas fa-user-plus me-2"></i>Create New User</h6>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show small py-2" role="alert">
                            @ViewBag.ErrorMessage
                            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success small py-2">@TempData["SuccessMessage"]</div>
                    }

                    <form method="post" asp-action="Register">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <input type="text" name="username" class="form-control" placeholder="Enter username" required autocomplete="username" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                            <input type="password" name="password" class="form-control" placeholder="Enter password" required autocomplete="new-password" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Confirm Password <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter password" required autocomplete="new-password" />
                        </div>

                        <div class="mb-4 p-3 bg-light rounded">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="canEdit" id="canEditCheck" value="true" />
                                <label class="form-check-label fw-semibold" for="canEditCheck">
                                    Can Edit
                                </label>
                                <div class="form-text mt-1">
                                    ✅ Checked = <strong>Admin</strong> — can create, edit, delete tasks<br />
                                    ☑ Unchecked = <strong>Viewer</strong> — read-only access
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="@Url.Action("Index", "User")" class="btn btn-secondary btn-sm flex-fill">Cancel</a>
                            <button type="submit" class="btn btn-modal-action btn-sm flex-fill">
                                <i class="fas fa-user-check me-1"></i>Create User
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
