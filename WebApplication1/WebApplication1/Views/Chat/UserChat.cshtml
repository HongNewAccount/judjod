@using WebApplication1.Models
@model IEnumerable<ChatMessage>
@{
    ViewData["Title"] = "Chat with Admin";
    var messages = Model.ToList();
    var lastId   = messages.Any() ? messages.Last().Id : 0;
    var myUserId = (int)ViewBag.CurrentUserId;
}
@Html.AntiForgeryToken()

<div class="container-fluid d-flex flex-column" style="height:calc(100vh - 130px);">
    <div class="page-header mb-3 flex-shrink-0">
        <h1 class="page-title mb-0"><i class="fas fa-comments me-2" style="color:var(--color-accent);"></i>Chat with Admin</h1>
    </div>

    <div id="chatBox" class="flex-1 overflow-y-auto p-3 rounded mb-3"
         style="background:#f8f9fa;border:1px solid #e9ecef;min-height:0;">
        @if (!messages.Any())
        {
            <p class="text-center text-muted small mt-4">No messages yet. Say hi to admin!</p>
        }
        @foreach (var m in messages)
        {
            <div class="d-flex @(!m.IsFromAdmin ? "justify-content-end" : "justify-content-start") mb-2">
                <div class="chat-bubble @(!m.IsFromAdmin ? "chat-bubble-me" : "chat-bubble-admin")">
                    <div>@m.Content</div>
                    <small class="chat-time">@m.CreatedAt.ToString("HH:mm")</small>
                </div>
            </div>
        }
    </div>

    <div class="d-flex gap-2 flex-shrink-0">
        <input type="text" id="msgInput" class="form-control" placeholder="Type a message..." />
        <button class="btn btn-modal-action px-4" onclick="sendMsg()">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

<style>
.chat-bubble { max-width:70%;padding:.55rem .85rem;border-radius:16px;font-size:.9rem; }
.chat-bubble-me    { background:var(--color-accent);color:#fff;border-bottom-right-radius:4px; }
.chat-bubble-admin { background:#fff;color:#1a1a2e;border:1px solid #e9ecef;border-bottom-left-radius:4px; }
.chat-time { display:block;font-size:.7rem;opacity:.65;margin-top:2px;text-align:right; }
</style>

@section Scripts {
<script>
const token  = document.querySelector('input[name="__RequestVerificationToken"]').value;
const userId = @myUserId;
let   lastId = @lastId;

function scrollBottom() {
    const box = document.getElementById('chatBox');
    box.scrollTop = box.scrollHeight;
}
scrollBottom();

async function sendMsg() {
    const input = document.getElementById('msgInput');
    const text  = input.value.trim();
    if (!text) return;
    input.value = '';
    const res = await fetch('/Chat/Send', {
        method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'},
        body: new URLSearchParams({ userId, content: text, isFromAdmin: 'false', __RequestVerificationToken: token })
    });
    if (res.ok) {
        const m = await res.json();
        appendMsg(m);
        lastId = m.id;
    }
}

function appendMsg(m) {
    const box  = document.getElementById('chatBox');
    const isMine = !m.isFromAdmin;
    const side = isMine ? 'end' : 'start';
    const cls  = isMine ? 'chat-bubble-me' : 'chat-bubble-admin';
    box.insertAdjacentHTML('beforeend',
        `<div class="d-flex justify-content-${side} mb-2">
           <div class="chat-bubble ${cls}">
             <div>${m.content}</div>
             <small class="chat-time">${m.createdAt}</small>
           </div>
         </div>`);
    box.scrollTop = box.scrollHeight;
}

document.getElementById('msgInput').addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });

setInterval(async () => {
    const res = await fetch(`/Chat/Poll?userId=${userId}&afterId=${lastId}`, { headers:{'X-Requested-With':'XMLHttpRequest'} });
    if (!res.ok) return;
    const msgs = await res.json();
    msgs.forEach(m => { appendMsg(m); lastId = m.id; });
}, 3000);
</script>
}
