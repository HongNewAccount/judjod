@using WebApplication1.Models
@model IEnumerable<ChatMessage>
@{
    ViewData["Title"] = "Chat with Admin";
    var messages    = Model.ToList();
    var lastId      = messages.Any() ? messages.Last().Id : 0;
    var myUserId    = (int)ViewBag.CurrentUserId;
    var currentUser = ViewBag.CurrentUser as WebApplication1.Models.User;
    var adminUser   = ViewBag.AdminUser  as WebApplication1.Models.User;
    var isEditor    = currentUser?.Role == "Editor";

    string AvatarHtml(WebApplication1.Models.User? u, string size = "28px") {
        if (u == null) return $"<div class=\"chat-avatar chat-avatar-initials\" style=\"width:{size};height:{size};\">?</div>";
        if (!string.IsNullOrEmpty(u.ProfileImagePath))
            return $"<img src=\"{u.ProfileImagePath}\" class=\"chat-avatar\" style=\"width:{size};height:{size};object-fit:cover;\" />";
        var f = u.FirstName?.Length > 0 ? u.FirstName[0] : ' ';
        var l = u.LastName?.Length  > 0 ? u.LastName[0]  : ' ';
        return $"<div class=\"chat-avatar chat-avatar-initials\" style=\"width:{size};height:{size};\">{f}{l}</div>";
    }


}
@Html.AntiForgeryToken()

<div class="container-fluid d-flex flex-column" style="height:calc(100vh - 130px);">
    <div class="d-flex align-items-center mb-3 flex-shrink-0 gap-3">
        @Html.Raw(AvatarHtml(adminUser, "42px"))
        <div class="flex-grow-1">
            <h5 class="mb-0 fw-semibold">@(adminUser != null ? adminUser.FirstName + " " + adminUser.LastName : "Admin")</h5>
            <small class="text-muted" style="font-size:.72rem;">Admin</small>
        </div>
        @if (!isEditor)
        {
            <button id="roleReqBtn" class="btn btn-sm btn-outline-warning flex-shrink-0" onclick="requestRole()">
                <i class="fas fa-key me-1"></i>ขอสิทธิ์ Editor
            </button>
        }
    </div>

    <div id="chatBox" class="flex-1 overflow-y-auto p-3 rounded mb-3"
         style="background:#f8f9fa;border:1px solid #e9ecef;min-height:0;">
        @if (!messages.Any())
        {
            <p class="text-center text-muted small mt-4">No messages yet. Say hi to admin!</p>
        }
        @foreach (var m in messages)
        {
            var isMe = !m.IsFromAdmin;
            var side = isMe ? "end" : "start";
            var cls  = isMe ? "chat-bubble-me" : "chat-bubble-admin";
            <div class="d-flex justify-content-@side align-items-end gap-2 mb-2">
                @if (!isMe) { @Html.Raw(AvatarHtml(adminUser)) }
                <div class="chat-bubble @cls">
                    @if (!string.IsNullOrEmpty(m.ImagePath)) { <a href="@m.ImagePath" target="_blank"><img src="@m.ImagePath" class="chat-img" /></a> }
                    else { <div>@m.Content</div> }
                    <small class="chat-time">@m.CreatedAt.ToString("HH:mm")</small>
                </div>
                @if (isMe) { @Html.Raw(AvatarHtml(currentUser)) }
            </div>
        }
    </div>

    <div class="d-flex gap-2 flex-shrink-0">
        <label class="btn btn-outline-secondary btn-sm px-2 mb-0" title="Send file">
            <i class="fas fa-image"></i>
            <input type="file" id="fileInput" style="display:none;" accept="image/*" onchange="sendFile(this)" />
        </label>
        <input type="text" id="msgInput" class="form-control" placeholder="Type a message..." />
        <button class="btn btn-modal-action px-4" onclick="sendMsg()">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

<style>
.chat-bubble { max-width:70%;padding:.55rem .85rem;border-radius:16px;font-size:.9rem; }
.chat-bubble-me    { background:var(--color-accent);color:#fff;border-bottom-right-radius:4px; }
.chat-bubble-admin { background:#fff;color:#1a1a2e;border:1px solid #e9ecef;border-bottom-left-radius:4px; }
.chat-time { display:block;font-size:.7rem;opacity:.65;margin-top:2px;text-align:right; }
.chat-avatar { border-radius:50%;flex-shrink:0; }
.chat-avatar-initials {
    display:inline-flex;align-items:center;justify-content:center;
    background:linear-gradient(135deg,#667eea,#764ba2);
    color:#fff;font-size:.65rem;font-weight:700;
}
.chat-img { max-width:200px;max-height:200px;border-radius:8px;display:block; }
</style>

@section Scripts {
<script>
const token   = document.querySelector('input[name="__RequestVerificationToken"]').value;
const userId  = @myUserId;
let   lastId  = @lastId;

const myAvatarHtml    = `@Html.Raw(AvatarHtml(currentUser).Replace("`", "\\`"))`;
const adminAvatarHtml = `@Html.Raw(AvatarHtml(adminUser).Replace("`", "\\`"))`;

function scrollBottom() {
    const box = document.getElementById('chatBox');
    box.scrollTop = box.scrollHeight;
}
scrollBottom();

async function requestRole() {
    const btn = document.getElementById('roleReqBtn');
    if (btn) { btn.disabled = true; btn.textContent = 'ส่งแล้ว...'; }
    const res = await fetch('/Chat/RequestRoleChange', {
        method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams({ __RequestVerificationToken: token })
    });
    if (res.ok) {
        const data = await res.json();
        if (data.alreadyPending) { alert('มีคำขออยู่แล้ว รอ Admin อนุมัติ'); if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-key me-1"></i>ขอสิทธิ์ Editor'; } return; }
        appendMsg(data);
        lastId = data.id;
        if (btn) btn.style.display = 'none';
    } else {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-key me-1"></i>ขอสิทธิ์ Editor'; }
    }
}

async function sendMsg() {
    const input = document.getElementById('msgInput');
    const text  = input.value.trim();
    if (!text) return;
    input.value = '';
    const res = await fetch('/Chat/Send', {
        method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'},
        body: new URLSearchParams({ userId, content: text, isFromAdmin: 'false', __RequestVerificationToken: token })
    });
    if (res.ok) { const m = await res.json(); appendMsg(m); lastId = m.id; }
}

async function sendFile(input) {
    if (!input.files[0]) return;
    const form = new FormData();
    form.append('userId', userId);
    form.append('isFromAdmin', 'false');
    form.append('file', input.files[0]);
    form.append('__RequestVerificationToken', token);
    input.value = '';
    const res = await fetch('/Chat/SendFile', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: form });
    if (res.ok) { const m = await res.json(); appendMsg(m); lastId = m.id; }
}

function appendMsg(m) {
    const box   = document.getElementById('chatBox');
    const isMine = !m.isFromAdmin;
    const side   = isMine ? 'end' : 'start';
    const cls    = isMine ? 'chat-bubble-me' : 'chat-bubble-admin';
    const av     = isMine ? myAvatarHtml : adminAvatarHtml;
    let   body   = '';
    if (m.imagePath) {
        body = `<a href="${m.imagePath}" target="_blank"><img src="${m.imagePath}" class="chat-img" /></a>`;
    } else {
        body = m.content;
    }
    const bubble = `<div class="chat-bubble ${cls}"><div>${body}</div><small class="chat-time">${m.createdAt}</small></div>`;
    const html = isMine
        ? `<div class="d-flex justify-content-${side} align-items-end gap-2 mb-2">${bubble}${av}</div>`
        : `<div class="d-flex justify-content-${side} align-items-end gap-2 mb-2">${av}${bubble}</div>`;
    box.insertAdjacentHTML('beforeend', html);
    box.scrollTop = box.scrollHeight;
}

document.getElementById('msgInput').addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });

setInterval(async () => {
    const res = await fetch(`/Chat/Poll?userId=${userId}&afterId=${lastId}`, { headers:{'X-Requested-With':'XMLHttpRequest'} });
    if (!res.ok) return;
    const msgs = await res.json();
    msgs.forEach(m => { appendMsg(m); lastId = m.id; });
}, 3000);
</script>
}
