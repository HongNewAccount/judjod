@using WebApplication1.Models
@model IEnumerable<ChatMessage>
@{
    ViewData["Title"] = "Chat";
    var chatUser       = ViewBag.ChatUser       as WebApplication1.Models.User;
    var adminUser      = ViewBag.AdminUser      as WebApplication1.Models.User;
    var pendingReqs    = ViewBag.PendingRequests as List<WebApplication1.Models.ProjectApprovalRequest> ?? new();
    var messages       = Model.ToList();
    var lastId         = messages.Any() ? messages.Last().Id : 0;
    var returnUrl      = ViewBag.ReturnUrl as string ?? Url.Action("Index", "Chat");

    string AvatarHtml(WebApplication1.Models.User? u, string size = "32px") {
        if (u == null) return $"<div class=\"chat-avatar\" style=\"width:{size};height:{size};\"></div>";
        if (!string.IsNullOrEmpty(u.ProfileImagePath))
            return $"<img src=\"{u.ProfileImagePath}\" class=\"chat-avatar\" style=\"width:{size};height:{size};object-fit:cover;\" />";
        var f = u.FirstName?.Length > 0 ? u.FirstName[0] : ' ';
        var l = u.LastName?.Length  > 0 ? u.LastName[0]  : ' ';
        return $"<div class=\"chat-avatar chat-avatar-initials\" style=\"width:{size};height:{size};\">{f}{l}</div>";
    }
}
@Html.AntiForgeryToken()

<div class="container-fluid d-flex flex-column" style="height:calc(100vh - 130px);">
    <div class="d-flex align-items-center mb-3 flex-shrink-0 gap-3">
        @Html.Raw(AvatarHtml(chatUser, "42px"))
        <div class="flex-grow-1">
            <h5 class="mb-0 fw-semibold">@chatUser?.FirstName @chatUser?.LastName</h5>
        </div>
        <a href="@returnUrl" class="btn btn-sm btn-outline-secondary flex-shrink-0">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
    </div>

    <div id="pendingSection" class="flex-shrink-0 @(pendingReqs.Any() ? "" : "d-none")">
        <div class="d-flex align-items-center gap-2 mb-1">
            <small class="fw-semibold text-warning"><i class="fas fa-clock me-1"></i>คำขอแก้ไขที่รอดำเนินการ</small>
            <span id="pendingCount" class="badge bg-warning text-dark">@pendingReqs.Count</span>
        </div>
        <div id="pendingList" class="d-flex flex-column gap-1 mb-2">
            @foreach (var r in pendingReqs)
            {
                <div class="d-flex align-items-center gap-2 p-2 rounded border bg-warning bg-opacity-10" id="req-@r.Id">
                    <div class="flex-grow-1 small">
                        <i class="fas fa-key me-1 text-warning"></i>
                        <span class="fw-semibold">@r.Issues</span> ขอสิทธิ์ <span class="badge bg-primary">Editor</span>
                    </div>
                    <button class="btn btn-sm btn-success py-0 px-2" onclick="approveReq(@r.Id)"><i class="fas fa-check me-1"></i>Approve</button>
                    <button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="rejectReq(@r.Id)"><i class="fas fa-times me-1"></i>Reject</button>
                </div>
            }
        </div>
    </div>

    <div id="chatBox" class="flex-1 overflow-y-auto p-3 rounded mb-3"
         style="background:#f8f9fa;border:1px solid #e9ecef;min-height:0;">
        @foreach (var m in messages)
        {
            if (m.IsFromAdmin)
            {
                <div class="d-flex justify-content-end align-items-end gap-2 mb-2">
                    <div class="chat-bubble chat-bubble-admin">
                        @if (!string.IsNullOrEmpty(m.ImagePath)) { <a href="@m.ImagePath" target="_blank"><img src="@m.ImagePath" class="chat-img" /></a> }
                        else { <div>@m.Content</div> }
                        <small class="chat-time">@m.CreatedAt.ToString("HH:mm")</small>
                    </div>
                    @Html.Raw(AvatarHtml(adminUser))
                </div>
            }
            else
            {
                <div class="d-flex justify-content-start align-items-end gap-2 mb-2">
                    @Html.Raw(AvatarHtml(chatUser))
                    <div class="chat-bubble chat-bubble-user">
                        @if (!string.IsNullOrEmpty(m.ImagePath)) { <a href="@m.ImagePath" target="_blank"><img src="@m.ImagePath" class="chat-img" /></a> }
                        else { <div>@m.Content</div> }
                        <small class="chat-time">@m.CreatedAt.ToString("HH:mm")</small>
                    </div>
                </div>
            }
        }
    </div>

    <div class="d-flex gap-2 flex-shrink-0">
        <label class="btn btn-outline-secondary btn-sm px-2 mb-0" title="Send file">
            <i class="fas fa-image"></i>
            <input type="file" id="fileInput" style="display:none;" accept="image/*" onchange="sendFile(this)" />
        </label>
        <input type="text" id="msgInput" class="form-control" placeholder="Type a message..." />
        <button class="btn btn-modal-action px-4" onclick="sendMsg()">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

<style>
.chat-bubble { max-width:70%;padding:.55rem .85rem;border-radius:16px;font-size:.9rem; }
.chat-bubble-admin { background:var(--color-accent);color:#fff;border-bottom-right-radius:4px; }
.chat-bubble-user  { background:#fff;color:#1a1a2e;border:1px solid #e9ecef;border-bottom-left-radius:4px; }
.chat-time { display:block;font-size:.7rem;opacity:.65;margin-top:2px;text-align:right; }
.chat-avatar { border-radius:50%;flex-shrink:0; }
.chat-avatar-initials {
    display:inline-flex;align-items:center;justify-content:center;
    background:linear-gradient(135deg,#667eea,#764ba2);
    color:#fff;font-size:.72rem;font-weight:700;
}
.chat-img { max-width:200px;max-height:200px;border-radius:8px;display:block; }
</style>

@section Scripts {
<script>
const token   = document.querySelector('input[name="__RequestVerificationToken"]').value;
const userId  = @chatUser!.Id;
let   lastId  = @lastId;

const userAvatarHtml  = `@Html.Raw(AvatarHtml(chatUser).Replace("`","\\`"))`;
const adminAvatarHtml = `@Html.Raw(AvatarHtml(adminUser).Replace("`","\\`"))`;

function scrollBottom() {
    const box = document.getElementById('chatBox');
    box.scrollTop = box.scrollHeight;
}
scrollBottom();

async function sendMsg() {
    const input = document.getElementById('msgInput');
    const text  = input.value.trim();
    if (!text) return;
    input.value = '';
    const res = await fetch('/Chat/Send', {
        method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'},
        body: new URLSearchParams({ userId, content: text, isFromAdmin: 'true', __RequestVerificationToken: token })
    });
    if (res.ok) { const m = await res.json(); appendMsg(m); lastId = m.id; }
}

async function sendFile(input) {
    if (!input.files[0]) return;
    const form = new FormData();
    form.append('userId', userId);
    form.append('isFromAdmin', 'true');
    form.append('file', input.files[0]);
    form.append('__RequestVerificationToken', token);
    input.value = '';
    const res = await fetch('/Chat/SendFile', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: form });
    if (res.ok) { const m = await res.json(); appendMsg(m); lastId = m.id; }
}

function appendMsg(m) {
    const box = document.getElementById('chatBox');
    const cls = m.isFromAdmin ? 'chat-bubble-admin' : 'chat-bubble-user';
    let body  = '';
    if (m.imagePath) {
        body = `<a href="${m.imagePath}" target="_blank"><img src="${m.imagePath}" class="chat-img" /></a>`;
    } else { body = m.content; }
    const bubble = `<div class="chat-bubble ${cls}"><div>${body}</div><small class="chat-time">${m.createdAt}</small></div>`;
    const html = m.isFromAdmin
        ? `<div class="d-flex justify-content-end align-items-end gap-2 mb-2">${bubble}${adminAvatarHtml}</div>`
        : `<div class="d-flex justify-content-start align-items-end gap-2 mb-2">${userAvatarHtml}${bubble}</div>`;
    box.insertAdjacentHTML('beforeend', html);
    box.scrollTop = box.scrollHeight;
}

document.getElementById('msgInput').addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });

async function approveReq(id) {
    const res = await fetch('/Chat/ApproveRoleRequest', {
        method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams({ requestId: id, __RequestVerificationToken: token })
    });
    if (res.ok) removeReqCard(id);
}

async function rejectReq(id) {
    const res = await fetch('/Chat/RejectRoleRequest', {
        method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams({ requestId: id, __RequestVerificationToken: token })
    });
    if (res.ok) removeReqCard(id);
}

function removeReqCard(id) {
    const el = document.getElementById('req-' + id);
    if (el) el.remove();
    const remaining = document.querySelectorAll('#pendingList [id^="req-"]').length;
    document.getElementById('pendingCount').textContent = remaining;
    if (remaining === 0) document.getElementById('pendingSection').classList.add('d-none');
}

setInterval(async () => {
    const res = await fetch(`/Chat/Poll?userId=${userId}&afterId=${lastId}`, { headers:{'X-Requested-With':'XMLHttpRequest'} });
    if (!res.ok) return;
    const msgs = await res.json();
    msgs.forEach(m => { appendMsg(m); lastId = m.id; });
}, 3000);

setInterval(async () => {
    const res = await fetch(`/Chat/PendingRoleRequests?userId=${userId}`, { headers:{'X-Requested-With':'XMLHttpRequest'} });
    if (!res.ok) return;
    const reqs = await res.json();
    const existing = new Set([...document.querySelectorAll('#pendingList [id^="req-"]')].map(el => parseInt(el.id.replace('req-', ''))));
    reqs.forEach(r => {
        if (!existing.has(r.id)) {
            document.getElementById('pendingList').insertAdjacentHTML('beforeend',
                `<div class="d-flex align-items-center gap-2 p-2 rounded border bg-warning bg-opacity-10" id="req-${r.id}">
                    <div class="flex-grow-1 small"><i class="fas fa-key me-1 text-warning"></i><span class="fw-semibold">${r.displayName}</span> ขอสิทธิ์ <span class="badge bg-primary">Editor</span></div>
                    <button class="btn btn-sm btn-success py-0 px-2" onclick="approveReq(${r.id})"><i class="fas fa-check me-1"></i>Approve</button>
                    <button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="rejectReq(${r.id})"><i class="fas fa-times me-1"></i>Reject</button>
                </div>`);
            document.getElementById('pendingSection').classList.remove('d-none');
            document.getElementById('pendingCount').textContent = document.querySelectorAll('#pendingList [id^="req-"]').length;
        }
    });
}, 5000);
</script>
}
