@using WebApplication1.Models
@model IEnumerable<WebApplication1.Models.ChatRoom>
@{
    ViewData["Title"] = "Chat";
    var currentUserId = (int)ViewBag.CurrentUserId;
    var lastMessages = (Dictionary<int, ChatRoomMessage>)ViewBag.LastMessages;
    var unreadCounts = (Dictionary<int, int>)ViewBag.UnreadCounts;
    var allUsers = (List<User>)ViewBag.AllUsers;

    string Initials(User? u) {
        if (u == null) return "?";
        var f = u.FirstName?.Length > 0 ? u.FirstName[0].ToString() : "";
        var l = u.LastName?.Length > 0 ? u.LastName[0].ToString() : "";
        return (f + l).ToUpper();
    }

    string RoomName(ChatRoom r) {
        if (r.IsGroup) return r.Name ?? "Group Chat";
        var other = r.Members.FirstOrDefault(m => m.UserId != currentUserId)?.User;
        return $"{other?.FirstName} {other?.LastName}".Trim();
    }
}
@Html.AntiForgeryToken()

<div class="container-fluid">
    <div class="page-header mb-3 d-flex align-items-center">
        <div class="flex-grow-1">
            <h1 class="page-title mb-0"><i class="fas fa-comments me-2" style="color:var(--color-accent);"></i>Chat</h1>
            <p class="page-subtitle mb-0">Team conversations</p>
        </div>
        <button class="btn btn-action" data-bs-toggle="modal" data-bs-target="#newChatModal">
            <i class="fas fa-plus me-1"></i>New Chat
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="card p-5 text-center border-0 shadow-sm mx-auto" style="max-width:560px;">
            <i class="fas fa-comments" style="font-size:48px;color:#ccc;"></i>
            <p class="text-muted mt-3">No conversations yet.</p>
            <button class="btn btn-modal-action btn-sm mx-auto" style="width:fit-content;" data-bs-toggle="modal" data-bs-target="#newChatModal">
                <i class="fas fa-plus me-1"></i>Start a chat
            </button>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mx-auto" style="max-width:620px;">
            @foreach (var room in Model)
            {
                var name = RoomName(room);
                var other = room.IsGroup ? null : room.Members.FirstOrDefault(m => m.UserId != currentUserId)?.User;
                var lastMsg = lastMessages.GetValueOrDefault(room.Id);
                var unread = unreadCounts.GetValueOrDefault(room.Id, 0);

                @* Razor auto-encodes @ expressions — JSON " → &quot; in HTML, browser decodes back to " for dataset *@
                var membersJson = System.Text.Json.JsonSerializer.Serialize(
                    room.Members.Where(m => m.User != null).OrderBy(m => m.User!.FirstName).Select(m => new {
                        id   = m.UserId,
                        name = $"{m.User!.FirstName} {m.User.LastName}".Trim(),
                        role = m.User.Role ?? "User",
                        img  = m.User.ProfileImagePath ?? "",
                        init = $"{(m.User.FirstName?.Length > 0 ? m.User.FirstName[0] : ' ')}{(m.User.LastName?.Length > 0 ? m.User.LastName[0] : ' ')}".Trim().ToUpper()
                    })
                );

                <div class="d-flex align-items-center gap-3 p-3 border-bottom chat-row">

                    @* Avatar: clickable *@
                    @if (room.IsGroup)
                    {
                        <button type="button" class="btn p-0 border-0 rounded-circle flex-shrink-0 js-show-members"
                                data-room-name="@name"
                                data-members="@membersJson"
                                title="View members"
                                style="width:44px;height:44px;background:linear-gradient(135deg,#11998e,#38ef7d);color:#fff;">
                            <i class="fas fa-users" style="font-size:.9rem;"></i>
                        </button>
                    }
                    else if (!string.IsNullOrEmpty(other?.ProfileImagePath))
                    {
                        <a href="/User/Details/@other!.Id" class="flex-shrink-0">
                            <img src="@other.ProfileImagePath" class="rounded-circle"
                                 style="width:44px;height:44px;object-fit:cover;" />
                        </a>
                    }
                    else
                    {
                        <a href="/User/Details/@other?.Id" class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold text-decoration-none flex-shrink-0"
                           style="width:44px;height:44px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:.85rem;">
                            @Initials(other)
                        </a>
                    }

                    @* Text → goes to room *@
                    <a href="@Url.Action("Room","Chat", new { id = room.Id })"
                       class="text-decoration-none text-dark flex-grow-1" style="min-width:0;">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">@name</span>
                            @if (lastMsg != null)
                            {
                                <small class="text-muted flex-shrink-0 ms-2">@lastMsg.CreatedAt.ToString("dd MMM HH:mm")</small>
                            }
                        </div>
                        <p class="text-muted small mb-0 text-truncate">
                            @if (lastMsg != null)
                            {
                                @(string.IsNullOrEmpty(lastMsg.Content) ? "[Image]" : lastMsg.Content)
                            }
                            else { <span class="fst-italic">No messages yet</span> }
                        </p>
                    </a>

                    @if (unread > 0)
                    {
                        <span class="badge rounded-pill flex-shrink-0" style="background:var(--color-accent);">@unread</span>
                    }
                </div>
            }
        </div>

        <!-- Shared group members modal -->
        <div class="modal fade" id="groupMembersModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-dark text-white py-3 px-4">
                        <h6 class="modal-title fw-bold" id="groupMembersTitle"></h6>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0" id="groupMembersList" style="max-height:400px;overflow-y:auto;"></div>
                </div>
            </div>
        </div>
    }
</div>

<!-- New Chat Modal -->
<div class="modal fade" id="newChatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white py-3 px-4">
                <h6 class="modal-title fw-bold"><i class="fas fa-comments me-2" style="color:var(--color-accent);"></i>New Chat</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <ul class="nav nav-tabs px-4 pt-3 border-bottom-0">
                    <li class="nav-item">
                        <button class="nav-link active fw-semibold" data-bs-toggle="tab" data-bs-target="#tabDM">
                            <i class="fas fa-user me-1"></i>Direct Message
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-semibold" data-bs-toggle="tab" data-bs-target="#tabGroup">
                            <i class="fas fa-users me-1"></i>Group Chat
                        </button>
                    </li>
                </ul>

                <div class="tab-content px-4 pb-4 pt-3">
                    <!-- DM Tab -->
                    <div class="tab-pane fade show active" id="tabDM">
                        <input type="text" id="dmSearch" class="form-control mb-3" placeholder="Search people..." />
                        <div style="max-height:340px;overflow-y:auto;" class="rounded border">
                            @foreach (var u in allUsers)
                            {
                                <a href="@Url.Action("StartDM","Chat", new { userId = u.Id })"
                                   class="d-flex align-items-center gap-3 p-3 text-decoration-none text-dark dm-user-row user-row border-bottom">
                                    @if (!string.IsNullOrEmpty(u.ProfileImagePath))
                                    {
                                        <img src="@u.ProfileImagePath" class="rounded-circle flex-shrink-0"
                                             style="width:40px;height:40px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                             style="width:40px;height:40px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:.75rem;">
                                            @Initials(u)
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-semibold">@u.FirstName @u.LastName</div>
                                        <div class="text-muted small">@u.Role</div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>

                    <!-- Group Tab -->
                    <div class="tab-pane fade" id="tabGroup">
                        <form method="post" action="@Url.Action("CreateGroup","Chat")">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Group name *</label>
                                <input type="text" name="name" class="form-control" placeholder="Enter group name..." required />
                            </div>
                            <div class="mb-2">
                                <label class="form-label fw-semibold small">Add members</label>
                                <input type="text" id="groupSearch" class="form-control mb-2" placeholder="Search people..." />
                            </div>
                            <div style="max-height:240px;overflow-y:auto;" id="groupUserList" class="rounded border">
                                @foreach (var u in allUsers)
                                {
                                    <label class="d-flex align-items-center gap-3 p-3 group-user-row user-row border-bottom" style="cursor:pointer;">
                                        <input type="checkbox" name="memberIds" value="@u.Id" class="form-check-input mt-0 flex-shrink-0" />
                                        @if (!string.IsNullOrEmpty(u.ProfileImagePath))
                                        {
                                            <img src="@u.ProfileImagePath" class="rounded-circle flex-shrink-0"
                                                 style="width:36px;height:36px;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                                 style="width:36px;height:36px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:.7rem;">
                                                @Initials(u)
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold">@u.FirstName @u.LastName</div>
                                            <div class="text-muted small">@u.Role</div>
                                        </div>
                                    </label>
                                }
                            </div>
                            <button type="submit" class="btn btn-modal-action w-100 mt-3">
                                <i class="fas fa-users me-1"></i>Create Group
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.chat-row:hover, .user-row:hover { background: #f8f9fa; }
.member-row:hover { background: #f8f9fa; }
</style>

@section Scripts {
<script>
document.getElementById('dmSearch').addEventListener('input', function () {
    const term = this.value.toLowerCase();
    document.querySelectorAll('.dm-user-row').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
});
document.getElementById('groupSearch').addEventListener('input', function () {
    const term = this.value.toLowerCase();
    document.querySelectorAll('.group-user-row').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
});

document.addEventListener('click', function(e) {
    const btn = e.target.closest('.js-show-members');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    const name = btn.dataset.roomName;
    const members = JSON.parse(btn.dataset.members);
    showGroupMembers(name, members);
});

function showGroupMembers(name, members) {
    document.getElementById('groupMembersTitle').innerHTML =
        `<i class="fas fa-users me-2" style="color:var(--color-accent);"></i>${name}`;
    document.getElementById('groupMembersList').innerHTML = members.map(m => {
        const avatar = m.img
            ? `<img src="${m.img}" class="rounded-circle flex-shrink-0" style="width:38px;height:38px;object-fit:cover;">`
            : `<div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                    style="width:38px;height:38px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:.7rem;">${m.init}</div>`;
        return `<a href="/User/Details/${m.id}"
                   class="d-flex align-items-center gap-3 px-4 py-3 text-decoration-none text-dark member-row border-bottom">
            ${avatar}
            <div>
                <div class="fw-semibold">${m.name}</div>
                <div class="text-muted small">${m.role}</div>
            </div>
        </a>`;
    }).join('');
    const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('groupMembersModal'));
    modal.show();
}
</script>
}
