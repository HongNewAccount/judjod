@using WebApplication1.Models
@{
    ViewData["Title"] = "Chat";
    var room        = (ChatRoom)ViewBag.Room;
    var messages    = (List<ChatRoomMessage>)ViewBag.Messages;
    var currentUserId = (int)ViewBag.CurrentUserId;
    var isAdmin     = (bool)ViewBag.IsAdmin;
    var currentUser = (User)ViewBag.CurrentUser;
    var lastId      = messages.Any() ? messages.Last().Id : 0;

    string roomName;
    User? dmPartner = null;
    if (room.IsGroup)
    {
        roomName = room.Name ?? "Group Chat";
    }
    else
    {
        dmPartner = room.Members.FirstOrDefault(m => m.UserId != currentUserId)?.User;
        roomName  = $"{dmPartner?.FirstName} {dmPartner?.LastName}".Trim();
    }

    string AvatarHtml(User? u, string size = "32px") {
        if (u == null) return "";
        if (!string.IsNullOrEmpty(u.ProfileImagePath))
            return $"<img src=\"{u.ProfileImagePath}\" class=\"chat-avatar\" style=\"width:{size};height:{size};object-fit:cover;\" />";
        var f = u.FirstName?.Length > 0 ? u.FirstName[0] : ' ';
        var l = u.LastName?.Length  > 0 ? u.LastName[0]  : ' ';
        return $"<div class=\"chat-avatar chat-avatar-initials\" style=\"width:{size};height:{size};\">{f}{l}</div>";
    }

    string AvatarLink(User? u, string size = "32px") {
        if (u == null) return "";
        return $"<a href=\"/User/Details/{u.Id}\" title=\"{u.FirstName} {u.LastName}\">{AvatarHtml(u, size)}</a>";
    }

    var memberMap = room.Members.Where(m => m.User != null).ToDictionary(m => m.UserId, m => m.User!);
}
@Html.AntiForgeryToken()

<div class="container-fluid d-flex flex-column" style="height:calc(100vh - 130px);">

    <!-- Header -->
    <div class="d-flex align-items-center mb-3 flex-shrink-0 gap-2">
        @if (room.IsGroup)
        {
            <button type="button" class="d-flex align-items-center gap-2 btn btn-link text-decoration-none text-dark p-0 flex-grow-1 text-start"
                    data-bs-toggle="modal" data-bs-target="#groupInfoModal" style="min-width:0;">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white flex-shrink-0"
                     style="width:40px;height:40px;background:linear-gradient(135deg,#11998e,#38ef7d);">
                    <i class="fas fa-users"></i>
                </div>
                <div style="min-width:0;">
                    <div class="fw-semibold text-truncate">@roomName</div>
                    <small class="text-muted">@room.Members.Count members · tap to view</small>
                </div>
            </button>
        }
        else
        {
            <a href="@Url.Action("Details","User", new { id = dmPartner?.Id })"
               class="d-flex align-items-center gap-2 text-decoration-none text-dark flex-grow-1" style="min-width:0;">
                @Html.Raw(AvatarHtml(dmPartner, "40px"))
                <div style="min-width:0;">
                    <div class="fw-semibold text-truncate">@roomName</div>
                </div>
            </a>
        }

        @if (isAdmin)
        {
            <form method="post" action="@Url.Action("ClearRoom","Chat")"
                  onsubmit="return confirm('ลบข้อความทั้งหมดในแชทนี้?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roomId" value="@room.Id" />
                <button type="submit" class="btn btn-sm btn-outline-danger flex-shrink-0">
                    <i class="fas fa-trash me-1"></i>Clear Chat
                </button>
            </form>
        }

        <button type="button" onclick="history.back()" class="btn btn-sm btn-secondary flex-shrink-0">
            <i class="fas fa-arrow-left me-1"></i>Back
        </button>
    </div>

    @if (room.IsGroup)
    {
        var canManage = (bool)ViewBag.CanManageGroup;
        var nonMembers = (List<WebApplication1.Models.User>)ViewBag.NonMembers;

        <div class="modal fade" id="groupInfoModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header py-2 px-3">
                        <h6 class="modal-title fw-semibold"><i class="fas fa-users me-2" style="color:var(--color-accent);"></i>@roomName</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <p class="small fw-semibold text-muted mb-0 px-3 pt-3 pb-1 text-uppercase" style="letter-spacing:.05em;">
                            Members (@room.Members.Count)
                        </p>
                        <div style="max-height:280px;overflow-y:auto;">
                            @foreach (var mem in room.Members.Where(m => m.User != null).OrderBy(m => m.User!.FirstName))
                            {
                                <div class="d-flex align-items-center gap-2 px-3 py-2 member-row">
                                    <a href="/User/Details/@mem.UserId" class="d-flex align-items-center gap-2 text-decoration-none text-dark flex-grow-1">
                                        @Html.Raw(AvatarHtml(mem.User, "32px"))
                                        <div>
                                            <div class="fw-semibold small">@mem.User!.FirstName @mem.User.LastName</div>
                                            <div class="text-muted" style="font-size:.7rem;">@mem.User.Role</div>
                                        </div>
                                    </a>
                                    @if (mem.UserId == room.CreatedByUserId)
                                    {
                                        <span class="badge bg-secondary flex-shrink-0" style="font-size:.6rem;">Creator</span>
                                    }
                                    else if (canManage)
                                    {
                                        <form method="post" action="@Url.Action("RemoveMember","Chat")"
                                              onsubmit="return confirm('Remove @mem.User!.FirstName?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="roomId" value="@room.Id" />
                                            <input type="hidden" name="userId" value="@mem.UserId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1 flex-shrink-0" title="Remove">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        </div>

                        @if (canManage && nonMembers.Any())
                        {
                            <hr class="my-0" />
                            <p class="small fw-semibold text-muted mb-0 px-3 pt-3 pb-1 text-uppercase" style="letter-spacing:.05em;">
                                Invite
                            </p>
                            <div style="max-height:200px;overflow-y:auto;padding-bottom:.5rem;">
                                @foreach (var u in nonMembers)
                                {
                                    <div class="d-flex align-items-center gap-2 px-3 py-1 member-row">
                                        <div class="flex-grow-1 d-flex align-items-center gap-2">
                                            @Html.Raw(AvatarHtml(u, "28px"))
                                            <span class="small">@u.FirstName @u.LastName</span>
                                        </div>
                                        <form method="post" action="@Url.Action("AddMember","Chat")">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="roomId" value="@room.Id" />
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary py-0 px-2 flex-shrink-0">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="modal-footer py-2 px-3 justify-content-start">
                        <form method="post" action="@Url.Action("LeaveRoom","Chat")"
                              onsubmit="return confirm('ออกจากกลุ่ม?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roomId" value="@room.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-sign-out-alt me-1"></i>Leave Group
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <style>.member-row:hover { background:#f8f9fa; }</style>
    }

    <!-- Messages -->
    <div id="chatBox" class="flex-1 overflow-y-auto p-3 rounded mb-3"
         style="background:#f8f9fa;border:1px solid #e9ecef;min-height:0;">
        @if (!messages.Any())
        {
            <p class="text-muted text-center small mt-3">No messages yet. Say hello!</p>
        }
        @foreach (var m in messages)
        {
            if (m.IsSystemMessage)
            {
                <div class="chat-system-msg">@m.Content</div>
            }
            else
            {
                var isMe   = m.SenderId == currentUserId;
                var sender = memberMap.GetValueOrDefault(m.SenderId);

                if (isMe)
                {
                    <div class="d-flex justify-content-end align-items-end gap-2 mb-2">
                        <div class="chat-bubble chat-bubble-mine">
                            @if (!string.IsNullOrEmpty(m.ImagePath))
                            { <a href="@m.ImagePath" target="_blank"><img src="@m.ImagePath" class="chat-img" /></a> }
                            else { <div class="chat-text">@m.Content</div> }
                            <small class="chat-time">@m.CreatedAt.ToString("HH:mm")</small>
                        </div>
                        @Html.Raw(AvatarHtml(currentUser))
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-start align-items-end gap-2 mb-2">
                        @Html.Raw(AvatarLink(sender))
                        <div class="chat-theirs-wrap">
                            @if (room.IsGroup && sender != null)
                            {
                                <small class="text-muted ms-1 d-block mb-1">@sender.FirstName @sender.LastName</small>
                            }
                            <div class="chat-bubble chat-bubble-theirs">
                                @if (!string.IsNullOrEmpty(m.ImagePath))
                                { <a href="@m.ImagePath" target="_blank"><img src="@m.ImagePath" class="chat-img" /></a> }
                                else { <div class="chat-text">@m.Content</div> }
                                <small class="chat-time">@m.CreatedAt.ToString("HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    <!-- Input -->
    <div class="d-flex gap-2 flex-shrink-0">
        <label class="btn btn-outline-secondary btn-sm px-2 mb-0" title="Send image">
            <i class="fas fa-image"></i>
            <input type="file" id="fileInput" style="display:none;" accept="image/*" onchange="sendFile(this)" />
        </label>
        <input type="text" id="msgInput" class="form-control" placeholder="Type a message..." />
        <button class="btn btn-modal-action px-4" onclick="sendMsg()">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

<style>
.chat-bubble { padding:.5rem .8rem;border-radius:16px;font-size:.9rem; }
.chat-bubble-mine   { max-width:70%;background:var(--color-accent);color:#fff;border-bottom-right-radius:4px; }
.chat-bubble-theirs { background:#fff;color:#1a1a2e;border:1px solid #e9ecef;border-bottom-left-radius:4px; }
.chat-theirs-wrap   { max-width:50%; }
.chat-theirs-wrap .chat-bubble-theirs { max-width:100%; }
.chat-text  { word-break:break-word;overflow-wrap:break-word; }
.chat-time  { display:block;font-size:.7rem;opacity:.65;white-space:nowrap;margin-top:2px; }
.chat-bubble-mine .chat-time { text-align:right; }
.chat-avatar { border-radius:50%;flex-shrink:0;display:block; }
.chat-avatar-initials {
    display:inline-flex;align-items:center;justify-content:center;
    background:linear-gradient(135deg,#667eea,#764ba2);
    color:#fff;font-size:.72rem;font-weight:700;
}
a .chat-avatar, a .chat-avatar-initials { cursor:pointer; }
a .chat-avatar:hover, a .chat-avatar-initials:hover { opacity:.8; }
.chat-img { max-width:200px;max-height:200px;border-radius:8px;display:block; }
#chatBox { overflow-x:hidden; }
.chat-system-msg {
    text-align:center;font-size:.75rem;color:#888;
    background:#f0f0f0;border-radius:12px;
    padding:3px 12px;margin:.5rem auto;
    width:fit-content;max-width:80%;
}
</style>

@section Scripts {
<script>
const token   = document.querySelector('input[name="__RequestVerificationToken"]').value;
const roomId  = @room.Id;
const myId    = @currentUserId;
const isGroup = @(room.IsGroup ? "true" : "false");
let   lastId  = @lastId;

const myAvatarHtml = `@Html.Raw(AvatarHtml(currentUser).Replace("`", "\\`"))`;
const memberAvatars = {
    @foreach (var mem in room.Members.Where(m => m.User != null))
    {<text>@mem.UserId: `@Html.Raw(AvatarHtml(mem.User).Replace("`","\\`"))`,</text>}
};
const memberProfileUrls = {
    @foreach (var mem in room.Members.Where(m => m.User != null))
    {<text>@mem.UserId: '/User/Details/@mem.UserId',</text>}
};

function scrollBottom() {
    const box = document.getElementById('chatBox');
    box.scrollTop = box.scrollHeight;
}
scrollBottom();

async function sendMsg() {
    const input = document.getElementById('msgInput');
    const text  = input.value.trim();
    if (!text) return;
    input.value = '';
    const res = await fetch('/Chat/Send', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams({ roomId, content: text, __RequestVerificationToken: token })
    });
    if (res.ok) { const m = await res.json(); appendMsg(m); lastId = m.id; }
}

async function sendFile(input) {
    if (!input.files[0]) return;
    const form = new FormData();
    form.append('roomId', roomId);
    form.append('file', input.files[0]);
    form.append('__RequestVerificationToken', token);
    input.value = '';
    const res = await fetch('/Chat/SendFile', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: form
    });
    if (res.ok) { const m = await res.json(); appendMsg(m); lastId = m.id; }
}

function appendMsg(m) {
    const box = document.getElementById('chatBox');

    if (m.isSystem) {
        box.insertAdjacentHTML('beforeend', `<div class="chat-system-msg">${m.content}</div>`);
        box.scrollTop = box.scrollHeight;
        return;
    }

    const isMe = m.senderId === myId;
    const rawAvatar = memberAvatars[m.senderId] || '';
    const profileUrl = memberProfileUrls[m.senderId];
    const avatarHtml = isMe
        ? myAvatarHtml
        : (profileUrl ? `<a href="${profileUrl}" title="View profile">${rawAvatar}</a>` : rawAvatar);
    const senderLabel = (!isMe && isGroup && m.senderName)
        ? `<small class="text-muted ms-1 d-block mb-1">${m.senderName}</small>` : '';

    const bubbleBody = m.imagePath
        ? `<a href="${m.imagePath}" target="_blank"><img src="${m.imagePath}" class="chat-img" /></a><small class="chat-time">${m.createdAt}</small>`
        : `<div class="chat-text">${m.content}</div><small class="chat-time">${m.createdAt}</small>`;

    let html;
    if (isMe) {
        html = `<div class="d-flex justify-content-end align-items-end gap-2 mb-2">
            <div class="chat-bubble chat-bubble-mine">${bubbleBody}</div>
            ${avatarHtml}
        </div>`;
    } else {
        html = `<div class="d-flex justify-content-start align-items-end gap-2 mb-2">
            ${avatarHtml}
            <div class="chat-theirs-wrap">${senderLabel}<div class="chat-bubble chat-bubble-theirs">${bubbleBody}</div></div>
        </div>`;
    }
    box.insertAdjacentHTML('beforeend', html);
    box.scrollTop = box.scrollHeight;
}

document.getElementById('msgInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') sendMsg();
});

setInterval(async () => {
    const res = await fetch(`/Chat/Poll?roomId=${roomId}&afterId=${lastId}`, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    if (!res.ok) return;
    const msgs = await res.json();
    msgs.forEach(m => { appendMsg(m); lastId = m.id; });
}, 3000);
</script>
}
