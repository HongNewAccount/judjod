<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Organization Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <div class="layout-wrapper">
        <!-- Sidebar -->
        <nav class="sidebar bg-dark">
            <div class="sidebar-header">
                <h5 class="text-white mb-0">
                    <i class="fas fa-chart-line me-2"></i>Organization Dashboard
                </h5>
            </div>

            <ul class="sidebar-nav">
                <li class="sidebar-item">
                    <a class="sidebar-link" asp-controller="ProjectTracker" asp-action="Index">
                        <i class="fas fa-project-diagram"></i>
                        <span>Project Tracker</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-chart-bar"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link" asp-controller="Report" asp-action="Index">
                        <i class="fas fa-file-alt"></i>
                        <span>Reports</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link" asp-controller="Event" asp-action="Index">
                        <i class="fas fa-calendar"></i>
                        <span>Events</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link" asp-controller="User" asp-action="Index">
                        <i class="fas fa-users"></i>
                        <span>Users</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <div class="user-info mb-3">
                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <div class="user-details">
                            <small class="text-white d-block">@(Context.Session.GetString("UserName") ?? "User")</small>
                            <small class="text-muted">@(Context.Session.GetString("UserRole") ?? "User")</small>
                        </div>
                    </div>
                    <a asp-controller="User" asp-action="Details"
                       asp-route-id="@Context.Session.GetInt32("UserId")"
                       class="btn btn-sm btn-outline-light w-100 mb-2">
                        <i class="fas fa-user me-1"></i> Profile
                    </a>
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-sm btn-outline-danger w-100">
                        <i class="fas fa-sign-out-alt me-1"></i> Logout
                    </a>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-sm btn-primary w-100">
                        <i class="fas fa-sign-in-alt me-1"></i> Login
                    </a>
                }
            </div>
        </nav>

        <!-- Main Content -->
        <main role="main" class="main-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 pt-4">
        <div class="container text-center">
            <small>&copy; @DateTime.Now.Year Organization Dashboard. All rights reserved.</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
