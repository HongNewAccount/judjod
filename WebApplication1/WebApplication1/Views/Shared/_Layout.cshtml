@inject WebApplication1.Data.ApplicationDbContext DbContext
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userName = Context.Session.GetString("UserName") ?? "User";
    var userRole = Context.Session.GetString("UserRole") ?? "User";
    var userId = Context.Session.GetInt32("UserId");
    var userInitials = string.Concat(userName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => p[0])).ToUpper();
    var currentUserProfileImage = userId != null ? DbContext.Users.Where(u => u.Id == userId).Select(u => u.ProfileImagePath).FirstOrDefault() : null;

    var chatBadge = 0;
    if (userId != null)
    {
        var myMemberships = DbContext.ChatRoomMembers.Where(m => m.UserId == userId).ToList();
        foreach (var mem in myMemberships)
        {
            chatBadge += DbContext.ChatRoomMessages.Count(m =>
                m.RoomId == mem.RoomId &&
                m.Id > mem.LastReadMessageId &&
                m.SenderId != userId);
        }
    }

    string NavClass(string controller, string? action = null) =>
        "sidebar-link" + (currentController == controller && (action == null || currentAction == action) ? " active" : "");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Organization Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <div class="app-shell" data-sidebar>
        <div class="sidebar-overlay" data-sidebar-overlay></div>

        <nav class="sidebar" data-sidebar-el>
            <div class="sidebar-header">
                <img src="/uploads/pic/logo2.png" alt="Logo" class="sidebar-logo-icon" style="width:28px;height:28px;object-fit:contain;border-radius:4px;" />
                <span class="sidebar-logo-text">JUDJOD</span>
            </div>

            <ul class="sidebar-nav">
                <li class="sidebar-item">
                    <a class="@NavClass("ProjectTracker", "Index")" asp-controller="ProjectTracker" asp-action="Index" title="Board">
                        <i class="fas fa-columns"></i>
                        <span>Board</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="@NavClass("ProjectTracker", "Archive")" asp-controller="ProjectTracker" asp-action="Archive" title="Archive">
                        <i class="fas fa-archive"></i>
                        <span>Archive</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="@NavClass("Dashboard")" asp-controller="Dashboard" asp-action="Index" title="Calendar">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Calendar</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="@NavClass("Chat")" asp-controller="Chat" asp-action="Index" title="Chat">
                        <i class="fas fa-comments"></i>
                        <span>Chat @if (chatBadge > 0) { <span class="badge rounded-pill ms-1" style="background:var(--color-accent);font-size:.6rem;padding:2px 5px;vertical-align:middle;">@chatBadge</span> }</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="@NavClass("User")" asp-controller="User" asp-action="Index" title="Users">
                        <i class="fas fa-users"></i>
                        <span>Users</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="@NavClass("ProjectTracker", "ActivityLog")" asp-controller="ProjectTracker" asp-action="ActivityLog" title="Log">
                        <i class="fas fa-history"></i>
                        <span>Log</span>
                    </a>
                </li>
            </ul>

        </nav>

        <div class="app-main">
            <header class="topbar">
                <div class="topbar-left">
                    <button type="button" class="topbar-toggle" data-sidebar-toggle aria-label="Toggle sidebar">
                        <i class="fas fa-bars"></i>
                    </button>
                    <span class="topbar-title">@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>
                @if (userId != null)
                {
                    <div class="topbar-right d-flex align-items-center gap-2">
                        <a asp-controller="User" asp-action="Details" asp-route-id="@userId" class="topbar-user">
                            @if (!string.IsNullOrEmpty(currentUserProfileImage))
                            {
                                <img src="@currentUserProfileImage" alt="@userName" class="topbar-user-avatar" style="object-fit: cover;" />
                            }
                            else
                            {
                                <span class="topbar-user-avatar">@userInitials</span>
                            }
                            <span class="topbar-user-info d-none d-sm-flex">
                                <span class="topbar-user-name">@userName</span>
                                <span class="topbar-user-role">@userRole</span>
                            </span>
                        </a>
                        <a asp-controller="Auth" asp-action="Logout" class="btn btn-sm btn-danger" title="Logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    </div>
                }
            </header>

            <main role="main" class="main-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
